# STEP 1: Import Dependencies
# ═══════════════════════════════════════════════════════════

from eu_vocabulary_corporate_body_monitor import CorporateBodyMonitor
from rdflib import Graph, Namespace, URIRef, Literal
from rdflib.namespace import RDF, XSD, DCTERMS
from datetime import datetime
from collections import defaultdict
import json
import os
import hashlib

print("✅ Dependencies imported!")

# ═══════════════════════════════════════════════════════════
# STEP 2: State Management (track what we've processed)
# ═══════════════════════════════════════════════════════════

class LDESStateManager:
    """Tracks which versions have already been processed."""
    
    def __init__(self, state_file="ldes_state.json"):
        self.state_file = state_file
        self.state = self._load()
    
    def _load(self):
        if os.path.exists(self.state_file):
            try:
                with open(self.state_file, 'r') as f:
                    return json.load(f)
            except json.JSONDecodeError:
                return self._default_state()
        return self._default_state()
    
    def _default_state(self):
        return {
            "processed_versions": [],
            "last_updated": None
        }
    
    def save(self):
        self.state["last_updated"] = datetime.now().isoformat()
        with open(self.state_file, 'w') as f:
            json.dump(self.state, f, indent=2)
    
    def is_processed(self, version):
        """Check if a version was already processed."""
        return version in self.state["processed_versions"]
    
    def mark_processed(self, version):
        """Mark a version as successfully processed."""
        if version not in self.state["processed_versions"]:
            self.state["processed_versions"].append(version)
        self.save()
    
    def get_last_processed(self):
        """Get the most recently processed version."""
        if self.state["processed_versions"]:
            return sorted(self.state["processed_versions"], reverse=True)[0]
        return None
    
    def reset(self):
        """Reset state (useful for testing)."""
        self.state = self._default_state()
        self.save()

print("✅ State manager ready!")

# ═══════════════════════════════════════════════════════════
# STEP 3: Check for New Versions
# ═══════════════════════════════════════════════════════════

monitor = CorporateBodyMonitor()
state = LDESStateManager()

# Get available versions from EU Publications Office
available_versions = monitor.get_available_versions()
last_processed = state.get_last_processed()

print(f"📦 Available versions: {len(available_versions)}")
print(f"   Latest:         {available_versions[0]}")
print(f"   Last processed: {last_processed or 'None (first run)'}")

# Determine what needs processing
if last_processed is None:
    # First run - compare the two most recent versions
    versions_to_compare = available_versions[:2]
    old_version = versions_to_compare[1]
    new_version = versions_to_compare[0]
    print(f"\n🆕 First run! Will compare: {old_version} → {new_version}")
else:
    # Find versions newer than last processed
    unprocessed = [v for v in available_versions if v > last_processed]
    if not unprocessed:
        print("\n✅ Already up to date! No new versions.")
        old_version = None
        new_version = None
    else:
        old_version = last_processed
        new_version = unprocessed[0]  # Process one at a time
        print(f"\n🔄 New version found! Will compare: {old_version} → {new_version}")

# ═══════════════════════════════════════════════════════════
# STEP 4: Download Versions and Calculate Differences
# ═══════════════════════════════════════════════════════════

if old_version and new_version:
    print(f"\n⬇️  Downloading {old_version}...")
    old_graph = monitor.download_version(old_version)
    print(f"   Loaded {len(old_graph)} triples")
    
    print(f"\n⬇️  Downloading {new_version}...")
    new_graph = monitor.download_version(new_version)
    print(f"   Loaded {len(new_graph)} triples")
    
    # Calculate the diff
    added_triples = new_graph - old_graph
    removed_triples = old_graph - new_graph
    
    print(f"\n🔄 Changes detected:")
    print(f"   ➕ Added:   {len(added_triples)} triples")
    print(f"   ➖ Removed: {len(removed_triples)} triples")

# ═══════════════════════════════════════════════════════════
# STEP 5: Group Changes by Subject (Concept)
# ═══════════════════════════════════════════════════════════

def group_by_subject(graph):
    """Group triples by their subject URI."""
    grouped = defaultdict(list)
    for s, p, o in graph:
        grouped[str(s)].append((p, o))
    return dict(grouped)

if old_version and new_version:
    added_by_subject = group_by_subject(added_triples)
    removed_by_subject = group_by_subject(removed_triples)
    
    # Categorize changes
    added_subjects = set(added_by_subject.keys())
    removed_subjects = set(removed_by_subject.keys())
    
    new_concepts = added_subjects - removed_subjects
    deleted_concepts = removed_subjects - added_subjects
    modified_concepts = added_subjects & removed_subjects
    
    print(f"\n📊 Change Summary:")
    print(f"   🆕 New concepts:      {len(new_concepts)}")
    print(f"   📝 Modified concepts: {len(modified_concepts)}")
    print(f"   🗑️  Deleted concepts:  {len(deleted_concepts)}")

# ═══════════════════════════════════════════════════════════
# STEP 6: Define LDES Namespaces
# ═══════════════════════════════════════════════════════════

# Standard LDES/TREE namespaces
LDES = Namespace("https://w3id.org/ldes#")
TREE = Namespace("https://w3id.org/tree#")
AS = Namespace("https://www.w3.org/ns/activitystreams#")
PROV = Namespace("http://www.w3.org/ns/prov#")

# Our stream's base URI
STREAM_BASE = "http://example.org/ldes/corporate-body"

print("✅ LDES namespaces defined:")
print(f"   LDES: {LDES}")
print(f"   TREE: {TREE}")
print(f"   AS:   {AS}")

# ═══════════════════════════════════════════════════════════
# STEP 7: Generate LDES Events
# ═══════════════════════════════════════════════════════════

def create_event_uri(subject, version):
    """Create a unique, deterministic event URI."""
    content = f"{subject}{version}"
    hash_id = hashlib.md5(content.encode()).hexdigest()[:12]
    return URIRef(f"{STREAM_BASE}/event/{hash_id}")

def create_event(subject, event_type, changes, version, timestamp):
    """Create a single LDES event."""
    event = Graph()
    event_uri = create_event_uri(subject, version)
    
    # Event metadata
    event.add((event_uri, RDF.type, AS[event_type]))
    event.add((event_uri, LDES.timestampPath, PROV.generatedAtTime))
    event.add((event_uri, PROV.generatedAtTime, Literal(timestamp, datatype=XSD.dateTime)))
    event.add((event_uri, AS.object, URIRef(subject)))
    event.add((event_uri, DCTERMS.source, Literal(f"corporate-body version {version}")))
    
    # Include the changed triples
    for predicate, obj in changes:
        event.add((URIRef(subject), predicate, obj))
    
    return event, event_uri

# Generate all events
if old_version and new_version:
    timestamp = datetime.now().isoformat()
    all_events = Graph()
    event_uris = []
    
    # Bind namespaces for clean output
    all_events.bind("ldes", LDES)
    all_events.bind("tree", TREE)
    all_events.bind("as", AS)
    all_events.bind("prov", PROV)
    all_events.bind("dcterms", DCTERMS)
    
    # Create events for new concepts
    for subject in new_concepts:
        event, uri = create_event(
            subject, "Create", 
            added_by_subject[subject], 
            new_version, timestamp
        )
        all_events += event
        event_uris.append(uri)
    
    # Create events for modified concepts
    for subject in modified_concepts:
        event, uri = create_event(
            subject, "Update",
            added_by_subject[subject],
            new_version, timestamp
        )
        all_events += event
        event_uris.append(uri)
    
    # Create events for deleted concepts
    for subject in deleted_concepts:
        event, uri = create_event(
            subject, "Delete",
            removed_by_subject[subject],
            new_version, timestamp
        )
        all_events += event
        event_uris.append(uri)
    
    print(f"\n✅ Generated {len(event_uris)} LDES events")
    print(f"   Total triples: {len(all_events)}")

# ═══════════════════════════════════════════════════════════
# STEP 8: Build the LDES Stream Structure
# ═══════════════════════════════════════════════════════════

if old_version and new_version:
    # Create the stream
    ldes_stream = Graph()
    stream_uri = URIRef(STREAM_BASE)
    
    # Bind namespaces
    ldes_stream.bind("ldes", LDES)
    ldes_stream.bind("tree", TREE)
    ldes_stream.bind("as", AS)
    ldes_stream.bind("prov", PROV)
    ldes_stream.bind("dcterms", DCTERMS)
    
    # Stream metadata
    ldes_stream.add((stream_uri, RDF.type, LDES.EventStream))
    ldes_stream.add((stream_uri, DCTERMS.title, Literal("Corporate Body Authority Table - LDES")))
    ldes_stream.add((stream_uri, DCTERMS.description, 
        Literal("Linked Data Event Stream of changes to the EU Corporate Body authority table")))
    ldes_stream.add((stream_uri, DCTERMS.source, 
        Literal("https://op.europa.eu/en/web/eu-vocabularies/dataset/-/resource?uri=http://publications.europa.eu/resource/dataset/corporate-body")))
    ldes_stream.add((stream_uri, LDES.timestampPath, PROV.generatedAtTime))
    
    # Link all events as members
    for event_uri in event_uris:
        ldes_stream.add((stream_uri, TREE.member, event_uri))
    
    # Combine stream metadata with events
    ldes_stream += all_events
    
    print(f"\n✅ LDES Stream built!")
    print(f"   Stream URI: {stream_uri}")
    print(f"   Members:    {len(event_uris)}")
    print(f"   Total triples: {len(ldes_stream)}")

# ═══════════════════════════════════════════════════════════
# STEP 9: Save the LDES
# ═══════════════════════════════════════════════════════════

if old_version and new_version:
    # Save as JSON-LD (most common LDES format)
    output_file = "corporate_body_ldes.jsonld"
    
    jsonld_output = ldes_stream.serialize(format="json-ld", indent=2)
    
    with open(output_file, "w") as f:
        f.write(jsonld_output)
    
    print(f"\n✅ LDES saved to: {output_file}")
    
    # Also save as Turtle for readability
    turtle_file = "corporate_body_ldes.ttl"
    turtle_output = ldes_stream.serialize(format="turtle")
    
    with open(turtle_file, "w") as f:
        f.write(turtle_output)
    
    print(f"✅ LDES saved to: {turtle_file}")
    
    # Mark version as processed
    state.mark_processed(new_version)
    print(f"\n✅ State updated: {new_version} marked as processed")

# ═══════════════════════════════════════════════════════════
# STEP 10: Preview the LDES
# ═══════════════════════════════════════════════════════════

if old_version and new_version:
    print("\n" + "═" * 60)
    print("📄 LDES PREVIEW (Turtle format)")
    print("═" * 60)
    print(turtle_output[:3000])
    if len(turtle_output) > 3000:
        print(f"\n... [{len(turtle_output) - 3000} more characters]")

