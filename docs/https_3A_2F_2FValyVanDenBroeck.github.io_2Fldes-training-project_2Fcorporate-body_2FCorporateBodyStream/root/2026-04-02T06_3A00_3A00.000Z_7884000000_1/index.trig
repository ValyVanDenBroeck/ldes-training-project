    <http://publications.europa.eu/ontology/authority/op-code> "BSSE";
    <http://publications.europa.eu/ontology/authority/start.use> "2007-02-23";
    <http://publications.europa.eu/ontology/authority/authority-code> "BSSE"
}
<../../../index.trig> <https://w3id.org/tree#member> <#bef49ae6ccee9f3004b35d8d3dc3cd2d>.
