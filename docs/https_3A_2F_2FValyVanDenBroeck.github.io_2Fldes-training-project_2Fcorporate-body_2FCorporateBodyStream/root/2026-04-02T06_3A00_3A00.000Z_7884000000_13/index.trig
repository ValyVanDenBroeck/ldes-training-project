    <http://www.w3.org/2004/02/skos/core#prefLabel> "Евридика"@bg, "Eurydice"@hu, "Eurydice"@fr, "Eurydice"@da, "Eurydice"@pl, "Eurydice"@fi, "Eurydice"@sv, "Eurydice"@mt, "Eurydice"@sl, "Eurydice"@el, "Eurydice"@et, "Eurydice"@nl, "Eurydice"@cs, "Eurydice"@ro, "Euridikė"@lt, "Eurydice"@es, "Eurydice"@sk, "Eurydice"@pt, "Eurydice"@en, "Eurydice"@de, "Eurydice"@ga, "Eurydice"@hr, "Eurydice"@lv, "Eurydice"@it;
    <http://www.w3.org/2004/02/skos/core#definition> "The Eurydice network supports and facilitates European cooperation in the field of lifelong learning by providing information on education systems and policies in 37 countries and by producing studies on issues common to European education systems."@en;
