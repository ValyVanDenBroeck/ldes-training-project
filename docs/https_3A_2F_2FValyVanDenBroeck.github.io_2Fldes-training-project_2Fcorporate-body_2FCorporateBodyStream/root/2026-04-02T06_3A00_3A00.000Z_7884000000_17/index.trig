    <http://publications.europa.eu/resource/authority/op-code> "UNRISD";
    <http://publications.europa.eu/ontology/authority/op-code> "UNRISD";
    <http://publications.europa.eu/ontology/authority/start.use> "1963-08-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNRISD";
