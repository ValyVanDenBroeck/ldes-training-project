    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.399Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#e6abfeb93267ff2fcc5fe63300065ffb> {
<http://publications.europa.eu/resource/authority/corporate-body/IBRD> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/8377>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Internationale Bank für Wiederaufbau und Entwicklung"@de, "Rahvusvaheline Rekonstruktsiooni- ja Arengupank"@et, "Den Internationale Bank for Genopbygning og Økonomisk Udvikling"@da, "Internationale Bank voor Herstel en Ontwikkeling"@nl, "Starptautiskā Rekonstrukcijas un attīstības banka"@lv, "Banca internazionale per la ricostruzione e lo sviluppo"@it, "Международна банка за реконструкция и развитие"@bg, "Kansainvälinen jälleenrakennus- ja kehityspankki"@fi, "Medzinárodná banka pre obnovu a rozvoj"@sk, "Међународна банка за обнову и развој"@sr, "An Banc Idirnáisiúnta Athfhoirgníochta agus Forbartha"@ga, "Bank Internazzjonali għar-Rikostruzzjoni u l-Iżvilupp"@mt, "Internationella banken för återuppbyggnad och utveckling"@sv, "Διεθνής Τράπεζα Ανασυγκρότησης και Ανάπτυξης"@el, "Banco Internacional para a Reconstrução e o Desenvolvimento"@pt, "Mednarodna banka za obnovo in razvoj"@sl, "Międzynarodowy Bank Odbudowy i Rozwoju"@pl, "Banca Internațională pentru Reconstrucție și Dezvoltare"@ro, "Tarptautinis rekonstrukcijos ir plėtros bankas"@lt, "Međunarodna banka za obnovu i razvoj"@hr, "Banco Internacional de Reconstrucción y Fomento"@es, "International Bank for Reconstruction and Development"@en, "Mezinárodní banka pro obnovu a rozvoj"@cs, "Nemzetközi Újjáépítési és Fejlesztési Bank"@hu, "Banque internationale pour la reconstruction et le développement"@fr;
    <http://www.w3.org/2004/02/skos/core#definition> "La Banque internationale pour la reconstruction et le développement (BIRD) a été fondée en 1944 afin d’accompagner la reconstruction de l’Europe au lendemain de la Seconde Guerre mondiale. De nos jours, ses prêts et son assistance sont essentiellement dirigés vers les pays à revenu intermédiaire. Institution « historique » du Groupe de la Banque mondiale, la BIRD œuvre aujourd’hui étroitement avec les autres institutions du Groupe pour aider les pays en développement à réduire la pauvreté, promouvoir la croissance économique et bâtir la prospérité. La BIRD appartient à ses 188 pays membres, ces derniers étant représentés au sein d’un Conseil (a) composé de 25 administrateurs (dont 5 administrateurs désignés et 20 administrateurs élus). Elle fournit des ressources financières mais aussi des services techniques et d’appui aux connaissances ainsi que des conseils stratégiques ; ses clients sont des pays en développement à revenu intermédiaire ou plus pauvres mais solvables."@fr, "The International Bank for Reconstruction and Development was created in 1944 to help Europe rebuild after World War II. Today, IBRD provides loans and other assistance primarily to middle income countries. IBRD is the original World Bank institution. It works closely with the rest of the World Bank Group to help developing countries reduce poverty, promote economic growth, and build prosperity. IBRD is owned by the governments of its 188 member countries, which are represented by a 25-member board of 5 appointed and 20 elected Executive Directors. The institution provides a combination of financial resources, knowledge and technical services, and strategic advice to developing countries, including middle income and credit-worthy lower income countries."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "IBRD"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001265"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "IBRD"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "IBRD"@en, "BIAF"@ga, "TRPB"@lt, "BIRS"@it, "BIRF"@es, "ΔΤΑΑ"@el, "BIRD"@pt, "BIRD"@fr, "BIRD"@ro, "МБВР"@bg, "IBRD"@sl, "IBRD"@hr, "IBRD"@mt, "IBRD"@lv, "IBRD"@nl, "IBRD"@fi, "IBRD"@de, "IBRD"@sk, "IBRD"@cs, "IBRD"@hu, "IBRD"@et, "IBRD"@da, "IBRD"@pl, "IBRD"@sv;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/IBRD_1951_0>;
    <http://purl.org/dc/elements/1.1/identifier> "IBRD";
    <http://publications.europa.eu/resource/authority/op-code> "IBRD";
    <http://publications.europa.eu/ontology/authority/op-code> "IBRD";
    <http://publications.europa.eu/ontology/authority/start.use> "1951-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "IBRD";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/WB>
}
<../../../index.trig> <https://w3id.org/tree#member> <#2f2c196c8777ebc706f6edc6fe2e5c2f>.
