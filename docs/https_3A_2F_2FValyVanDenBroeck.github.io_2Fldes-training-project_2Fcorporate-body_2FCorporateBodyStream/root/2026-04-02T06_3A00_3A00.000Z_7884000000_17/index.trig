    <http://www.w3.org/2004/02/skos/core#prefLabel> "International Trade Centre"@en, "Internationales Handelszentrum"@de, "Rahvusvaheline Kaubanduskeskus"@et, "Međunarodni trgovački centar"@hr, "Lárionad Trádála Idirnáisiúnta"@ga, "Ċentru Internazzjonali għall-Kummerċ"@mt, "Centro internazionale per il commercio"@it, "Mednarodni trgovinski center"@sl, "Międzynarodowe Centrum Handlu"@pl, "Tarptautinis prekybos centras"@lt, "Internationaal Handelscentrum"@nl, "Centro de Comercio Internacional"@es, "Internationella handelscentret"@sv, "Centre du commerce international"@fr, "Международен търговски център"@bg, "Centro de Comércio Internacional"@pt, "Nemzetközi Kereskedelmi Központ"@hu, "Medzinárodné obchodné centrum"@sk, "Centrul de comerț internațional"@ro, "Starptautiskais Tirdzniecības centrs"@lv, "Kansainvälisen kaupan keskus"@fi, "Det Internationale Handelscenter"@da, "Διεθνές Εμπορικό Επιμελητήριο"@el, "Mezinárodní obchodní centrum"@cs;
    <http://www.w3.org/2004/02/skos/core#definition> "The ITC has been recognized by the Economic and Social Council as the focal point of the United Nations system for technical cooperation with developing countries in trade promotion. The title \"International Trade Centre UNCTAD/WTO\" came into force on 1 Jan 1995, which was when the Centre began to be jointly operated by the World Trade Organization and the UN. Since 1984 ITC has been an executing agency of the United Nations Development Programme (UNDP), directly responsible for implementing UNDP-financed projects in developing countries and economies in transition related to trade promotion."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ITC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "ITC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001271"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Kansainvälinen kauppakeskus (UNCTAD/WTO)"@fi, "Internationales Handelszentrum UNCTAD/WTO"@de, "ITC"@en, "ITC"@da, "ITC"@cs, "ITC"@de, "ITC"@nl, "ITC"@lv, "ITC"@fi, "ITC"@mt, "ITC"@it, "Mednarodni trgovinski center Unctad/WTO"@sl, "ITC"@sv, "Διεθνές Εμπορικό Κέντρο UNCTAD/WTO"@el, "ITC"@sk, "Centro de Comercio Internacional UNCTAD/OMC"@es, "Internationaal Handelscentrum (UNCTAD/GATT)"@nl, "{ITC (Unctad/WTO)}"@sl, "CCI"@fr, "CCI"@es, "CCI"@pt, "Det Internationale Handelscenter (UNCTAD-WTO)"@da, "Międzynarodowe Centrum Handlu (UNCTAD/WTO)"@pl, "Mezinárodní obchodní centrum UNCTAD/WTO"@cs, "ITC (Unctad/WTO)"@sl, "Contrul de comerț internațional OMC-UNCTAD"@ro, "Lárionad Trádála Idirnáisiúnta UNCTAD/WTO"@ga, "Centre CNUCED/OMC du commerce international"@fr, "МТЦ"@bg;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ITC_1984_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ITC";
    <http://publications.europa.eu/resource/authority/op-code> "ITC";
    <http://publications.europa.eu/ontology/authority/op-code> "ITC";
    <http://publications.europa.eu/ontology/authority/start.use> "1984-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "ITC";
