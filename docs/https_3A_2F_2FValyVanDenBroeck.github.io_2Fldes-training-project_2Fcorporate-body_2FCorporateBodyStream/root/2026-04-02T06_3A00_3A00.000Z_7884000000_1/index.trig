    <http://www.w3.org/2004/02/skos/core#prefLabel> "Zahodnoafriška ekonomska in monetarna unija"@sl, "Lääne-Aafrika Majandus- ja Rahaliit"@et, "Unione economica e monetaria dell’Africa occidentale"@it, "Δυτικοαφρικανική Οικονομική και Νομισματική Ένωση"@el, "Länsi-Afrikan talous- ja rahaliitto"@fi, "Západoafrická hospodárska a menová únia"@sk, "Westafrikanische Wirtschafts- und Währungsunion"@de, "Unión Económica y Monetaria del África Occidental"@es, "West African Economic and Monetary Union"@en, "União Económica e Monetária da África Ocidental"@pt, "Zachodnioafrykańska Unia Gospodarcza i Walutowa"@pl, "Vakarų Afrikos ekonominė ir pinigų sąjunga"@lt, "Den Vestafrikanske Økonomiske og Monetære Union"@da, "Västafrikanska ekonomiska och monetära unionen"@sv, "Západoafrická ekonomická a měnová unie"@cs, "Uniunea Economică și Monetară a Africii de Vest"@ro, "Zapadnoafrička ekonomska i monetarna unija"@hr, "Rietumāfrikas Ekonomikas un valūtas savienība"@lv, "West-Afrikaanse Economische en Monetaire Unie"@nl, "Nyugat-afrikai Gazdasági és Monetáris Unió"@hu, "Union économique et monétaire ouest-africaine"@fr, "Западноафрикански икономически и валутен съюз"@bg, "Unjoni Ekonomika u Monetarja tal-Afrika tal-Punent"@mt, "Aontas Eacnamaíoch agus Airgeadaíochta na hAfraice Thiar"@ga;
    <http://www.w3.org/2004/02/skos/core#definition> "The West African Economic and Monetary Union is an organization of eight West African states. It was established to promote economic integration among countries that share the CFA franc as a common currency. It is a customs union and currency union between the members of Economic Community of West African States."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001039"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "WAEMU"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "WAEMU"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "WAEMU"@sv, "WAEMU"@en, "WAEMU"@sl, "UEMOA"@da, "UEMOA"@fr, "UEMOA"@it, "UEMOA"@ro, "UEMOA"@cs, "UEMOA"@hu, "UEMOA"@de, "Uemoa"@nl, "UEMOA"@pl, "UEMOA"@sk, "UEMOA"@fi, "UEMOA"@pt, "UEMOA"@es, "UEMOA"@mt, "UEMOA"@bg, "VAEPS"@lt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/WAEMU_1994_0>;
