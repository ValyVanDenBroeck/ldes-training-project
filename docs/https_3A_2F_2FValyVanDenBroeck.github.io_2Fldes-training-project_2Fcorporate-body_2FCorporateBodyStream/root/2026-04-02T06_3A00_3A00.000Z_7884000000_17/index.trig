    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Comisia economică a Organizației Națiunilor Unite pentru America Latină"@ro, "United Nations Economic Commission for Latin America"@en, "Comissão Económica das Nações Unidas para a América Latina"@pt, "Comisión Económica para América Latina de las Naciones Unidas"@es, "Commission économique des Nations unies pour l’Amérique latine"@fr, "Kummissjoni Ekonomika tan-Nazzjonijiet Uniti għall-Amerika Latina"@mt, "Economische Commissie der Verenigde Naties voor Latijns-Amerika (VN)"@nl, "Икономическа комисия на ООН за Латинска Америка"@bg, "Apvienoto Nāciju Organizācijas Ekonomikas komisija Latīņamerikai"@lv, "YK:n Latinalaisen Amerikan talouskomissio"@fi, "Ühinenud Rahvaste Organisatsiooni Ladina-Ameerika majanduskomisjon"@et;
    <http://www.w3.org/2004/02/skos/core#definition> "The Economic Commission for Latin America was established by Economic and Social Council resolution 106(VI). The scope of the Commission’s work was later broadened to include the countries of the Caribbean, and by resolution 1984/67 of 27 July 1984, the Economic Council decided to change its name to the Economic Commission for Latin America and the Caribbean."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNECLA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001195"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNECLA"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "CEPAL"@es, "Comissão Económica para a América Latina"@pt, "ECLA"@en, "Comisión Económica para América Latina"@es, "CEAL"@pt, "Commission économique pour l’Amérique latine"@fr, "Economic Commission for Latin America"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNECLA_1948_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNECLA";
    <http://publications.europa.eu/resource/authority/op-code> "UNECLA";
    <http://publications.europa.eu/ontology/authority/op-code> "UNECLA";
    <http://publications.europa.eu/ontology/authority/start.use> "1948-03-15";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNECLA";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
