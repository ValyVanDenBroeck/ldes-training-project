<../../../index.trig> <https://w3id.org/tree#member> <#cbfc013b226e61098eee1731a8cd7e4b>.
<#cbfc013b226e61098eee1731a8cd7e4b> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/ETUI_1978_0>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:07.996Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#cbfc013b226e61098eee1731a8cd7e4b> {
<http://publications.europa.eu/resource/authority/corporate-body/ETUI_1978_0> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Istitut Ewropew tat-Trade Unions"@mt, "Euroopa Ametiühingute Instituut"@et, "Euroopan ammattiyhdistysinstituutti"@fi, "Europees Vakbondsinstituut"@nl, "European Trade Union Institute"@en, "Istituto sindacale europeo"@it, "Institut syndical européen"@fr, "Europos profesinių sąjungų institutas"@lt, "Instituto Sindical Europeo"@es, "Eiropas Arodbiedrību institūts"@lv, "Европейски синдикален институт"@bg, "Európsky odborový inštitút"@sk;
    <http://www.w3.org/2004/02/skos/core#definition> "ETUI was founded on the initiative of the European Trade Union Confederation. ETUI’s aim was to form a bridge between the trade union movement and the academic world; keep trade union organisations informed about various European matters affecting trade union policy and its implementation; conduct and promote intellectually independent research in two areas on topics of strategic importance for the trade unions: Europeanisation of industrial relations (Unit I) and Employment, labour markets and social protection (Unit II). In April 2005, the three former ETUC centres of expertise – the European Trade Union Institute (ETUI), the European Trade Union College (ETUCO), and the European Trade Union Technical Bureau for Health and Safety (TUTB), joined together to form the European Trade Union Institute (ETUI)."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ETUI"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001288"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ETUI"@en, "ETUI"@hr, "EVI"@nl, "EPSI"@lt, "ETUI"@pl, "EAI"@lv, "DEFI"@da, "EGI"@de, "ISE"@es, "ISE"@fr, "ISE"@it, "ISE"@pt, "Euroopan ammattiyhdistysinstituutin tutkimuslaitos"@fi, "ETUI-REHS"@et, "ETUI-REHS"@el, "ETUI-REHS"@cs, "Institutul Sindical European pentru Cercetare, Educație și Sănătate și Securitate"@ro, "Europeiska fackföreningsinstitutet för forskning, utbildning och hälsa och säkerhet"@sv, "Instituto Sindical Europeu – Investigação, Educação, Saúde e Segurança"@pt, "Európsky odborový inštitút pre výskum, vzdelávanie, zdravie a bezpečnosť"@sk, "Europejski Instytut Związków Zawodowych na rzecz Badań, Kształcenia i BHP"@pl, "Evropski sindikalni inštitut – raziskave, izobraževanje, zdravje in varnost"@sl, "Europos profesinių sąjungų tyrimų, švietimo, sveikatos ir saugos darbe institutas"@lt, "Eiropas Arodbiedrību pētniecības, izglītības, darba drošības un veselības aizsardzības institūts"@lv, "Ευρωπαϊκό Συνδικαλιστικό Ίδρυμα – Έρευνα, Εκπαίδευση, Υγεία και Ασφάλεια"@el, "European Trade Union Institute for Research, Education and Health and Safety"@en, "ЕСИ–ИОЗБ"@bg, "Instituto Sindical Europeo para Investigación, Educación e Higiene y Seguridad"@es, "Европейски синдикален институт за изследвания, обучение, здраве и безопасност"@bg, "Europees Vakbondsinstituut – onderzoek, onderwijs, gezondheid en veiligheid"@nl, "Evropský odborový institut pro výzkum, vzdělávání a BOZP Odborový institut pro Evropu"@cs, "Euroopa ametiühingute instituut teaduse, hariduse, tervishoiu ja ohutuse vallas"@et, "Europski sindikalni institut za istraživanje, edukaciju, zdravlje i sigurnost"@hr, "Institut syndical européen pour la recherche, la formation et la santé-sécurité"@fr, "Istituto sindacale europeo per la ricerca, la formazione, la salute e la sicurezza"@it, "Europäisches Gewerkschaftsinstitut für Forschung, Bildung und Arbeits- und Gesundheitsschutz"@de, "L-Istitut Ewropew tat-Trade Unions – Riċerka, Edukazzjoni, Saħħa u Sigurtà"@mt, "Európai Szakszervezeti Intézet – Kutatás, oktatás, egészség és biztonság"@hu;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ETUI_1978_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ETUI_1978_0";
