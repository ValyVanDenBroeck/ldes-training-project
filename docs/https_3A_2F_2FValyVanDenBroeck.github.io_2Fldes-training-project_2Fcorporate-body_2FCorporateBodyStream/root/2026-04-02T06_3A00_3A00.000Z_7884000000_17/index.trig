<../../../index.trig> <https://w3id.org/tree#member> <#182a5c00c6aacaf73e70fd865d6fd7dc>.
<#182a5c00c6aacaf73e70fd865d6fd7dc> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNSCOM>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.133Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#182a5c00c6aacaf73e70fd865d6fd7dc> {
<http://publications.europa.eu/resource/authority/corporate-body/UNSCOM> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Statistična komisija Združenih narodov"@sl, "Štatistická komisia OSN"@sk, "Ühinenud Rahvaste Organisatsiooni statistikakomisjon"@et, "United Nations Statistical Commission"@en, "De Forenede Nationers statistiske kommission"@da, "Comisia pentru statistică a Organizației Națiunilor Unite"@ro, "Comisión de Estadística de las Naciones Unidas"@es, "Statistická komise OSN"@cs, "Jungtinių Tautų Statistikos komisija"@lt, "Στατιστική Επιτροπή των Ηνωμένων Εθνών"@el, "Comissão de Estatísticas das Nações Unidas"@pt, "FN:s statistikkommission"@sv, "Статистическа комисия на Обединените нации"@bg, "Apvienoto Nāciju Organizācijas Statistikas komisija"@lv, "Commissione statistica delle Nazioni Unite"@it, "Statistička komisija Ujedinjenih naroda"@hr, "Statistikkommission der Vereinten Nationen"@de, "Kummissjoni tan-Nazzjonijiet Uniti tal-Istatistika"@mt, "Commission de statistique des Nations unies"@fr, "YK:n tilastokomissio"@fi, "Statistische Commissie van de Verenigde Naties"@nl, "Az ENSZ Statisztikai Bizottsága"@hu, "Komisja Statystyczna ONZ"@pl, "Coimisiún Staidrimh na Náisiún Aontaithe"@ga;
    <http://www.w3.org/2004/02/skos/core#definition> "The United Nations Statistical Commission is the highest body of the global statistical system. It brings together the Chief Statisticians from member states from around the world. It is the highest decision making body for international statistical activities especially the setting of statistical standards, the development of concepts and methods and their implementation at the national and international level. The Statistical Commission oversees the work of the United Nations Statistics Division and is a Functional Commission of the UN Economic and Social Council."@en, "La Commission de statistique a été créée, et dotée d’un mandat, par le Conseil économique et social sur la base des recommandations formulées lors de la première session (nucléaire) de la Commission. Le mandat de la Commission, (...) indique que la Commission a pour fonction d’aider le Conseil : «a ) À favoriser le développement des statistiques sur le plan national et l’amélioration de leur comparabilité; b) À coordonner les activités des institutions spécialisées en matière de statistiques; c) À développer le Service central de statistique du Secrétariat;d) À donner des avis aux divers organes des Nations Unies sur ces questions générales relatives à la centralisation, à l’interprétation et à la diffusion des données statistiques; e) À favoriser le perfectionnement des statistiques et des méthodes de statistique en général.»."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "UNSCOM"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "UNSCOM"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001223"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UNSC"@en, "Kommissionen för statistik"@sv, "Den Statistiske Kommission"@da, "Comisión de Estadística"@es, "Tilastotoimikunta"@fi, "Статистическа комисия"@bg, "Komisja Statystyczna"@pl, "Statistična komisija"@sl, "Statistická komise"@cs, "UNSC"@mt, "Στατιστική Επιτροπή"@el, "Comisia pentru statistică"@ro, "Statistische Commissie"@nl, "Statistikas komisija"@lv, "Statistische Kommission"@de, "Comissão de Estatística"@pt, "Kummissjoni tal-Istatistika"@mt, "CENU"@es, "Statistikos komisija"@lt, "Statisztikai Bizottság"@hu, "Statistikakomisjon"@et, "Commissione di statistica"@it, "An Coimisiún Staidrimh"@ga, "Commission de statistique"@fr;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNSCOM_1947_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNSCOM";
    <http://publications.europa.eu/resource/authority/op-code> "UNSCOM";
    <http://publications.europa.eu/ontology/authority/op-code> "UNSCOM";
    <http://publications.europa.eu/ontology/authority/start.use> "1947-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNSCOM";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
<../../../index.trig> <https://w3id.org/tree#member> <#d2fa5ade648e9ad78440289b91b0f6ff>.
<#d2fa5ade648e9ad78440289b91b0f6ff> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNCOMPD>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.139Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d2fa5ade648e9ad78440289b91b0f6ff> {
<http://publications.europa.eu/resource/authority/corporate-body/UNCOMPD> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "De Forenede Nationers Kommission for Befolkning og Udvikling"@da, "Komise OSN pro populaci a rozvoj"@cs, "Комисия на ООН по населението и развитието"@bg, "Comisión de Población y Desarrollo de las Naciones Unidas"@es, "FN:s kommission för befolkning och utveckling"@sv, "YK:n väestö- ja kehityskysymysten toimikunta"@fi, "Jungtinių Tautų Gyventojų ir vystymosi komisija"@lt, "Commissie Bevolking en Ontwikkeling van de Verenigde Naties"@nl, "Kummissjoni tan-Nazzjonijiet Uniti dwar il-Popolazzjoni u l-Iżvilupp"@mt, "Επιτροπή των Ηνωμένων Εθνών για τον πληθυσμό και την ανάπτυξη"@el, "Apvienoto Nāciju Organizācijas Iedzīvotāju un attīstības komisija"@lv, "Komisija Ujedinjenih naroda za stanovništvo i razvoj"@hr, "Kommission der Vereinten Nationen für Bevölkerung und Entwicklung"@de, "Comisia Națiunilor Unite pentru populație și dezvoltare"@ro, "Comissão de População e Desenvolvimento das Nações Unidas"@pt, "Komisja ONZ ds. Ludności i Rozwoju"@pl, "ÜRO rahvastiku- ja arengukomisjon"@et, "Commission des Nations unies de la population et du développement"@fr, "Commissione delle Nazioni Unite su popolazione e sviluppo"@it, "Komisia OSN pre populáciu a rozvoj"@sk, "Komisija Združenih narodov za prebivalstvo in razvoj"@sl, "United Nations Commission on Population and Development"@en, "Coimisiún na Náisiún Aontaithe maidir le Daonra agus Forbairt"@ga, "Az ENSZ Népesedésügyi és Fejlesztési Bizottsága"@hu;
    <http://www.w3.org/2004/02/skos/core#definition> "The Commission is to assist the Council by: arranging for studies and advising the Council; Monitoring, reviewing and assessing the implementation of the Programme of Action of the International Conference on Population and Development at the national, regional and global levels, identifying reasons for success and failure, and advising the Council thereon; Providing appropriate recommendations to the Council on the basis of an integrated consideration of the reports and issues related to the implementation of the Programme of Action."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNCOMPD"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNCOMPD"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001211"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Komisija za prebivalstvo in razvoj"@sl, "Väestö- ja kehitystoimikunta"@fi, "CPD"@sk, "CPD"@en, "CPD"@it, "Commissie Bevolking en Ontwikkeling"@nl, "Commissione sulla popolazione e lo sviluppo"@it, "An Coimisiún maidir le Daonra agus Forbairt"@ga, "Comisión de Población y Desarrollo"@es, "Комисия по населението и развитието"@bg, "Comissão sobre População e Desenvolvimento"@pt, "Gyventojų ir vystymosi komisija"@lt, "Comisia pentru populație și dezvoltare"@ro, "Iedzīvotāju un attīstības komisija"@lv, "Kommissionen för befolkning och utveckling"@sv, "Commission on Population and Development"@en, "Rahvastiku- ja arengukomisjon"@et, "Commission de la population et du développement"@fr, "Kummissjoni dwar il-Popolazzjoni u l-Iżvilupp"@mt, "Komisia pre populáciu a rozvoj"@sk, "Népesedésügyi és Fejlesztési Bizottság"@hu;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCOMPD_1994_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCOMPD";
    <http://publications.europa.eu/resource/authority/op-code> "UNCOMPD";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCOMPD";
    <http://publications.europa.eu/ontology/authority/start.use> "1994-12-19";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCOMPD";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
