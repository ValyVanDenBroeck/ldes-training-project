    <http://www.w3.org/2004/02/skos/core#prefLabel> "Διεθνής Ένωση Aεροπορικών Μεταφορών"@el, "Mezinárodní sdružení leteckých dopravců"@cs, "Udruga za međunarodni zračni prijevoz"@hr, "Starptautiskā Gaisa transporta asociācija"@lv, "Alþjóðasamband flugfélaga"@is, "Rahvusvaheline Lennutranspordi Assotsiatsioon"@et, "Internationaler Luftverkehrsverband"@de, "Associazione internazionale del trasporto aereo"@it, "Den Internationale Luftfartssammenslutning"@da, "Asociația Internațională de Transport Aerian"@ro, "Medzinárodné združenie leteckých prepravcov"@sk, "An Comhlachas Aeriompair Idirnáisiúnta"@ga, "Association du transport aérien international"@fr, "Assoċjazzjoni Internazzjonali tat-Trasport bl-Ajru"@mt, "Internationella lufttransportorganisationen"@sv, "Associação do Transporte Aéreo Internacional"@pt, "Zrzeszenie Międzynarodowego Transportu Lotniczego"@pl, "Nemzetközi Légiszállítási Szövetség"@hu, "Kansainvälinen ilmakuljetusliitto"@fi, "Международна асоциация за въздушен транспорт"@bg, "Internationale vereniging voor luchtvervoer"@nl, "Asociación de Transporte Aéreo Internacional"@es, "Tarptautinė oro transporto asociacija"@lt, "ИАТА"@sr, "Uluslararası Hava Taşımacılığı Birliği"@tr, "International Air Transport Association"@en, "Mednarodno združenje letalskih prevoznikov"@sl;
    <http://www.w3.org/2004/02/skos/core#definition> "The International Air Transport Association (IATA) works with its airline members and the air transport industry as a whole to promote safe, reliable, secure and economical air travel for the benefit of the world’s consumers. IATA sets standards in many areas of the business – from ticketing to baggage – that make it possible for passengers to travel from one place to another using two or more airlines. It also leads a number of industry initiatives involving safety, security, environment and the quality of air travel."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001176"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "IATA"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "IATA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "IATA"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Iata"@sv, "IATA"@fi, "IATA"@da, "IATA"@lt, "IATA"@sk, "IATA"@mt, "IATA"@el, "IATA"@de, "IATA"@pt, "IATA"@ga, "IATA"@hu, "IATA"@nl, "IATA"@hr, "IATA"@lv, "IATA"@fr, "IATA"@sl, "IATA"@cs, "IATA"@ro, "IATA"@pl, "IATA"@et, "IATA"@it, "IATA"@en, "AITA"@es;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/IATA_1945_0>;
    <http://purl.org/dc/elements/1.1/identifier> "IATA";
