<../../../index.trig> <https://w3id.org/tree#member> <#7fa46d981a60f1f082786c9de5ccd7cd>.
<#7fa46d981a60f1f082786c9de5ccd7cd> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/EEAREA_COUN>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.855Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#7fa46d981a60f1f082786c9de5ccd7cd> {
<http://publications.europa.eu/resource/authority/corporate-body/EEAREA_COUN> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "EØS-Rådet"@da, "ETA:n neuvosto"@fi, "Kunsill taż-ŻEE"@mt, "Rada EOG"@pl, "EEZ Padome"@lv, "EER-Raad"@nl, "Consiglio SEE"@it, "Conselho do EEE"@pt, "EEA Council"@en, "Conseil de l’EEE"@fr, "Съвет на ЕИП"@bg, "Consejo del EEE"@es, "Rada EHP"@cs, "Rada EHP"@sk, "EES-rådet"@sv, "EWR-Rat"@de, "EEE taryba"@lt, "Vijeće EGP-a"@hr, "Consiliul SEE"@ro, "Svet EGP"@sl, "EMP nõukogu"@et, "EGT-Tanács"@hu, "Comhairle LEE"@ga, "Συμβούλιο ΕΟΧ"@el;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Economic Area Council meets twice a year at ministerial level and provides political impetus for the development of the EEA Agreement. The EEA EFTA States are represented in the EEA Council by their respective ministers of foreign or European affairs. The European Union is represented by the rotating presidency of the Council of the EU, as well as representatives of the European External Action Service and the European Commission."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EEAREA_COUN"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "EEAREA_COUN"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001577"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Rada Európskeho hospodárskeho priestoru"@sk, "Съвет на Европейското икономическо пространство"@bg, "Europos ekonominės erdvės taryba"@lt, "Conseil de l’Espace économique européen"@fr, "Raad van de Europese Economische Ruimte"@nl, "Vijeće Europskoga gospodarskog prostora"@hr, "Euroopan talousalueen neuvosto"@fi, "Comhairle an Limistéir Eorpaigh Eacnamaíoch"@ga, "Svet Evropskega gospodarskega prostora"@sl, "Rat des Europäischen Wirtschaftsraums"@de, "Consejo del Espacio Económico Europeo"@es, "Az Európai Gazdasági Térség Tanácsa"@hu, "Consiglio dello Spazio economico europeo"@it, "European Economic Area Council"@en, "Rada pro Evropský hospodářský prostor"@cs, "Rada Europejskiego Obszaru Gospodarczego"@pl, "Consiliul Spațiului Economic European"@ro, "Συμβούλιο του Ευρωπαϊκού Οικονομικού Χώρου"@el, "Eiropas Ekonomikas zonas Padome"@lv, "Kunsill taż-Żona Ekonomika Ewropea"@mt, "Conselho do Espaço Económico Europeu"@pt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EEAREA_COUN_1994_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EEAREA_COUN";
