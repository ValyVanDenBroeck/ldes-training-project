<../../../index.trig> <https://w3id.org/tree#member> <#67fbce8bd735e36cf38ea3e23a41a86c>.
<#67fbce8bd735e36cf38ea3e23a41a86c> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNPCOM>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.234Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#67fbce8bd735e36cf38ea3e23a41a86c> {
<http://publications.europa.eu/resource/authority/corporate-body/UNPCOM> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "United Nations Population Commission"@en, "Kummissjoni tan-Nazzjonijiet Uniti dwar il-Popolazzjoni"@mt, "YK:n väestökysymysten toimikunta"@fi, "Comisión de Población de las Naciones Unidas"@es, "Apvienoto Nāciju Organizācijas Iedzīvotāju komisija"@lv, "ÜRO rahvastikukomisjon"@et, "Commission des Nations unies de la population"@fr, "Комисия на ООН за населението"@bg;
    <http://www.w3.org/2004/02/skos/core#definition> "A Population Commission was established by the Economic and Social Council in its resolution 3 (III) of 3 October 1946. In its resolution 49/128 of 19 December 1994, the General Assembly decided that the Commission should be renamed the Commission on Population and Development. In the same resolution, the Assembly decided that it, the Council and the Commission should constitute a three-tiered intergovernmental mechanism that would play the primary role in the follow-up to the implementation of the Programme of Action of the International Conference on Population and Development, and that the Commission, as a functional commission assisting the Council, would monitor, review and assess the implementation of the Programme of Action at the national, regional and international levels and advise the Council thereon."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNPCOM"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNPCOM"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001212"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Population Commission"@en, "Commission de la population"@fr, "Comisión de Población"@es;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNPCOM_1946_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNPCOM";
    <http://publications.europa.eu/resource/authority/op-code> "UNPCOM";
    <http://publications.europa.eu/ontology/authority/op-code> "UNPCOM";
    <http://publications.europa.eu/ontology/authority/start.use> "1946-10-03";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNPCOM";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1994-12-18"
}
<../../../index.trig> <https://w3id.org/tree#member> <#273e33f9176d28bf83175e4f1b7085b0>.
<#273e33f9176d28bf83175e4f1b7085b0> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNCHR>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.245Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#273e33f9176d28bf83175e4f1b7085b0> {
<http://publications.europa.eu/resource/authority/corporate-body/UNCHR> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Jungtinių Tautų Gyventojų ir vystymosi komisija"@lt, "YK:n ihmisoikeustoimikunta"@fi, "Comissão dos Direitos do Homem das Nações Unidas"@pt, "Coimisiún na Náisiún Aontaithe um Chearta an Duine"@ga, "Komise OSN pro lidská práva"@cs, "Commission des Nations unies des droits de l’homme"@fr, "Ühinenud Rahvaste Organisatsiooni inimõiguste komisjon"@et, "Comisia Organizației Națiunilor Unite pentru drepturile omului"@ro, "Kummissjoni tan-Nazzjonijiet Uniti dwar id-Drittijiet tal-Bniedem"@mt, "FN:s kommission för de mänskliga rättigheterna"@sv, "United Nations Commission on Human Rights"@en, "Komisija Združenih narodov za človekove pravice"@sl, "Komisia OSN pre ľudské práva"@sk, "Komisja Praw Człowieka ONZ"@pl, "Apvienoto Nāciju Organizācijas Cilvēktiesību komisija"@lv, "Комисия на ООН по правата на човека"@bg, "Comisión de Derechos Humanos de las Naciones Unidas"@es, "Επιτροπή των Ηνωμένων Εθνών για τα Ανθρώπινα Δικαιώματα"@el;
    <http://www.w3.org/2004/02/skos/core#definition> "La Commission des droits de l’homme de l’Organisation des Nations Unies est le principal organe chargé de la promotion des droits de l’homme du monde. Créée en 1946 afin de mettre en place la trame juridique internationale qui protège nos libertés et droits fondamentaux, son mandat s’est développé au fil des ans de sorte qu’elle puisse répondre à l’ensemble des questions liées aux droits de l’homme. Le 15 mars 2006, l’Assemblée Générale a adopté la résolution A/RES/60/251 qui établit le Conseil des Droits de l’Homme. Le 27 mars 2006, la Commission des Droits de l’Homme a conclu sa soixante-deuxième et ultime session."@fr, "The United Nations Commission on Human Rights was established to weave the international legal fabric that protects our fundamental rights and freedoms. Composed of 53 States members, its brief expanded over time to allow it to respond to the whole range of human rights problems and it set standards to govern the conduct of States. It also acted as a forum where countries large and small, non-governmental groups and human rights defenders from around the world voiced their concerns."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNCHR"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "ONU-HOMME"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "UNCHR"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001208"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Comisión de Derechos Humanos"@es, "Commissie voor de rechten van de mens"@nl, "Menschenrechtskommission"@de, "Commission des droits de l’homme"@fr, "Commission on Human Rights"@en, "Комисия по правата на човека"@bg, "Comissão dos Direitos do Homem"@pt, "Emberi Jogok Bizottsága"@hu, "Ihmisoikeustoimikunta"@fi, "Commissione per i diritti umani"@it, "Kummissjoni dwar id-Drittijiet tal-Bniedem"@mt, "Komise pro lidská práva"@cs, "Žmogaus teisių komisija"@lt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCHR_1946_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCHR";
    <http://publications.europa.eu/resource/authority/op-code> "UNCHR";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCHR";
    <http://publications.europa.eu/ontology/authority/start.use> "1946-02-16";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCHR";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b5368_b5367_b5366_df_15_1444;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "2006-03-14".
_:b5368_b5367_b5366_df_15_1444 a <http://publications.europa.eu/ontology/authority/MappedCode>;
    <http://purl.org/dc/elements/1.1/source> "EurLex";
    <http://publications.europa.eu/ontology/authority/affected-table> "FD_050";
    <http://publications.europa.eu/ontology/authority/legacy-code> "ONU-HOMME"
}
