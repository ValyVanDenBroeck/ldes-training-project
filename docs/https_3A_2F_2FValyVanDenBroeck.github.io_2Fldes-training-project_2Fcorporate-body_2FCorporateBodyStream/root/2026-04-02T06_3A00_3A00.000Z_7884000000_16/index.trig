<#4343c2d9a4ee4f579506f2030583649a> {
<http://publications.europa.eu/resource/authority/corporate-body/EFTA_CC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "EBTA Konsultatīvā komiteja"@lv, "EFTAn konsultatiivinen komitea"@fi, "Kumitat Konsultattiv tal-EFTA"@mt, "Det Rådgivende EFTA-Udvalg"@da, "EFTA nõuandekomitee"@et, "Poradní výbor ESVO"@cs, "EFTA konzultatív bizottság"@hu, "Coiste Comhairleach CSTE"@ga, "EFTA Consultative Committee"@en, "ELPA konsultacinis komitetas"@lt, "Comité Consultivo da EFTA"@pt, "Comitato consultivo EFTA"@it, "Savjetodavni odbor za EFTA-u"@hr, "Eftas rådgivande kommitté"@sv, "Komitet Konsultacyjny EFTA"@pl, "Συμβουλευτική Επιτροπή ΕΖΕΣ"@el, "Comité consultatif de l’AELE"@fr, "Comité Consultivo de la AELC"@es, "Posvetovalni odbor Efte"@sl, "Консултативен комитет на ЕАСТ"@bg, "Poradný výbor EZVO"@sk, "EFTA-Konsultativkomitee"@de, "Comitetul consultativ al AELS"@ro, "Raadgevend Comité van de EVA"@nl;
    <http://www.w3.org/2004/02/skos/core#definition> "The Consultative Committee of the European Free Trade Association (EFTA) is a forum for trade unions and employers’ organisations in the four member countries, Iceland, Liechtenstein, Norway and Switzerland. Through its co-operation with social partners in the European Union, the Committee also serves as a link between social partners in EFTA and in the EU."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EFTA_CC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "EFTA_CC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001581"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "European Free Trade Association Consultative Committee"@en, "Comité consultatif de l’Association européenne de libre-échange"@fr;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EFTA_CC_1961_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EFTA_CC";
    <http://publications.europa.eu/resource/authority/op-code> "EFTA_CC";
    <http://publications.europa.eu/ontology/authority/op-code> "EFTA_CC";
    <http://publications.europa.eu/ontology/authority/start.use> "1961-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "EFTA_CC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/EFTA>
}
