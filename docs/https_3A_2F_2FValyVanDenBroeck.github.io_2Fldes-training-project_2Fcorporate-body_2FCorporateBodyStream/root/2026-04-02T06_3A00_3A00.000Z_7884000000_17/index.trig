    <http://publications.europa.eu/ontology/authority/op-code> "IMO";
    <http://publications.europa.eu/ontology/authority/start.use> "1982-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "IMO";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b5254_b5253_b5252_df_15_1439;
