    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Comissão Parlamentar da EFTA"@pt, "EFTAn parlamentaarinen komitea"@fi, "EFTA-Parlamentarikerudvalget"@da, "Commissione parlamentare EFTA"@it, "EBTA Parlamentārā komiteja"@lv, "Comité parlementaire de l’AELE"@fr, "EFTA Parliamentary Committee"@en, "Parlamentný výbor EZVO"@sk, "Komitet Parlamentarny EFTA"@pl, "Parlamentní výbor ESVO"@cs, "Κοινοβουλευτική Επιτροπή ΕΖΕΣ"@el, "Parlamentarischer EFTA-Ausschuss"@de, "Parlamentarni odbor EFTA-e"@hr, "Парламентарен комитет на ЕАСТ"@bg, "Coiste Parlaiminteach CSTE"@ga, "Eftas parlamentarikerkommitté"@sv, "EFTA parlamentaarne komitee"@et, "Parlementair Comité van de EVA"@nl, "Comisia parlamentară a AELS"@ro, "Comité Parlamentario de la AELC"@es, "Parlamentarni odbor Efte"@sl, "EFTA Parlamenti Bizottság"@hu, "Kumitat Parlamentari tal-EFTA"@mt, "ELPA parlamentinis komitetas"@lt;
    <http://www.w3.org/2004/02/skos/core#definition> "The EFTA Parliamentary Committee is a forum for parliamentarians from the four Member States of the European Free Trade Association: Iceland, Liechtenstein, Norway and Switzerland. It provides the Association with a valuable link to political life in each EFTA country and, through its cooperation with parliamentarians in the European Union, serves as a link between political life in EFTA and the EU."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EFTA_PC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001580"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EFTA_PC"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EFTA_PC_1977_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EFTA_PC";
    <http://publications.europa.eu/resource/authority/op-code> "EFTA_PC";
    <http://publications.europa.eu/ontology/authority/op-code> "EFTA_PC";
    <http://publications.europa.eu/ontology/authority/start.use> "1977-10-13";
    <http://publications.europa.eu/ontology/authority/authority-code> "EFTA_PC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/EFTA>
}
