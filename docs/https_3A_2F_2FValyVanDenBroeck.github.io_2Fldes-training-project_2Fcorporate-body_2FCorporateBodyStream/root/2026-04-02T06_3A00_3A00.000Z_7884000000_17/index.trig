    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "ÜRO Rahvastikufond"@et, "Fonds der Vereinten Nationen für bevölkerungspolitische Tätigkeiten"@de, "Fonds van de Verenigde Naties voor bevolkingsactiviteiten"@nl, "United Nations Fund for Population Activities"@en, "Fond tan-Nazzjonijiet Uniti għall-Attivitajiet tal-Popolazzjoni"@mt, "Jungtinių Tautų demografinės veiklos fondas"@lt, "YK:n väestötoimirahasto"@fi, "Fonds des Nations Unies pour les activités en matière de population"@fr, "Apvienoto Nāciju Organizācijas Iedzīvotāju aktivitāšu fonds"@lv, "Fondo delle Nazioni Unite per le attività demografiche"@it, "FN’s Fond for Befolkningsaktiviteter"@da, "Fondo de las Naciones Unidas para Actividades en materia de Población"@es;
    <http://www.w3.org/2004/02/skos/core#definition> "The United Nations Fund for Population Activities was established as a trust fund in 1967 and began funding population programmes in 1969. In 1987, it was officially renamed the United Nations Population Fund, reflecting its lead role in the UN system in the area of population."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNFPA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001238"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UNFPA"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNFPA_1972_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNFPA_1972_0";
    <http://publications.europa.eu/resource/authority/op-code> "UNFPA_1972_0";
    <http://publications.europa.eu/ontology/authority/op-code> "UNFPA_1972_0";
    <http://publications.europa.eu/ontology/authority/start.use> "1972-12-19";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNFPA_1972_0";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1987-12-10"
}
<../../../index.trig> <https://w3id.org/tree#member> <#77f958c29689701db131b0dcf898930c>.
