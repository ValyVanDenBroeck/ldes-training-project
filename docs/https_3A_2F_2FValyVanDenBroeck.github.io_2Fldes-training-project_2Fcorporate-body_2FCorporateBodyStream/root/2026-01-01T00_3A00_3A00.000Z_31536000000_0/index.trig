<..\\..\\..\\index.trig> <https://w3id.org/tree#member> <#9fdd1d9bda1bd95a5cc16a99e3286ef5>.
<#9fdd1d9bda1bd95a5cc16a99e3286ef5> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/WTORG>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T00:53:35.106Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9fdd1d9bda1bd95a5cc16a99e3286ef5> {
<http://publications.europa.eu/resource/authority/corporate-body/WTORG> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/2183>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Varšavas līguma organizācija"@lv, "Warschauer Vertragsorganisation"@de, "Varšavski pakt"@hr, "Varšuvos sutarties organizacija"@lt, "Organizace Varšavské smlouvy"@cs, "Organisation du traité de Varsovie"@fr, "Organização do Pacto de Varsóvia"@pt, "Varssavi Lepingu Organisatsioon"@et, "Warszawapagtens Organisation"@da, "Układ Warszawski"@pl, "Οργανισμός του Συμφώνου της Βαρσοβίας"@el, "Warsaw Treaty Organization"@en, "Organizația Pactului de la Varșovia"@ro, "Warszawapakten"@sv, "Organizzazzjoni tat-Trattat ta’ Varsavja"@mt, "Варшавски пакт"@sr, "Organizacija Varšavske pogodbe"@sl, "Организация на Варшавския договор"@bg, "A Varsói Szerződés Szervezete"@hu, "Organisatie van het Warschaupact"@nl, "Eagraíocht Chonradh Vársa"@ga, "Organización del Tratado de Varsovia"@es, "Varsovan liitto"@fi, "Organizácia Varšavskej zmluvy"@sk, "Organizzazione del trattato di Varsavia"@it;
    <http://www.w3.org/2004/02/skos/core#definition> "Alliance set up under the Warsaw Treaty of Friendship, Cooperation and Mutual Assistance, a mutual defence treaty signed in 1955 by Albania, Bulgaria, Czechoslovakia, East Germany, Hungary, Poland, Romania and the Soviet Union. The organization was the Soviet bloc’s equivalent of the North Atlantic Treaty Organization. Initiated as an alliance propelled by the remilitarization of West Germany under the Paris Pacts of 1954, the Treaty was designed to lapse in the event of a general European collective security treaty. A unified military command, with headquarters in Moscow, directed the united forces, which included Soviet divisions stationed in some of the member nations prior to the signing of the Treaty. The 1989 collapse of the Communist Governments in Eastern Europe made the treaty superfluous. The Warsaw Treaty Organization dissolved in 1 July 1991."@en, "Alliance militaire qui regroupait autour de l’Union soviétique l’Albanie (jusqu’en 1968), la R.D.A., la Bulgarie, la Hongrie, la Pologne, la Roumanie et la Tchécoslovaquie. Créé en 1955 pour faire pièce à l’entrée de l’Allemagne fédérale dans l’O.T.A.N., il fut dissous en 1991."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001282"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "WTORG"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "PVAR-GEM"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "WTORG"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
