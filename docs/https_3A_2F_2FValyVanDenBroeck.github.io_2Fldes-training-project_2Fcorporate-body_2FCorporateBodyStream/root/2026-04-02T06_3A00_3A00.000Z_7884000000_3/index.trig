    <http://www.w3.org/2004/02/skos/core#prefLabel> "Fundação para o Software Livre"@pt, "Fundacija Free Software Foundation"@sl, "Brīvās programmatūras fonds (Free Software Foundation)"@lv, "Fondazzjoni ta’ Software Bla Ħlas"@mt, "Fundacja Wolnego Oprogramowania"@pl, "Vaba tarkvara sihtasutus"@et, "Stiftung für freie Software"@de, "„Free Software Foundation“"@lt, "Free Software Foundation"@it, "Free Software Foundation"@hu, "Free Software Foundation"@ga, "Free Software Foundation"@nl, "Free Software Foundation"@sv, "Free Software Foundation"@es, "Фондация за свободен софтуер"@bg, "Free Software Foundation (zaklada za besplatni softver)"@hr, "Free Software Foundation"@fi, "Nadace pro volně distribuovatelný software"@cs, "Free Software Foundation"@fr, "Free Software Foundation"@el, "Nadácia Free Software Foundation"@sk, "Free Software Foundation"@da, "Free Software Foundation"@ro, "Free Software Foundation"@en;
    <http://www.w3.org/2004/02/skos/core#definition> "The FSF maintains historic articles covering free software philosophy and maintains the Free Software Definition to show clearly what must be true about a particular software program for it to be considered free software. The FSF sponsors the GNU project, the ongoing effort to provide a complete operating system licensed as free software. The FSF publishes the GNU General Public License (GNU GPL), a free software license, and the only license written with the express purpose of promoting and preserving software freedom. The FSF also provides important resources to the community including the FSF/UNESCO free software directory."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "FSF"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001349"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "FSF"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "FSF"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/FSF_1985_0>;
    <http://purl.org/dc/elements/1.1/identifier> "FSF";
    <http://publications.europa.eu/resource/authority/op-code> "FSF";
    <http://publications.europa.eu/ontology/authority/op-code> "FSF";
    <http://publications.europa.eu/ontology/authority/start.use> "1985-10-04";
    <http://publications.europa.eu/ontology/authority/authority-code> "FSF"
}
