<../../../index.trig> <https://w3id.org/tree#member> <#9e2c8d64c3cad823bce5ae305e726915>.
<#9e2c8d64c3cad823bce5ae305e726915> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/EFI>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:06.991Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9e2c8d64c3cad823bce5ae305e726915> {
<http://publications.europa.eu/resource/authority/corporate-body/EFI> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/450898>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Европейски горски институт"@bg, "Európsky lesnícky inštitút"@sk, "Europejski Instytut Leśny"@pl, "European Forest Institute"@en, "Instituto Florestal Europeu"@pt, "Det Europæiske Skovinstitut"@da, "Istitut Ewropew tal-Foresti"@mt, "Euroopa Metsainstituut"@et, "Europski šumarski institut"@hr, "Európai Erdészeti Intézet"@hu, "Institut européen de la forêt"@fr, "Instituto Forestal Europeo"@es, "Europees Bosseninstituut"@nl, "Institutul Forestier European"@ro, "Istituto forestale europeo"@it, "Eiropas Meža institūts"@lv, "Euroopan metsäinstituutti"@fi, "An Institiúid Eorpach um Fhoraoisí"@ga, "Ευρωπαϊκό Ινστιτούτο Δασών"@el, "Europäisches Forstinstitut"@de, "Evropský lesnický institut"@cs, "Europos miškų institutas"@lt, "Europeiska skogsinstitutet"@sv, "Evropski gozdarski inštitut"@sl;
    <http://www.w3.org/2004/02/skos/core#definition> "L’objectif de l’Institut est d’entreprendre des travaux de recherche sur la politique forestière, y compris dans ses aspects environnementaux, sur l’écologie, l’utilisation à fins multiples, les ressources et la santé des forêts européennes, l’offre et la demande en bois et d’autres produits forestiers, et d’établir des provisions sur l’évolution future des ressources forestières en Europe, ainsi que leur utilisation."@fr, "EFI was established with the aim of enhancing international forest research and providing decision makers with unbiased forest-related information at a pan-European level. The Act of Constitution of EFI was signed by 12 founding members on 9 September 1993."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EFI"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001277"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EFI"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "EFI"@pl, "EMI"@lt, "EMI"@lv, "EFI"@ro, "EFI"@et, "EFI"@it, "EFI"@en, "EFI"@pt, "EFI"@fr, "EFI"@nl, "EFI"@de, "EFI"@fi, "EFI"@hr, "EFI"@da, "EFI"@es, "EFI"@mt, "EFI"@hu, "ΕΙΔ"@el;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EFI_1993_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EFI";
    <http://publications.europa.eu/resource/authority/op-code> "EFI";
    <http://publications.europa.eu/ontology/authority/op-code> "EFI";
    <http://publications.europa.eu/ontology/authority/start.use> "1993-09-09";
    <http://publications.europa.eu/ontology/authority/authority-code> "EFI"
}
<../../../index.trig> <https://w3id.org/tree#member> <#b3d9d3070bd0e52900805dc94f2848a5>.
<#b3d9d3070bd0e52900805dc94f2848a5> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/COMECON>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:06.998Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#b3d9d3070bd0e52900805dc94f2848a5> {
<http://publications.europa.eu/resource/authority/corporate-body/COMECON> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/5086>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Comecon"@hr, "Comecon"@es, "Comecon"@en, "Comecon"@et, "Comecon"@sr, "Comecon"@fr, "Comecon"@mt, "KGST"@hu, "Comecon"@ro, "Comecon"@da, "Comecon"@pt, "Comecon"@de, "Comecon"@it, "Comecon"@lv, "SEV"@sl, "Komecon"@el, "SEV"@fi, "Comecon"@tr, "RVHP"@cs, "RVHP"@sk, "RWPG"@pl, "Комекон"@bg, "Comecon"@ga, "Comecon"@is, "Comecon"@lt, "Comecon"@sv, "Comecon"@nl;
    <http://www.w3.org/2004/02/skos/core#definition> "Le Conseil d’assistance économique mutuelle ou Conseil d’aide économique mutuelle était une organisation d’entraide économique entre différents pays du bloc communiste. Créé par Staline en 1949 en réponse à l’OECE capitaliste, il s’est dissous avec la chute de l’empire soviétique en juin 1991, à la fin de la Guerre froide. Cet organisme avait pour but la meilleure planification et la spécialisation des industries nationales des pays communistes."@fr, "The Council for Mutual Economic Assistance, 1949–1991, was an economic organization under the leadership of the Soviet Union that comprised the countries of the Eastern Bloc, along with a number of socialist states elsewhere in the world. The Comecon was the Eastern Bloc’s reply to the formation of the Organization for European Economic Co-operation in Western Europe."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COMECON"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COMECON"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COMECON-G"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "COB0000757"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Vastastikuse Majandusabi Nõukogu"@et, "Savstarpējās ekonomiskās palīdzības padome"@lv, "Rådet för ömsesidigt ekonomiskt bistånd"@sv, "Conseil d’assistance économique mutuelle"@fr, "Consiliul de Ajutor Economic Reciproc"@ro, "Rat für gegenseitige Wirtschaftshilfe"@de, "Consiglio di mutua assistenza economica"@it, "Съвет за икономическа взаимопомощ"@bg, "Conselho para Assistência Económica Mútua"@pt, "Rada vzájomnej hospodárskej pomoci"@sk, "Raad voor wederzijdse economische hulp"@nl, "Kölcsönös Gazdasági Segítség Tanácsa"@hu, "Rada Wzajemnej Pomocy Gospodarczej"@pl, "Ekonominės savitarpio pagalbos taryba"@lt, "Consejo de Ayuda Mutua Económica"@es, "Rada vzájemné hospodářské pomoci"@cs, "Council for Mutual Economic Assistance"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/COMECON_1949_0>;
    <http://purl.org/dc/elements/1.1/identifier> "COMECON";
    <http://publications.europa.eu/resource/authority/op-code> "COMECON";
    <http://publications.europa.eu/ontology/authority/op-code> "COMECON";
    <http://publications.europa.eu/ontology/authority/start.use> "1949-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "COMECON";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b423_b422_b421_df_15_72;
    <http://publications.europa.eu/ontology/authority/end.use> "1991-12-31".
_:b423_b422_b421_df_15_72 a <http://publications.europa.eu/ontology/authority/MappedCode>;
    <http://purl.org/dc/elements/1.1/source> "EurLex";
    <http://publications.europa.eu/ontology/authority/affected-table> "FD_050";
    <http://publications.europa.eu/ontology/authority/legacy-code> "COMECON-G"
}
