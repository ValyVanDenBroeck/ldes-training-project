<#160a53bcc154d2494c81c0e8df8a9c1a> {
<http://publications.europa.eu/resource/authority/corporate-body/CARICOM> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
