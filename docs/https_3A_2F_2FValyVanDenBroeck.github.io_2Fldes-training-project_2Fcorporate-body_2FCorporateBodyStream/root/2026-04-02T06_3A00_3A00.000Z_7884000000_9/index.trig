<#e8aba0a7aa6c273a4e2390c458111d1a> {
<http://publications.europa.eu/resource/authority/corporate-body/EURCOU_PRES> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Presidente do Conselho Europeu"@pt, "Președintele Consiliului European"@ro, "Πρόεδρος του Ευρωπαϊκού Συμβουλίου"@el, "Председател на Европейския съвет"@bg, "Předseda Evropské rady"@cs, "Voorzitter van de Europese Raad"@nl, "Presidente del Consiglio europeo"@it, "Präsident des Europäischen Rates"@de, "Uachtarán na Comhairle Eorpaí"@ga, "Europeiska rådets ordförande"@sv, "Formand for Det Europæiske Råd"@da, "Presidente del Consejo Europeo"@es, "Predsjednik Europskog vijeća"@hr, "Président du Conseil européen"@fr, "Predsednik Evropskega sveta"@sl, "Europos Vadovų Tarybos pirmininkas"@lt, "Przewodniczący Rady Europejskiej"@pl, "Il-President tal-Kunsill Ewropew"@mt, "President of the European Council"@en, "Eurooppa-neuvoston puheenjohtaja"@fi, "Az Európai Tanács elnöke"@hu, "Predseda Európskej rady"@sk, "Eiropadomes priekšsēdētājs"@lv, "Euroopa Ülemkogu eesistuja"@et;
    <http://www.w3.org/2004/02/skos/core#definition> "Between 1975 and 2009, the Presidency of the European Council was based on the Presidency of the Council of the European Union, with it being hosted by the member state holding the Council Presidency, rotating every six months. As the European Council is composed of national leaders, it was chaired by the head of state or government of the Presidency state. By entry into force of the Lisbon Treaty, a full-time permanent president was appointed for prolongable 2,5-year period. The president’s role is largely political, preparing the work of the European Council, organising and chairing its meetings, seeking to find consensus among its members and reporting to the European Parliament after each meeting. He/she also ensures the external representation of the Union on issues concerning its common foreign and security policy."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0000359"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EURCOU_PRES"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "EURCOU_PRES"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "CM_CRF_246914"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Präsidentin des Europäischen Rates"@de, "Predsednica Evropskega sveta"@sl, "Predsjednica Europskog vijeća"@hr, "Présidente du Conseil européen"@fr, "Predsedníčka Európskej rady"@sk, "Europos Vadovų Tarybos pirmininkė"@lt, "Předsedkyně Evropské rady"@cs, "Przewodnicząca Rady Europejskiej"@pl, "Eiropadomes priekšsēdētāja"@lv, "Președinta Consiliului European"@ro;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EURCOU_PRES_1975_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EURCOU_PRES";
    <http://publications.europa.eu/resource/authority/op-code> "EURCOU_PRES";
    <http://publications.europa.eu/ontology/authority/op-code> "EURCOU_PRES";
