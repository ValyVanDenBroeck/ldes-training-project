    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Európai Távközlési Szabványügyi Intézet"@hu, "Evropský ústav pro telekomunikační normy"@cs, "Istituto europeo norme e telecomunicazioni"@it, "Institiúid Eorpach na gCaighdeán Teileachumarsáide"@ga, "Europäisches Institut für Telekommunikationsnormen"@de, "Det Europæiske Standardiseringsinstitut for Telekommunikation"@da, "Európsky inštitút pre telekomunikačné normy"@sk, "Instituto Europeu de Normalização das Telecomunicações"@pt, "Europos telekomunikacijų standartų institutas"@lt, "Istitut Ewropew tal-Istandards tat-Telekomunikazzjonijiet"@mt, "Europees Normalisatie Instituut voor Telecommunicatie"@nl, "Европски институт за телекомуникационе стандарде"@sr, "Evropski inštitut za telekomunikacijske standarde"@sl, "Euroopan telealan standardointilaitos"@fi, "Ευρωπαϊκό Ινστιτούτο Τηλεπικοινωνιακών Προτύπων"@el, "Institutul European de Standardizare în Telecomunicații"@ro, "Instituto Europeo de Normas de Telecomunicaciones"@es, "Euroopa Elekterside Standardimise Instituut"@et, "Europejski Instytut Norm Telekomunikacyjnych"@pl, "Европейски институт за далекосъобщителни стандарти"@bg, "European Telecommunications Standards Institute"@en, "Institut européen de normalisation des télécommunications"@fr, "Eiropas Telekomunikāciju standartu institūts"@lv, "Europeiska institutet för telekommunikationsstandarder"@sv, "Europski institut za telekomunikacijske norme"@hr;
    <http://www.w3.org/2004/02/skos/core#definition> "ETSI produces globally-applicable standards for Information and Communications Technologies, including fixed, mobile, radio, converged, broadcast and Internet technologies. ETSI is officially recognized by the European Union as a European Standards Organization. It is a not-for-profit organization with more than 800 member organizations worldwide, drawn from 64 countries and five continents."@en, "Organisme chargé d’établir des normes de télécommunications européennes applicables et acceptées dans toute l’Europe dans le domaine des télécommunications."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "ETSI"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "ETSI"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001296"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ETSI"@da, "ETSI"@hr, "ETSI"@ro, "ETSI"@lt, "ETSI"@et, "ETSI"@pl, "ETSI"@el, "ETSI"@hu, "ETSI"@cs, "ETSI"@ga, "ETSI"@nl, "ETSI"@lv, "ETSI"@fr, "ETSI"@es, "ETSI"@it, "ETSI"@sk, "ETSI"@en, "ETSI"@pt, "ETSI"@bg, "ETSI"@de, "ETSI"@sl, "Etsi"@sv, "Etsi"@fi, "ETSI"@mt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ETSI_1988_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ETSI";
    <http://publications.europa.eu/resource/authority/op-code> "ETSI";
    <http://publications.europa.eu/ontology/authority/op-code> "ETSI";
    <http://publications.europa.eu/ontology/authority/start.use> "1988-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "ETSI"
}
