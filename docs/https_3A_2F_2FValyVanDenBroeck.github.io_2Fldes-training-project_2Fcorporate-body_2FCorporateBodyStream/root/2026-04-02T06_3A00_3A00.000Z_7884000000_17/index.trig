<#158cbe3cf3c07bb3329bf4170963b8b9> {
<http://publications.europa.eu/resource/authority/corporate-body/UNIFEM> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
