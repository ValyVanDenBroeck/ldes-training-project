<#cf364f3b9e394699ccfaab6c9ec8c928> {
<http://publications.europa.eu/resource/authority/corporate-body/EUMS_EURO13> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "I Stati membri che hanno adottato l’euro: Belgio, Germania, Irlanda, Grecia, Spagna, Francia, Italia, Lussemburgo, Paesi Bassi, Austria, Portogallo, Slovenia, Finlandia"@it, "Los Estados miembros que han adoptado el euro: Bélgica, Alemania, Irlanda, Grecia, España, Francia, Italia, Luxemburgo, Países Bajos, Austria, Portugal, Eslovenia, Finlandia"@es, "Statele membre care au adoptat euro: Belgia, Germania, Irlanda, Grecia, Spania, Franţa, Italia, Luxemburg, Ţările de Jos, Austria, Portugalia, Slovenia, Finlanda"@ro, "Dalībvalstis, kuras ir ieviesušas euro: Beļģija, Vācija, Īrija, Grieķija, Spānija, Francija, Itālija, Luksemburga, Nīderlande, Austrija, Portugāle, Slovēnija, Somija"@lv, "Valstybės narės, įsivedusios eurą: Belgija, Vokietija, Airija, Graikija, Ispanija, Prancūzija, Italija, Liuksemburgas, Nyderlandai, Austrija, Portugalija, Slovėnija, Suomija"@lt, "Na Ballstáit a ghlac leis an euro: an Bheilg, an Ghearmáin, Éire, an Ghréig, an Spáinn, an Fhrainc, an Iodáil, Lucsamburg, an Ísiltír, an Ostair, an Phortaingéil, an tSlóivéin, an Fhionlainn"@ga, "Τα κράτη μέλη που υιοθέτησαν το ευρώ: Βέλγιο, Γερμανία, Ιρλανδία, Ελλάδα, Ισπανία, Γαλλία, Ιταλία, Λουξεμβούργο, Κάτω Χώρες, Αυστρία, Πορτογαλία, Σλοβενία, Φινλανδία"@el, "Členské státy, které přijaly euro: Belgie, Německo, Irsko, Řecko, Španělsko, Francie, Itálie, Lucembursko, Nizozemsko, Rakousko, Portugalsko, Slovinsko, Finsko"@cs, "Euro kasutusele võtnud liikmesriigid: Belgia, Saksamaa, Iirimaa, Kreeka, Hispaania, Prantsusmaa, Itaalia, Luksemburg, Madalmaad, Austria, Portugal, Sloveenia, Soome"@et, "Jäsenvaltiot, jotka ovat ottaneet käyttöön euron: Belgia, Saksa, Irlanti, Kreikka, Espanja, Ranska, Italia, Luxemburg, Alankomaat, Itävalta, Portugali, Slovenia, Suomi"@fi, "De lidstaten die de euro hebben aangenomen: België, Duitsland, Ierland, Griekenland, Spanje, Frankrijk, Italië, Luxemburg, Nederland, Oostenrijk, Portugal, Slovenië, Finland"@nl, "Държави-членки, които са приели еврото: Белгия, Германия, Ирландия, Гърция, Испания, Франция, Италия, Люксембург, Австрия, Нидерландия, Португалия, Словения, Финландия"@bg, "De medlemsstater, der har indført euroen: Belgien, Tyskland, Irland, Grækenland, Spanien, Frankrig, Italien, Luxembourg, Nederlandene, Østrig, Portugal, Slovenien, Finland"@da, "Os Estados-Membros que adoptaram o euro: Bélgica, Alemanha, Irlanda, Grécia, Espanha, França, Itália, Luxemburgo, Países Baixos, Áustria, Portugal, Eslovénia, Finlândia"@pt, "De medlemsstater som har infört euron: Belgien, Tyskland, Irland, Grekland, Spanien, Frankrike, Italien, Luxemburg, Nederländerna, Österrike, Portugal, Slovenien, Finland"@sv, "Členské štáty, ktoré prijali euro: Belgicko, Nemecko, Írsko, Grécko, Španielsko, Francúzsko, Taliansko, Luxembursko, Holandsko, Rakúsko, Portugalsko, Slovinsko, Fínsko"@sk, "États membres ayant adopté l’euro: Belgique, Allemagne, Irlande, Grèce, Espagne, France, Italie, Luxembourg, Pays-Bas, Autriche, Portugal, Slovénie, Finlande"@fr, "Az eurót bevezető tagállamok: Belgium, Németország, Írország, Görögország, Spanyolország, Franciaország, Olaszország, Luxemburg, Hollandia, Ausztria, Portugália, Szlovénia, Finnország"@hu, "L-Istati Membri wara li adottaw l-euro: il-Belġju, il-Ġermanja, l-Irlanda, il-Greċja, Spanja, Franza, l-Italja, il-Lussemburgu, il-Pajjiżi l-Baxxi, l-Awstrija, il-Portugall, is-Slovenja, il-Finlandja"@mt, "Države članice, ki so sprejele euro: Belgija, Nemčija, Irska, Grčija, Španija, Francija, Italija, Luksemburg, Nizozemska, Avstrija, Portugalska, Slovenija, Finska"@sl, "The Member States having adopted the euro: Belgium, Germany, Ireland, Greece, Spain, France, Italy, Luxembourg, Netherlands, Austria, Portugal, Slovenia, Finland"@en, "Države članice koje su prihvatile euro: Belgija, Njemačka, Irska, Grčka, Španjolska, Francuska, Italija, Luksemburg, Nizozemska, Austrija, Portugal, Slovenija, Finska"@hr, "Państwa członkowskie, które przyjęły walutę euro: Belgia, Niemcy, Irlandia, Grecja, Hiszpania, Francja, Włochy, Luksemburg, Niderlandy, Austria, Portugalia, Słowenia, Finlandia"@pl, "Die Mitgliedstaaten, die den Euro eingeführt haben: Belgien, Deutschland, Irland, Griechenland, Spanien, Frankreich, Italien, Luxemburg, Niederlande, Österreich, Portugal, Slowenien, Finland"@de;
    <http://www.w3.org/2004/02/skos/core#notation> "EUMS_EURO13"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0000342"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EUMS_EURO13"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EUMS_EURO13_2007_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EUMS_EURO13";
    <http://publications.europa.eu/resource/authority/op-code> "EUMS_EURO13";
    <http://publications.europa.eu/ontology/authority/op-code> "EUMS_EURO13";
    <http://publications.europa.eu/ontology/authority/start.use> "2007-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "EUMS_EURO13";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/EUMS>;
    <http://publications.europa.eu/ontology/authority/end.use> "2007-12-31"
}
