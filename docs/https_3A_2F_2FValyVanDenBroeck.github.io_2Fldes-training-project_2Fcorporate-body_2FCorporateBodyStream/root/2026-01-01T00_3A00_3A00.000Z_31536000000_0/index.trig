    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Caribbean Community"@en, "Karību valstu kopiena"@lv, "Karibské spoločenstvo"@sk, "Comunità caraibica"@it, "Karibska skupnost"@sl, "Karibų bendrija"@lt, "Karayip Ortak Pazarı"@tr, "Comunidade do Caribe"@pt, "Karibské společenství"@cs, "Karibian yhteisö"@fi, "Wspólnota Karaibska"@pl, "Karibi Közösség"@hu, "Kariibi Ühendus"@et, "Karibiska gemenskapen"@sv, "Caribische Gemeenschap"@nl, "Komunità tal-Karibew"@mt, "Karibische Gemeinschaft"@de, "Cómhargadh Mhuir Chairib"@ga, "Karipska zajednica"@hr, "Κοινότητα της Καραϊβικής"@el, "Communauté des Caraïbes"@fr, "Карибска общност"@bg, "Comunidad del Caribe"@es, "Det Caribiske fællesskab"@da, "Comunitatea Caraibilor"@ro;
    <http://www.w3.org/2004/02/skos/core#definition> "Established in 1973, the Caribbean Community (CARICOM) is an organization of 15 Caribbean nations and dependencies. CARICOM’s main purposes are to promote economic integration and cooperation among its members, to ensure that the benefits of integration are equitably shared, and to coordinate foreign policy."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "CARICOM"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0000809"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "CARICOM"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Caricom"@es, "Karaibska Wspólnota i Wspólny Rynek"@pl, "Кариком"@bg, "Karibska skupnost in skupni trg"@sl, "CARICOM"@lv, "CARICOM"@sl, "CARICOM"@lt, "CARICOM"@et, "CARICOM"@en, "CARICOM"@sk, "CARICOM"@pl, "CARICOM"@cs, "CARICOM"@it, "CARICOM"@hu, "CARICOM"@fr, "CARICOM"@hr, "Karibų bendrija ir bendroji rinka"@lt, "Caribiske fællesskab og fællesmarked"@da, "Communauté et marché commun des Caraïbes"@fr, "CARICOM"@de, "CARICOM"@mt, "Карибска общност и общ пазар"@bg, "Karibské společenství a společný trh"@cs, "Karibi Közösség és Közös Piac"@hu, "Comunità e mercato comune dei Caraibi"@it, "Comunidad y Mercado Común del Caribe"@es, "Kariibi Ühendus ja ühisturg"@et, "Karibische Gemeinschaft und Gemeinsame Markt"@de, "Comunidade e Mercado Comum das Caraíbas"@pt, "Karibian yhteisö ja yhteismarkkina-alue"@fi, "Karibské spoločenstvo a spoločný trh"@sk, "Caribische Gemeenschap en eenheidsmarkt"@nl, "Karipska zajednica i zajedničko tržište"@hr, "Comunitatea și piața comună a Caraibelor"@ro, "Karibiska gemenskapen och gemensamma marknaden"@sv, "Caribbean Community and Common Market"@en, "Karību valstu kopiena un kopējais tirgus"@lv, "Komunità u Suq Komuni tal-Karibew"@mt, "Caricom"@nl, "Caricom"@sv, "Caricom"@pt, "Caricom"@ro, "Κοινότητα της Καραϊβικής και Κοινή Αγορά"@el, "Caricom"@da, "Caricom"@fi;
