<../../../index.trig> <https://w3id.org/tree#member> <#5187bd024c3a7e5fc1f12e5749dbd1fe>.
<#5187bd024c3a7e5fc1f12e5749dbd1fe> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/ENISA>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:09.102Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#5187bd024c3a7e5fc1f12e5749dbd1fe> {
<http://publications.europa.eu/resource/authority/corporate-body/ENISA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Agentschap van de Europese Unie voor cyberbeveiliging"@nl, "Euroopan unionin kyberturvallisuusvirasto"@fi, "Európai Uniós Kiberbiztonsági Ügynökség"@hu, "Agencija Europske unije za kibersigurnost"@hr, "Agentur der Europäischen Union für Cybersicherheit"@de, "Euroopa Liidu Küberturvalisuse Amet"@et, "Οργανισμός της Ευρωπαϊκής Ένωσης για την Κυβερνοασφάλεια"@el, "Gníomhaireacht an Aontais Eorpaigh um Chibearshlándáil"@ga, "Agenția Uniunii Europene pentru Securitate Cibernetică"@ro, "Agenzia dell’Unione europea per la cibersicurezza"@it, "Agencia de la Unión Europea para la Ciberseguridad"@es, "Agentura Evropské unie pro kybernetickou bezpečnost"@cs, "Europeiska unionens cybersäkerhetsbyrå"@sv, "Agência da União Europeia para a Cibersegurança"@pt, "Agentúra Európskej únie pre kybernetickú bezpečnosť"@sk, "Europos Sąjungos kibernetinio saugumo agentūra"@lt, "Agencija Evropske unije za kibernetsko varnost"@sl, "Агенция на Европейския съюз за киберсигурност"@bg, "European Union Agency for Cybersecurity"@en, "Agence de l’Union européenne pour la cybersécurité"@fr, "Agencja Unii Europejskiej ds. Cyberbezpieczeństwa"@pl, "L-Aġenzija tal-Unjoni Ewropea għaċ-Ċibersigurtà"@mt, "Den Europæiske Unions Agentur for Cybersikkerhed"@da, "Eiropas Savienības Kiberdrošības aģentūra"@lv;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Union Agency for Cybersecurity, ENISA, is the Union’s agency dedicated to achieving a high common level of cybersecurity across Europe. Established in 2004 and strengthened by the EU Cybersecurity Act, the European Union Agency for Cybersecurity contributes to EU cyber policy, enhances the trustworthiness of ICT products, services and processes with cybersecurity certification schemes, cooperates with Member States and EU bodies, and helps Europe prepare for the cyber challenges of tomorrow. Through knowledge sharing, capacity building and awareness raising, the Agency works together with its key stakeholders to strengthen trust in the connected economy, to boost resilience of the Union’s infrastructure, and, ultimately, to keep Europe’s society and citizens digitally secure."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ENISA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "9204"^^<http://publications.europa.eu/ontology/euvoc#ISBN_RG>, "10.2824"^^<http://publications.europa.eu/ontology/euvoc#DOI_P>, "TP"^^<http://publications.europa.eu/ontology/euvoc#OP_CAT>, "ENISA_2"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>, "ENISA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001575"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ENISA"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ENISA"@ro, "ENISA"@bg, "ENISA"@mt, "ENISA"@fr, "ENISA"@et, "ENISA"@en, "ENISA"@sk, "ENISA"@da, "ENISA"@hu, "ENISA"@es, "ENISA"@de, "ENISA"@pl, "ENISA"@lv, "ENISA"@lt, "ENISA"@pt, "ENISA"@cs, "ENISA"@hr, "ENISA"@sl, "ENISA"@fi, "ENISA"@it, "ENISA"@ga, "ENISA"@el, "Enisa"@sv, "Enisa"@nl;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ENISA_2019_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ENISA";
    <http://publications.europa.eu/resource/authority/op-code> "ENISA";
    <http://publications.europa.eu/ontology/authority/op-code> "ENISA";
    <http://publications.europa.eu/ontology/authority/start.use> "2019-06-27";
    <http://publications.europa.eu/ontology/authority/authority-code> "ENISA";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b1317_b1316_b1315_df_15_312, _:b1317_b1316_b1315_df_15_313;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/EURAG>;
    <http://www.w3.org/2004/02/skos/core#historyNote> "On 3.12.2013 the label in Romanian was corrected – formerly \"Agenția Europeană pentru Securitatea Rețelelor Informatice și a Datelor\"."@en.
_:b1317_b1316_b1315_df_15_312 a <http://publications.europa.eu/ontology/authority/MappedCode>;
