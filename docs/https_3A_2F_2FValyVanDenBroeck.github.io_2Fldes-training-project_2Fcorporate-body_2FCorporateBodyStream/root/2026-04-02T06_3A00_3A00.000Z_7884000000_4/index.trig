    <http://www.w3.org/2004/02/skos/core#definition> "The Bio-Based Industries Joint Undertaking is public-private partnership aiming at increasing investment in the development of a sustainable bio-based industry sector in Europe."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "10.2884"^^<http://publications.europa.eu/ontology/euvoc#DOI_P>, "95219"^^<http://publications.europa.eu/ontology/euvoc#ISBN_RG>, "HQ"^^<http://publications.europa.eu/ontology/euvoc#OP_CAT>, "BBI"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>, "BBI"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0000987"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "BBI"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
