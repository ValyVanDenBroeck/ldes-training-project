    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "European Civil Aviation Conference"@en, "Европейска конференция за гражданска авиация"@bg, "Euroopa Tsiviillennunduse Konverents"@et, "Conferencia Europea de Aviación Civil"@es, "Konferenza Ewropea tal-Avjazzjoni Ċivili"@mt, "Ευρωπαϊκή Διάσκεψη Πολιτικής Αεροπορίας"@el, "Conferência Europeia da Aviação Civil"@pt, "Европска конференција цивилног ваздухопловства"@sr, "Evropska konferenca civilnega letalstva"@sl, "Conferința Europeană a Aviației Civile"@ro, "Europos civilinės aviacijos konferencija"@lt, "An Chomhdháil Eorpach um Eitlíocht Shibhialta"@ga, "Europejska Konferencja Lotnictwa Cywilnego"@pl, "Europäische Zivilluftfahrtkonferenz"@de, "Conferenza europea dell’aviazione civile"@it, "Európai Polgári Repülési Konferencia"@hu, "Europese Burgerluchtvaartconferentie"@nl, "Den Europæiske Konference for Civil Luftfart"@da, "Evropská konference pro civilní letectví"@cs, "Eiropas Civilās aviācijas konference"@lv, "Europska konferencija civilnoga zrakoplovstva"@hr, "Európska konferencia civilného letectva"@sk, "Europeiska civila luftfartskonferensen"@sv, "Conférence européenne de l’aviation civile"@fr, "Euroopan siviili-ilmailukonferenssi"@fi;
    <http://www.w3.org/2004/02/skos/core#definition> "Fondée comme organisation intergouvernementale, la Conférence européenne de l’Aviation civile s’emploie à harmoniser les politiques et pratiques dans le domaine de l’aviation civile au sein de ses États membres, et à promouvoir un rapprochement sur des questions de politique entre ses États membres et d’autres régions du monde. La CEAC a pour objectif de promouvoir le développement d’un système de transport aérien européen sûr, efficace et durable."@fr, "Founded as an intergovernmental organisation, the European Civil Aviation Conference (ECAC) seeks to harmonise civil aviation policies and practices amongst its Member States and, at the same time, promote understanding on policy matters between its Member States and other parts of the world. ECAC’s mission is the promotion of the continued development of a safe, efficient and sustainable European air transport system."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "CEAC"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "ECAC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001298"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ECAC"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ЕКГА"@bg, "CEAC"@et, "CEAC"@es, "CEAC"@pt, "CEAC"@it, "CEAC"@fr, "CEAC"@ro, "ECAC"@en, "ECAC"@de, "ECAC"@mt, "ECAC"@fi, "ECAC"@sl, "ECAC"@da, "ECAC"@nl, "ECAC"@sv, "ECAC"@ga, "ECAC"@hu, "ECAC"@pl, "ECAC"@lt, "ECAC"@lv, "ΕΔΠΑ"@el, "ECAC"@hr, "ECAC"@sk;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ECAC_1955_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ECAC";
    <http://publications.europa.eu/resource/authority/op-code> "ECAC";
    <http://publications.europa.eu/ontology/authority/op-code> "ECAC";
    <http://publications.europa.eu/ontology/authority/start.use> "1955-11-23";
    <http://publications.europa.eu/ontology/authority/authority-code> "ECAC";
