    <http://www.w3.org/2004/02/skos/core#prefLabel> "ANO Sieviešu attīstības fonds"@lv, "YK:n naisten kehitysrahasto"@fi, "Fondul de Dezvoltare al Organizației Națiunilor Unite pentru Femei"@ro, "Fonds de développement des Nations unies pour la femme"@fr, "Ciste Forbraíochta na Náisiún Aontaithe do Mhná"@ga, "United Nations Development Fund for Women"@en, "De Forenede Nationers Udviklingsfond for Kvinder"@da, "Entwicklungsfonds der Vereinten Nationen für die Frau"@de, "Ontwikkelingsfonds van de Verenigde Naties voor vrouwen"@nl, "Fundusz Narodów Zjednoczonych na rzecz Kobiet"@pl, "Fondo de Desarrollo de las Naciones Unidas para la Mujer"@es, "Fondo di sviluppo delle Nazioni Unite per le donne"@it, "Fundo de Desenvolvimento das Nações Unidas para a Mulher"@pt, "Jungtinių Tautų plėtros fondas moterims"@lt, "Ταμείο Ανάπτυξης των Ηνωμένων Εθνών για τις Γυναίκες"@el, "Razvojni sklad Združenih narodov za ženske"@sl, "Fond ta’ Żvilupp tan-Nazzjonijiet Uniti għan-Nisa"@mt, "ÜRO Naiste Arengufond"@et;
    <http://www.w3.org/2004/02/skos/core#definition> "Since its creation, UNIFEM has supported numerous projects and initiatives throughout the developing world. These have ranged from small grassroots enterprises to improve working conditions for women, to public education campaigns and the design of new gender-sensitive laws and marketing systems. UNIFEM is represented at the regional and country level by its 12 Regional Programme Advisers (RPAs). The RPAs develop and oversee UNIFEM’s projects in their regions and identify trends and issues affecting women in the region. Merged with United Nations Entity for Gender Equality and the Empowerment of Women according to GA resolution 64/289."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001244"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNIFEM"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "UNIFEM"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Rozvojový fond OSN pro ženy"@cs, "Международен фонд на ООН за жените"@bg, "FN:s utvecklingsfond för kvinnor"@sv, "ЮНИФЕМ"@bg, "UNIFEM"@pt, "UNIFEM"@ro, "UNIFEM"@fr, "UNIFEM"@sk, "UNIFEM"@de, "UNIFEM"@en, "UNIFEM"@sl, "UNIFEM"@cs, "UNIFEM"@lt, "UNIFEM"@fi, "UNIFEM"@pl, "UNIFEM"@el, "Rozvojový fond OSN pre ženy"@sk, "UNIFEM"@lv, "UNIFEM"@da, "UNIFEM"@ga, "UNIFEM"@mt, "UNIFEM"@es, "UNIFEM"@it, "Unifem"@nl, "Unifem"@sv;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNIFEM_1976_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNIFEM";
    <http://publications.europa.eu/resource/authority/op-code> "UNIFEM";
    <http://publications.europa.eu/ontology/authority/op-code> "UNIFEM";
    <http://publications.europa.eu/ontology/authority/start.use> "1976-09-16";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNIFEM";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "2010-07-01"
}
