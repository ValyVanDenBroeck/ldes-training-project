<#44bb5856519aa72f9d2d9f95c2026558> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNCHRC>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.151Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#44bb5856519aa72f9d2d9f95c2026558> {
<http://publications.europa.eu/resource/authority/corporate-body/UNCHRC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Comitetul pentru Drepturile Omului al Organizației Națiunilor Unite"@ro, "Výbor OSN pre ľudské práva"@sk, "Odbor Združenih narodov za človekove pravice"@sl, "FN:s kommitté för mänskliga rättigheter"@sv, "Komitet Praw Człowieka ONZ"@pl, "Kumitat tan-Nazzjonijiet Uniti dwar id-Drittijiet tal-Bniedem"@mt, "Ühinenud Rahvaste Organisatsiooni inimõiguste komitee"@et, "Commissione delle Nazioni Unite per i diritti umani"@it, "Coiste na Náisiún Aontaithe um Chearta an Duine"@ga, "Az ENSZ Emberi Jogi Bizottsága"@hu, "Комитет на ООН по правата на човека"@bg, "Mensenrechtencomité van de Verenigde Naties"@nl, "Comité dos Direitos Humanos das Nações Unidas"@pt, "United Nations Human Rights Committee"@en, "Výbor pro lidská práva OSN"@cs, "YK:n ihmisoikeuskomitea"@fi, "Apvienoto Nāciju Organizācijas Cilvēktiesību komiteja"@lv, "Comité de Derechos Humanos de las Naciones Unidas"@es, "Επιτροπή Ανθρωπίνων Δικαιωμάτων των Ηνωμένων Εθνών"@el, "FN’s Menneskerettighedskomité"@da, "Jungtinių Tautų Žmogaus teisių komitetas"@lt, "Odbor Ujedinjenih naroda za ljudska prava"@hr, "Comité des Nations unies des droits de l’homme"@fr, "Menschenrechtskommission der Vereinten Nationen"@de;
    <http://www.w3.org/2004/02/skos/core#definition> "The Human Rights Committee is the body of independent experts that monitors implementation of the International Covenant on Civil and Political Rights by its State parties. All States parties are obliged to submit regular reports to the Committee on how the rights are being implemented. States must report initially one year after acceding to the Covenant and then whenever the Committee requests (usually every four years). The Committee examines each report and addresses its concerns and recommendations to the State party in the form of \"concluding observations”. In addition to the reporting procedure, article 41 of the Covenant provides for the Committee to consider inter-state complaints."@en, "Le Comité des droits de l’homme est un organe composé d’experts indépendants qui surveille la mise en œuvre du Pacte international relatif aux droits civils et politiques par les États parties. Tous les États parties sont tenus de présenter au Comité, à intervalles réguliers, des rapports sur la mise en œuvre des droits consacrés par le Pacte. Ils doivent présenter un premier rapport un an après avoir adhéré au Pacte, puis à chaque fois que le Comité le leur demande (généralement tous les quatre ans). Le Comité examine chaque rapport et fait part de ses préoccupations et de ses recommandations à l’État partie sous la forme d’«observations finales». L’article 41 du Pacte prévoit l’examen de plaintes interétatiques par le Comité."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "UNCHRC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "UNCHRC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001209"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Komitet Praw Człowieka"@pl, "Cilvēktiesību komiteja"@lv, "Coiste um Chearta an Duine"@ga, "Odbor za človekove pravice"@sl, "CCPR"@fr, "HRC"@nl, "Ihmisoikeuskomitea"@fi, "Comité de Derechos Humanos"@es, "CCPR"@en, "Comitetul pentru Drepturile Omului"@ro, "Výbor pro lidská práva"@cs, "KPC"@pl, "Výbor pre ľudské práva"@sk, "Comitato dei diritti umani"@it, "Comité des droits de l’homme"@fr, "Inimõiguste komitee"@et, "Comité voor de rechten van de mens"@nl, "Menschenrechtsausschuss"@de, "Kommittén för de mänskliga rättigheterna"@sv, "Emberi Jogi Bizottság"@hu, "Menneskerettighedskomitéen"@da, "Kumitat tad-Drittijiet tal-Bniedem"@mt, "Human Rights Committee"@en, "CDH"@es;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCHRC_1976_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCHRC";
    <http://publications.europa.eu/resource/authority/op-code> "UNCHRC";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCHRC";
    <http://publications.europa.eu/ontology/authority/start.use> "1976-03-23";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCHRC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
