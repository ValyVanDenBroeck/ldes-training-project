    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Commissie van de Verenigde Naties voor nieuwe en hernieuwbare energiebronnen en energie voor ontwikkeling"@nl, "Apvienoto Nāciju Organizācijas Enerģētikas un dabas resursu attīstības komiteja"@lv, "YK:n energian ja luonnonvarojen kehitykselle tuomia hyötyjä käsittelevä toimikunta"@fi, "Kumitat tan-Nazzjonijiet Uniti dwar l-Enerġija u r-Riżorsi Naturali għall-Iżvilupp"@mt, "Comité de las Naciones Unidas sobre la Energía y los Recursos Naturales para el Desarrollo"@es, "United Nations Committee on Energy and Natural Resources for Development"@en, "ÜRO arengu- ja loodusressursside komitee"@et, "Comité des Nations unies de l’énergie et des ressources naturelles pour le développement"@fr;
    <http://www.w3.org/2004/02/skos/core#definition> "A subsidiary body of ECOSOC, the Committee was created through resolution 1998/46, annex I, which merged two committees – the Committee on New and Renewable Sources of Energy and the Committee on Energy for Development and the Committee on Natural Resources – into a single expert body."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNCENRD"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001218"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNCENRD"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Комисия на ООН за устойчиво развитие"@bg, "Comité de Energía y Recursos Naturales para el Desarrollo"@es, "Committee on Energy and Natural Resources for Development"@en, "Ausschuss für Energie und natürliche Ressourcen im Dienste der Entwicklung"@de, "Comité de l’énergie et des ressources naturelles au service du développement"@fr;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCENRD_1998_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCENRD";
    <http://publications.europa.eu/resource/authority/op-code> "UNCENRD";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCENRD";
    <http://publications.europa.eu/ontology/authority/start.use> "1998-07-31";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCENRD";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "2002-10-25"
}
