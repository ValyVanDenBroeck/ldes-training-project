<#ad4619d4ffb165c0e06766ac3c656bfc> {
<http://publications.europa.eu/resource/authority/corporate-body/ECPRD> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/8395>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Eiropas Parlamentārās pētniecības un dokumentācijas centrs"@lv, "Centrul European pentru Cercetare și Documentare Parlamentară"@ro, "Europos parlamentinių tyrimų ir dokumentų centras"@lt, "Európske centrum pre parlamentný výskum a dokumentáciu"@sk, "European Centre for Parliamentary Research and Documentation"@en, "Europski centar za parlamentarna istraživanja i dokumentaciju"@hr, "Europees Centrum voor parlementair onderzoek en documentatie"@nl, "Centro Europeo de Investigación y Documentación Parlamentaria"@es, "Evropské středisko pro parlamentní výzkum a dokumentaci"@cs, "Европски центар за парламентарна истраживања и документацију"@sr, "Euroopa Parlamendiuuringute ja -dokumentatsiooni Keskus"@et, "Centro Europeu de Investigação e Documentação Parlamentares"@pt, "An Lárionad Eorpach um Thaighde agus Doiciméadú Parlaiminteach"@ga, "Europejskie Centrum Badań i Dokumentacji Parlamentarnej"@pl, "Europeiskt center för parlamentarisk forskning och dokumentation"@sv, "Centro europeo di ricerca e documentazione parlamentare"@it, "Ċentru Ewropew ta’ Riċerka u Dokumentazzjoni Parlamentari"@mt, "Europäisches Zentrum für Parlamentarische Wissenschaft und Dokumentation"@de, "Centre européen de recherche et de documentation parlementaires"@fr, "Det Europæiske Center for Parlamentarisk Forskning og Dokumentation"@da, "Az Európai Parlamenti Kutatási és Dokumentációs Központ"@hu, "Европейски център за парламентарни проучвания и документация"@bg, "Evropski center za parlamentarne raziskave in dokumentacijo"@sl, "Euroopan parlamenttien tutkimus- ja dokumentaatiokeskus"@fi, "Ευρωπαϊκό Κέντρο Κοινοβουλευτικής Έρευνας και Τεκμηρίωσης"@el;
    <http://www.w3.org/2004/02/skos/core#definition> "Le CERDP créé à la demande des présidents des Assemblées parlementaires européennes, constitue un précieux instrument de coopération parlementaire et d’échange d’informations. Le Parlement européen, l’Assemblée parlementaire du Conseil de l’Europe et les assemblées parlementaires, dont les présidents sont membres de la Conférence européenne des Présidents de parlement, sont membres du CERDP. Le Centre offre à l’ensemble des acteurs concernés la possibilité de travailler de concert dans le cadre de demandes de données à des fins comparatives, de séminaires et d’enquêtes effectuées par tel ou tel parlement sur des questions spécifiques."@fr, "Since it was first established at the request of the Speakers of European Parliamentary Assemblies, the European Centre for Parliamentary Research & Documentation (ECPRD), a community of parliamentary knowledge, has become a useful tool for inter-parliamentary cooperation and information exchange. The ECPRDs members are: the European Parliament, the Parliamentary Assembly of the Council of Europe and Parliaments where the President is a member of the European Conference of Presidents of Parliament. The main activities of ECPRD are the comparative requests and seminars hosted by one of the Member Parliaments.In fact, the ECPRD is less a centre rather than a network of people whose voluntary commitment contributes essentially to its well-functioning."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ECPRD"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001304"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ECPRD"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "ECPRD"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "EZPWD"@de, "CERDP"@sv, "CERDP"@it, "CERDP"@fr, "ECPOD"@nl, "CEIDP"@es, "ECPRD"@en, "ECPRD"@fi, "ΕΚΚΕΤ"@el, "ЕЦППД"@bg;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ECPRD_1977_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ECPRD";
    <http://publications.europa.eu/resource/authority/op-code> "ECPRD";
    <http://publications.europa.eu/ontology/authority/op-code> "ECPRD";
    <http://publications.europa.eu/ontology/authority/start.use> "1977-06-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "ECPRD";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b3057_b3056_b3055_df_15_807;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR>, <http://publications.europa.eu/resource/authority/corporate-body/EP>.
_:b3057_b3056_b3055_df_15_807 a <http://publications.europa.eu/ontology/authority/MappedCode>;
    <http://purl.org/dc/elements/1.1/source> "PUB";
    <http://publications.europa.eu/ontology/authority/affected-table> "PUB_CORP";
