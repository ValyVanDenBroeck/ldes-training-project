<../../../index.trig> <https://w3id.org/tree#member> <#5f9071794f164915ef56fc19cc8bc005>.
<#5f9071794f164915ef56fc19cc8bc005> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_SFYM>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.691Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#5f9071794f164915ef56fc19cc8bc005> {
<http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_SFYM> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Fondo de Solidaridad para la Movilidad de los Jóvenes"@es, "Фонд солидарности за мобилност омладине"@sr, "Solidarnostni sklad za mobilnost mladih"@sl, "Fondul de solidaritate pentru mobilitatea tinerilor"@ro, "Fond solidarity pre mládežnícku mobilitu"@sk, "Fonds de solidarité pour la mobilité des jeunes"@fr, "Fundusz Solidarności na rzecz Mobilności Młodzieży"@pl, "Solidarity Fund for Youth Mobility"@en, "Solidaritätsfonds für Jugendmobilität"@de, "Solidariteitsfonds voor de mobiliteit van jongeren"@nl, "Fundo de Solidariedade para a Mobilidade dos Jovens"@pt, "Фонд за солидарност за младежка мобилност"@bg, "Noorte Liikuvuse Solidaarsusfond"@et, "Fondo di solidarietà per la mobilità dei giovani"@it, "Solidaritātes fonds jauniešu mobilitātes atbalstam"@lv, "Fond solidarity pro mobilitu mládeže"@cs, "Fond ta’ Solidarjetà għall-mobilità taż-żgħażagħ"@mt, "Szolidaritási Alap a Fiatalok Mobilitásáért"@hu, "Europarådets Solidaritetsfond for Unges Mobilitet"@da, "Jaunimo judumo solidarumo fondas"@lt, "Solidaarisuusrahasto nuorten liikkuvuuden edistämiseksi"@fi, "Ταμείο Αλληλεγγύης για την Κινητικότητα των Νέων"@el;
    <http://www.w3.org/2004/02/skos/core#definition> "The fund was commissioned by the European railway companies and a Protocol of Partnership Agreement was signed between the Council of Europe and the international Union of Railways on 16 December. The initial purpose of the agreement was to reduce the exclusion of the most disadvantaged young people by increasing their mobility, offering them access to international meetings, and developing the use of the InterRail card. The fund was financed by the sale of InterRail cards."@en, "Le fonds a été commissionné par les compagnies ferroviaires européennes, et un Accord de Partenariat fut signé entre le Conseil de l’Europe et l’Union Internationale des Chemins de Fer le 16 décembre. Le but initial de l’accord était de réduire l’exclusion des jeunes les plus désavantagés en accroissant leur mobilité, leur donnant accès à des réunions internationales et de développer l’utilisation des cartes InterRail. Le fonds était financé par la vente de cartes InterRail."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001319"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "COU_EUR_SFYM"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COU_EUR_SFYM"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "SFYM"@fr, "SFYM"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_SFYM_1994_0>;
    <http://purl.org/dc/elements/1.1/identifier> "COU_EUR_SFYM";
    <http://publications.europa.eu/resource/authority/op-code> "COU_EUR_SFYM";
    <http://publications.europa.eu/ontology/authority/op-code> "COU_EUR_SFYM";
    <http://publications.europa.eu/ontology/authority/start.use> "1994-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "COU_EUR_SFYM";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR>;
    <http://publications.europa.eu/ontology/authority/end.use> "2010-08-31"
}
<../../../index.trig> <https://w3id.org/tree#member> <#dcf40df2f00b684f31872e0d9c328ed4>.
<#dcf40df2f00b684f31872e0d9c328ed4> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_DB>;
