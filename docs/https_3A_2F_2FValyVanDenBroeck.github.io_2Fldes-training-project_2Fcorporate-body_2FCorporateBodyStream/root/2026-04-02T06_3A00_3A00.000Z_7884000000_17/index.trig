<#84ee42fb29581a2e6d6579aa919419a8> {
<http://publications.europa.eu/resource/authority/corporate-body/UNECA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Az ENSZ Afrikai Gazdasági Bizottsága"@hu, "Commission économique des Nations unies pour l’Afrique"@fr, "Gospodarska komisija Ujedinjenih naroda za Afriku"@hr, "Economische Commissie voor Afrika van de Verenigde Naties"@nl, "Comisia economică a Organizației Națiunilor Unite pentru Africa"@ro, "Commissione economica delle Nazioni Unite per l’Africa"@it, "Ekonomska komisija Združenih narodov za Afriko"@sl, "FN:s ekonomiska kommission för Afrika"@sv, "Birleşmiş Milletler Afrika Ekonomik Kurulu"@tr, "United Nations Economic Commission for Africa"@en, "Komisja Gospodarcza ONZ ds. Afryki"@pl, "Икономическа комисия на ООН за Африка"@bg, "Wirtschaftskommission der Vereinten Nationen für Afrika"@de, "Ühinenud Rahvaste Organisatsiooni Aafrika majanduskomisjon"@et, "Hospodárska komisia OSN pre Afriku"@sk, "Comissão Económica das Nações Unidas para a África"@pt, "Apvienoto Nāciju Organizācijas Ekonomikas komisija Āfrikai"@lv, "Економска комисија Уједињених нација за Африку"@sr, "Hospodářská komise OSN pro Afriku"@cs, "Kummissjoni Ekonomika tan-Nazzjonijiet Uniti għall-Afrika"@mt, "Οικονομική Επιτροπή των Ηνωμένων Εθνών για την Αφρική"@el, "YK:n Afrikan talouskomissio"@fi, "Jungtinių Tautų Afrikos ekonomikos komisija"@lt, "Comisión Económica para África de las Naciones Unidas"@es, "Coimisiún Eacnamaíochta na Náisiún Aontaithe don Afraic"@ga, "De Forenede Nationers Økonomiske Kommission for Afrika"@da;
    <http://www.w3.org/2004/02/skos/core#definition> "La Commission économique pour l’Afrique (CEA) joue un double rôle en tant qu’organisme régional de l’Organisation des Nations Unies et en tant que partie intégrante du paysage institutionnel régional en Afrique. Créée par le Conseil économique et social des Nations Unies, la CEA est l’une des cinq commissions régionales et a pour mandat d’appuyer le développement économique et social de ses États membres, d’encourager l’intégration régionale et de promouvoir la coopération internationale pour le développement de l’Afrique."@fr, "Established by the Economic and Social Council of the United Nations as one of the UN’s five regional commissions, ECA’s mandate is to promote the economic and social development of its member States, foster intra-regional integration, and promote international cooperation for Africa’s development. ECA’s strength derives from its role as the only UN agency mandated to operate at the regional and subregional levels to harness resources and bring them to bear on Africa’s priorities."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNECA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001193"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNECA"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ECA"@en, "CEA"@pt, "ECA"@de, "ECA"@hu, "ECA"@it, "ECA"@nl, "ECA"@lv, "ECA"@mt, "ECA"@da, "ECA"@pl, "ECA"@sv, "Ekonomická komise pro Afriku"@cs, "Икономическа комисия за Африка"@bg, "Kummissjoni Ekonomika għall-Afrika"@mt, "Ekonomska komisija za Afriko"@sl, "Comissão Económica para a África"@pt, "Den Økonomiske Kommission for Afrika"@da, "Wirtschaftskommission für Afrika"@de, "An Coimisiún Eacnamaíochta don Afraic"@ga, "Āfrikas Ekonomikas komisija"@lv, "Comisión Económica para África"@es, "Komisja Gospodarcza ds. Afryki"@pl, "ИКА"@bg, "CEA"@fr, "CEA"@ro, "Commissione economica per l’Africa"@it, "Οικονομική Επιτροπή για την Αφρική"@el, "Economic Commission for Africa"@en, "Economische Commissie voor Afrika"@nl, "Afrikai Gazdasági Bizottság"@hu, "Hospodárska komisia pre Afriku"@sk, "Afrikan talouskomissio"@fi, "CEPA"@es, "Comisia Economică pentru Africa"@ro, "Commission économique pour l’Afrique"@fr, "Afrikos ekonominė komisija"@lt, "Aafrika majanduskomisjon"@et;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNECA_1958_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNECA";
    <http://publications.europa.eu/resource/authority/op-code> "UNECA";
    <http://publications.europa.eu/ontology/authority/op-code> "UNECA";
    <http://publications.europa.eu/ontology/authority/start.use> "1958-04-29";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNECA";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
