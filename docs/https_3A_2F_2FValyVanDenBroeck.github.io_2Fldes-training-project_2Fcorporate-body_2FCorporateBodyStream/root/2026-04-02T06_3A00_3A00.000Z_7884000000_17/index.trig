<#399a7390a1312e5b3365007499c44f69> {
<http://publications.europa.eu/resource/authority/corporate-body/ICJ> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
