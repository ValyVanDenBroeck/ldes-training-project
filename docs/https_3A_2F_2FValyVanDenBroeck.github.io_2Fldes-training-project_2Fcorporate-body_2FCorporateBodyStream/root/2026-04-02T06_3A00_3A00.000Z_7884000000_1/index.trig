<#dcabdb74bb9bf93469fa11c436d8c2a2> {
<http://publications.europa.eu/resource/authority/corporate-body/ETSI> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
