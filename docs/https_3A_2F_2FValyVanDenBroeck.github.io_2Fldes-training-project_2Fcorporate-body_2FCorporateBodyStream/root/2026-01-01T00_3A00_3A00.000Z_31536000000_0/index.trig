    <http://www.w3.org/2004/02/skos/core#prefLabel> "Organisationen for Fiskeriet i Det Nordvestlige Atlanterhav"@da, "Organizacja Rybołówstwa Północno-Zachodniego Atlantyku"@pl, "Luoteis-Atlantin kalastusjärjestö"@fi, "Ziemeļrietumu Atlantijas zvejniecības organizācija"@lv, "Organizace pro rybolov v severozápadním Atlantiku"@cs, "Organização das Pescas do Noroeste Atlântico"@pt, "Северозападна атлантическа рибарска организация"@bg, "Visserijorganisatie voor het noordwestelijk deel van de Atlantische Oceaan"@nl, "Loode-Atlandi Kalastusorganisatsioon"@et, "Organizzazzjoni tas-Sajd fl-Atlantiku tal-Majjistral"@mt, "Šiaurės Vakarų Atlanto žvejybos organizacija"@lt, "Organisation des pêches de l’Atlantique du Nord-Ouest"@fr, "Eagraíocht Iascaigh an Atlantaigh Thiar Thuaidh"@ga, "Northwest Atlantic Fisheries Organization"@en, "Organizzazione della pesca nell’Atlantico nord-occidentale"@it, "Organizacija za ribarstvo na sjeverozapadnom Atlantiku"@hr, "Oganizația de Pescuit Nord-Vest-Atlantică"@ro, "Organización de Pesquerías del Atlántico Noroeste"@es, "Organizacije za ribištvo severozahodnega Atlantika"@sl, "Északnyugat-atlanti Halászati Szervezet"@hu, "Organisation für die Fischerei im Nordwestatlantik"@de, "Οργανισμός Αλιείας Βορειοδυτικού Ατλαντικού"@el, "Organisationen för fisket i nordvästra Atlanten"@sv, "Severozápadná atlantická rybárska organizácia"@sk;
    <http://www.w3.org/2004/02/skos/core#definition> "The Northwest Atlantic Fisheries Organization is an intergovernmental fisheries science and management organization that ensures the long-term conservation and sustainable use of the fishery resources in the Northwest Atlantic."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "NAFO"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001003"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "NAFO"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "NAFO"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/NAFO_1979_0>;
    <http://purl.org/dc/elements/1.1/identifier> "NAFO";
