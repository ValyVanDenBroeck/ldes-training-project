<../../../index.trig> <https://w3id.org/tree#member> <#299954782682116fa8ce29441405c535>.
<#299954782682116fa8ce29441405c535> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_ECLA>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.653Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#299954782682116fa8ce29441405c535> {
<http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_ECLA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Konferenza Ewropea tal-Awtoritajiet Lokali"@mt, "Euroopan paikallishallinnon konferenssi"@fi, "Eiropas Vietējo pašvaldību konference"@lv, "Conferência Europeia dos Poderes Locais"@pt, "Conferenza europea dei poteri locali"@it, "European Conference of Local Authorities"@en, "Conférence des pouvoirs locaux de l’Europe"@fr, "Conferencia Europea de Poderes Locales"@es;
    <http://www.w3.org/2004/02/skos/core#definition> "La Conférence tendait à assurer la participation des pouvoirs locaux à la réalisation des buts du Conseil de l’Europe, tels qu’ils étaient définis à l’article 1er de son Statut. Elle a eu notamment pour objet de faire connaître au Comité des Ministres et à l’Assemblée Consultative son avis sur les mesures susceptibles de se répercuter sur l’existence des collectivités locales et de mettre en cause leur responsabilité à l’égard des populations et des gouvernements. Elle tenait également les pouvoirs locaux informés du progrès de l’intégration européenne et s’efforce de les intéresser à l’idéal de l’unité européenne."@fr, "The Conference ensured the participation of local authorities in the achievement of the aims of the Council of Europe as defined in Article 1 of the Statute of the Council. The primary aim of the Conference was to inform the Committee of Ministers and the Consultative Assembly of its views on measures which were likely to have repercussions on local authorities or to involve the responsibility of local authorities towards the population and towards the Governments. It should also keep the local authorities informed about the progress of European integration and seek their support for the ideal of European unity."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COU_EUR_ECLA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COU_EUR_ECLA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001309"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_ECLA_1957_0>;
    <http://purl.org/dc/elements/1.1/identifier> "COU_EUR_ECLA";
    <http://publications.europa.eu/resource/authority/op-code> "COU_EUR_ECLA";
    <http://publications.europa.eu/ontology/authority/op-code> "COU_EUR_ECLA";
    <http://publications.europa.eu/ontology/authority/start.use> "1957-01-12";
    <http://publications.europa.eu/ontology/authority/authority-code> "COU_EUR_ECLA";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR>;
    <http://publications.europa.eu/ontology/authority/end.use> "1975-02-18"
}
