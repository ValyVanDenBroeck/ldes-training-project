<#dcf40df2f00b684f31872e0d9c328ed4> {
<http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_DB> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Ontwikkelingsbank van de Raad van Europa"@nl, "Euroopa Nõukogu Arengupank"@et, "Razvojna banka Vijeća Europe"@hr, "Rozvojová banka Rady Európy"@sk, "Eiropas Padomes Attīstības banka"@lv, "Banc Forbartha Chomhairle na hEorpa"@ga, "Banca de Dezvoltare a Consiliului Europei"@ro, "Entwicklungsbank des Europarates"@de, "Banco de Desarrollo del Consejo de Europa"@es, "Τράπεζα Ανάπτυξης του Συμβουλίου της Ευρώπης"@el, "Europarådets utvecklingsbank"@sv, "Europarådets Udviklingsbank"@da, "Euroopan neuvoston kehityspankki"@fi, "Council of Europe Development Bank"@en, "Az Európa Tanács Fejlesztési Bankja"@hu, "Banco de Desenvolvimento do Conselho da Europa"@pt, "Razvojna banka Sveta Evrope"@sl, "Bank Rozwoju Rady Europy"@pl, "Банка за развитие към Съвета на Европа"@bg, "Banca di sviluppo del Consiglio d’Europa"@it, "Banque de Développement du Conseil de l’Europe"@fr, "Bank ta’ Żvilupp tal-Kunsill tal-Ewropa"@mt, "Rozvojová banka Rady Evropy"@cs, "Europos Tarybos vystymo bankas"@lt;
    <http://www.w3.org/2004/02/skos/core#definition> "La CEB est un instrument majeur de la politique de solidarité en Europe. Elle participe au financement de projets sociaux, intervient en cas de situation d’urgence et contribue à améliorer la qualité de vie des groupes de population les plus défavorisés."@fr, "The CEB represents a major instrument of the policy of solidarity in Europe. It participates in financing social projects, responds to emergency situations and contributes to improving the living conditions of the most disadvantaged population groups."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COU_EUR_DB"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COU_EUR_DB"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001092"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "CEB"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_DB_1999_0>;
    <http://purl.org/dc/elements/1.1/identifier> "COU_EUR_DB";
    <http://publications.europa.eu/resource/authority/op-code> "COU_EUR_DB";
    <http://publications.europa.eu/ontology/authority/op-code> "COU_EUR_DB";
    <http://publications.europa.eu/ontology/authority/start.use> "1999-11-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "COU_EUR_DB";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR>
}
