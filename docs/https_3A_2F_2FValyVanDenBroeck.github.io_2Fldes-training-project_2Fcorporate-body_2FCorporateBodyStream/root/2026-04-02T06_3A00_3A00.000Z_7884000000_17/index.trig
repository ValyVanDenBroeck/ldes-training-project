    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Curtea Internațională de Justiție"@ro, "Meddržavno sodišče"@sl, "Cour internationale de justice"@fr, "Medzinárodný súdny dvor"@sk, "Starptautiskā Tiesa"@lv, "Den Internationale Domstol"@da, "Internationella domstolen"@sv, "Qorti Internazzjonali tal-Ġustizzja"@mt, "International Court of Justice"@en, "Международен съд"@bg, "Corte internazionale di giustizia"@it, "Corte Internacional de Justicia"@es, "Διεθνές Δικαστήριο"@el, "Tribunal Internacional de Justiça"@pt, "An Chúirt Bhreithiúnais Idirnáisiúnta"@ga, "Међународни суд правде"@sr, "Internationaal Gerechtshof"@nl, "Tarptautinis Teisingumo Teismas"@lt, "Międzynarodowy Trybunał Sprawiedliwości"@pl, "Internationaler Gerichtshof"@de, "Međunarodni sud"@hr, "Nemzetközi Bíróság"@hu, "Mezinárodní soudní dvůr"@cs, "Kansainvälinen tuomioistuin"@fi, "Rahvusvaheline Kohus"@et;
    <http://www.w3.org/2004/02/skos/core#definition> "Principal judicial organ of the United Nations which functions in accordance with its Statute, endowed with the power to settle legal disputes between nations when voluntarily submitted to it (judgements) and to give an advisory opinion, when requested, to the General Assembly, the Security Council as well as any other organ of the United Nations or a specialized agency (Parry and Grant) (cf. Arts. 92-96 of the United Nations Charter)."@en, "Organe judiciaire principal des Nations Unies, fonctionnant conformément à un Statut annexé à la Charte, dont la mission est de régler par des arrêts les différends d’ordre juridique entre États et de donner des avis consultatifs aux organes de l’ONU et aux institutions spécialisées (Dalloz) (cf. Art. 92 à 96 de la Charte des Nations Unies)"@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001224"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ICJ"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "ICJ"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "NB"@hu, "QIĠ"@mt, "TIJ"@pt, "ICJ"@sl, "ICJ"@da, "CBI"@ga, "ICJ"@en, "CIG"@it, "CIJ"@fr, "CIJ"@es, "MTS"@pl, "ΔΔ"@el, "IGH"@nl, "IGH"@de;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ICJ_1945_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ICJ";
    <http://publications.europa.eu/resource/authority/op-code> "ICJ";
    <http://publications.europa.eu/ontology/authority/op-code> "ICJ";
    <http://publications.europa.eu/ontology/authority/start.use> "1945-06-26";
    <http://publications.europa.eu/ontology/authority/authority-code> "ICJ";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
