<../../../index.trig> <https://w3id.org/tree#member> <#d2c4f6a24059609bdf61c6d1c0f5ac62>.
<#d2c4f6a24059609bdf61c6d1c0f5ac62> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/EACEA>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:09.875Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d2c4f6a24059609bdf61c6d1c0f5ac62> {
<http://publications.europa.eu/resource/authority/corporate-body/EACEA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Agencia Ejecutiva Europea de Educación y Cultura"@es, "Europäische Exekutivagentur für Bildung und Kultur"@de, "Europos švietimo ir kultūros vykdomoji įstaiga"@lt, "Agenzia esecutiva europea per l’istruzione e la cultura"@it, "Európska výkonná agentúra pre vzdelávanie a kultúru"@sk, "Det Europæiske Forvaltningsorgan for Uddannelse og Kultur"@da, "Европейска изпълнителна агенция за образование и култура"@bg, "An Ghníomhaireacht Feidhmiúcháin Eorpach um Oideachas agus Cultúr"@ga, "Agenția Executivă Europeană pentru Educație și Cultură"@ro, "Evropska izvajalska agencija za izobraževanje in kulturo"@sl, "Agência de Execução Europeia da Educação e da Cultura"@pt, "Evropská výkonná agentura pro vzdělávání a kulturu"@cs, "Ευρωπαϊκός Εκτελεστικός Οργανισμός Εκπαίδευσης και Πολιτισμού"@el, "Agence exécutive européenne pour l’éducation et la culture"@fr, "Eiropas Izglītības un kultūras izpildaģentūra"@lv, "European Education and Culture Executive Agency"@en, "Europska izvršna agencija za obrazovanje i kulturu"@hr, "Euroopa Hariduse ja Kultuuri Rakendusamet"@et, "L-Aġenzija Eżekuttiva Ewropea għall-Edukazzjoni u għall-Kultura"@mt, "Europeiska genomförandeorganet för utbildning och kultur"@sv, "Europees Uitvoerend Agentschap onderwijs en cultuur"@nl, "Európai Oktatási és Kulturális Végrehajtó Ügynökség"@hu, "Europejska Agencja Wykonawcza ds. Edukacji i Kultury"@pl, "Euroopan koulutuksen ja kulttuurin toimeenpanovirasto"@fi;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Education and Culture Executive Agency is entrusted with the implementation of the following (parts of) Union programmes: Creative Europe; Erasmus; European Solidarity Corps; Citizens, Equality, Rights and Values; Neighbourhood, development and international cooperation instrument (NDICI); Instrument for pre-accession assistance (IPA III), as well as with the implementation of the legacy of the following (parts of) Union programmes: Creative Europe; Erasmus+; European Solidarity Corps; Europe for Citizens; EU Aid Volunteers; the Instrument for Pre-accession Assistance (IPA II); the European Neighbourhood Instrument; the Instrument for Development Cooperation; the Partnership Instrument for cooperation with third countries; the 10th and 11th European Development Funds; the following programmes which were previously entrusted to the Education, Audio-visual and Culture Executive Agency in the period 2000-2013: the programme of cooperation with the United States of America in the field of higher education and vocational education and training (2006-2013); the agreement between the European Community and the Government of Canada establishing a cooperation framework in the fields of higher education, training and youth (2006-2013); the action programme in the field of lifelong learning (2007-2013); the ‘Culture’ programme (2007-2013); the ‘Europe for Citizens’ programme to promote active European citizenship (2007-2013); the ‘Youth in Action’ programme (2007-2013); the support programme for the European audiovisual sector (MEDIA 2007) (2007-2013); the Erasmus Mundus (II) action programme 2009-2013 for the enhancement of quality in higher education and the promotion of intercultural understanding through cooperation with third countries; the audiovisual cooperation programme with professionals from third countries (MEDIA Mundus) (2011-2013); projects in the field of higher education eligible for funding under the provisions on aid for economic cooperation with the developing countries in Asia; projects in the fields of higher education and youth eligible for funding under the provisions of the Instrument for Pre-Accession Assistance (IPA); projects in the field of primary, secondary and higher education and youth eligible for funding under the provisions of the European Neighbourhood and Partnership Instrument; projects in the field of higher education eligible for funding under the provisions of the financing instrument for development cooperation; projects in the field of higher education and youth eligible for funding under the provisions of the financing instrument for cooperation with industrialised and other high-income countries and territories."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EC"^^<http://publications.europa.eu/ontology/euvoc#OP_CAT>, "10.2797"^^<http://publications.europa.eu/ontology/euvoc#DOI_P>, "EACEA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "EACEA_CRF_232578"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>, "9416"^^<http://publications.europa.eu/ontology/euvoc#ISBN_RG>, "EACEA"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>, "EACEA_1"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>, "EACEA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001635"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "EACEA"@mt, "EACEA"@sl, "EACEA"@pl, "EACEA"@bg, "EACEA"@da, "EACEA"@fi, "EACEA"@ro, "EACEA"@sv, "EACEA"@el, "EACEA"@it, "EACEA"@pt, "EACEA"@hu, "EACEA"@ga, "EACEA"@es, "EACEA"@lv, "EACEA"@sk, "EACEA"@de, "EACEA"@et, "EACEA"@nl, "EACEA"@cs, "EACEA"@hr, "EACEA"@fr, "EACEA"@en, "EACEA"@lt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EACEA_2021_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EACEA";
    <http://publications.europa.eu/resource/authority/op-code> "EACEA";
    <http://publications.europa.eu/ontology/authority/op-code> "EACEA";
    <http://publications.europa.eu/ontology/authority/start.use> "2021-04-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "EACEA";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b1651_b1650_b1649_df_15_445, _:b1651_b1650_b1649_df_15_446, _:b1651_b1650_b1649_df_15_447;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COM>;
    <http://www.w3.org/2004/02/skos/core#narrower> <http://publications.europa.eu/resource/authority/corporate-body/EURY>;
    <http://www.w3.org/2004/02/skos/core#historyNote> "According to the Commission Implementing Decision (EU) 2021/173 of 12 February 2021 (http://data.europa.eu/eli/dec_impl/2021/173/oj), the European Education and Culture Executive Agency is established from 1 April 2021 until 31 December 2028 and it succeeds and replaces the Education, Audio-visual and Culture Executive Agency."@en.
_:b1651_b1650_b1649_df_15_445 a <http://publications.europa.eu/ontology/authority/MappedCode>;
