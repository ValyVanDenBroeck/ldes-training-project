<#a7e5226acdc3232bc261083ec555f5a9> {
<http://publications.europa.eu/resource/authority/corporate-body/IMO> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
