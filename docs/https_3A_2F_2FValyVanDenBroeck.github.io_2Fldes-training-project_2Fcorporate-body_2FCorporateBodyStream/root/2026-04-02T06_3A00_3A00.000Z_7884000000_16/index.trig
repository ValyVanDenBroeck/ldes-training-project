    <http://publications.europa.eu/ontology/authority/op-code> "EFTA_COUN";
    <http://publications.europa.eu/ontology/authority/start.use> "1960-01-04";
    <http://publications.europa.eu/ontology/authority/authority-code> "EFTA_COUN";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/EFTA>
}
<../../../index.trig> <https://w3id.org/tree#member> <#4343c2d9a4ee4f579506f2030583649a>.
<#4343c2d9a4ee4f579506f2030583649a> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/EFTA_CC>;
