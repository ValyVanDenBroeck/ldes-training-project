<#ae7fab1b81cc35dc8c898d8948e06840> {
<http://publications.europa.eu/resource/authority/corporate-body/BEUC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/4859>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Европейска организация на потребителите"@bg, "Ευρωπαϊκό Γραφείο Ενώσεων Καταναλωτών"@el, "Den Europæiske Forbrugerorganisation"@da, "Europska organizacija za zaštitu potrošača"@hr, "Europees Bureau van consumentenverenigingen"@nl, "Oficina Europea de Uniones de Consumidores"@es, "Gabinete Europeu das Uniões de Consumidores"@pt, "Evropská organizace spotřebitelů"@cs, "Eiropas Patērētāju organizācija"@lv, "Ufficio europeo delle unioni di consumatori"@it, "Biúró Eorpach na gCumann Tomhaltóirí"@ga, "Európai Fogyasztók Szervezete"@hu, "Bureau européen des unions de consommateurs"@fr, "Organizația Europeană a Consumatorilor"@ro, "Euroopan kuluttajajärjestö"@fi, "Europeiska konsumentorganisationen"@sv, "Uffiċċju Ewropew tal-Għaqdiet tal-Konsumaturi"@mt, "Evropska potrošniška organizacija"@sl, "European Consumer Organisation"@en, "Europäischer Verbraucherverband"@de, "Euroopa Tarbijaliitude Amet"@et, "Európska organizácia spotrebiteľov"@sk, "Europejska Organizacja Konsumentów"@pl, "Europos vartotojų organizacijų asociacija"@lt;
    <http://www.w3.org/2004/02/skos/core#definition> "Le BEUC a été fondé par les organisations de consommateurs de 6 États membres de ce qui s’appelait alors la Communauté économique européenne. Regroupant plus de 40 organisations membres issues de 31 pays européens, BEUC est une organisation non gouvernementale dont le travail consiste à faire entendre la voix des consommateurs européens auprès des institutions de l’Union européenne que sont la Commission, le Parlement et le Conseil."@fr, "BEUC was founded by consumer organisations from 6 Member States of what was then the European Economic Community. Comprised of more than 40 member organisations from 30-plus European countries, BEUC is a non-governmental organisation whose job it is to bring the voice of Europe’s consumers to the European Union legislative institutions of Commission, Parliament and Council."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001274"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "BEUC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "BEUC"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "BEUC"@da, "BEUC"@el, "BEUC"@nl, "BEUC"@ro, "BEUC"@lt, "BEUC"@fr, "BEUC"@pl, "BEUC"@bg, "BEUC"@hr, "BEUC"@hu, "BEUC"@sl, "BEUC"@it, "BEUC"@en, "BEUC"@cs, "BEUC"@sk, "BEUC"@de, "BEUC"@fi, "BEUC"@lv, "BEUC"@et, "BEUC"@pt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/BEUC_1962_0>;
    <http://purl.org/dc/elements/1.1/identifier> "BEUC";
    <http://publications.europa.eu/resource/authority/op-code> "BEUC";
    <http://publications.europa.eu/ontology/authority/op-code> "BEUC";
    <http://publications.europa.eu/ontology/authority/start.use> "1962-03-06";
    <http://publications.europa.eu/ontology/authority/authority-code> "BEUC"
}
