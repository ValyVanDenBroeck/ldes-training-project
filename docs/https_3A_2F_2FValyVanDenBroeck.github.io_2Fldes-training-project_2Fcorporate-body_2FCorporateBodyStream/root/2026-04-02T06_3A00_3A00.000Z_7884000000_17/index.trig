    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNEP>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.870Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1b0e1269b9922b792f5cf1552654079b> {
<http://publications.europa.eu/resource/authority/corporate-body/UNEP> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
