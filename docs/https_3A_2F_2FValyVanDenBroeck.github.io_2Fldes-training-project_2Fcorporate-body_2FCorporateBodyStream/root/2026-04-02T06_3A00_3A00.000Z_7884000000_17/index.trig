<#d6196bdc8fb8da8459d3e3a58aa37ff7> {
<http://publications.europa.eu/resource/authority/corporate-body/UNITAR> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/4611>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Apvienoto Nāciju Organizācijas Apmācības un pētniecības institūts"@lv, "Istituto delle Nazioni Unite per la formazione e la ricerca"@it, "Institut Ujedinjenih naroda za izobrazbu i istraživanja"@hr, "Istitut tan-Nazzjonijiet Uniti għat-Taħriġ u r-Riċerka"@mt, "De Forenede Nationers Institut for Uddannelse og Forskning"@da, "Institutul Națiunilor Unite pentru Instruire și Cercetare"@ro, "Instytut Narodów Zjednoczonych ds. Szkolenia i Badań"@pl, "FN:s utbildnings- och forskningsinstitut"@sv, "Instituto das Nações Unidas para a Formação e a Investigação"@pt, "Институт УН за обуку и истраживање"@sr, "Instituut van de Verenigde Naties voor opleiding en onderzoek"@nl, "Ausbildungs- und Forschungsinstitut der Vereinten Nationen"@de, "United Nations Institute for Training and Research"@en, "Институт на ООН за подготовка и научни изследвания"@bg, "Inštitút Organizácie Spojených národov pre vzdelávanie a výskum"@sk, "YK:n koulutus- ja tutkimuslaitos"@fi, "Institut OSN pro vzdělávání a výzkum"@cs, "Az ENSZ Képzési és Kutatóintézete"@hu, "Jungtinių Tautų mokymo ir mokslinių tyrimų institutas"@lt, "Institut des Nations unies pour la formation et la recherche"@fr, "Instituto de las Naciones Unidas para la Formación Profesional y la Investigación"@es, "ÜRO Koolitus- ja Uurimisinstituut"@et, "Ινστιτούτο των Ηνωμένων Εθνών για την Εκπαίδευση και την Έρευνα"@el, "Institiúid na Náisiún Aontaithe um Oiliúint agus Taighde"@ga, "Inštitut Združenih narodov za usposabljanje in raziskave"@sl;
    <http://www.w3.org/2004/02/skos/core#definition> "Organe autonome du système des Nations Unies, l’Institut des Nations Unies pour la formation et la recherche (UNITAR), contribue concrètement au développement des capacités de dizaines de milliers de personnes dans le monde. Depuis sa fondation en 1963, l’UNITAR a conclu des partenariats durables et a acquis une expérience et un savoir unique lui permettant de remplir son mandat. Ainsi, l’UNITAR peut répondre à la demande croissante des États Membres dans les domaines de la formation et du renforcement des capacités en matière d’Environnement; de la Paix, Sécurité et Diplomatie; et de-Gouvernance."@fr, "The United Nations Institute for Training and Research (UNITAR) is a training arm of the United Nations System. The Mission of UNITAR is to develop capacities of individuals, organizations and institutions to enhance global decision-making and to support country-level action for shaping a better future. UNITAR offers various training and capacity-development activities in the thematic areas of Strengthen multilateralism; Promote economic development and social inclusion; Advance environmental sustainability and green development; Promote sustainable peace; Research and Technology Applications and Cross-cutting issues. It is an autonomous body within the United Nations System."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNITAR"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001242"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNITAR"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UNITAR"@fr, "UNITAR"@sk, "UNITAR"@et, "UNITAR"@da, "UNITAR"@sl, "Unitar"@lv, "UNITAR"@hu, "Ινστιτούτο Εκπαιδεύσεως και Ερευνών του ΟΗΕ"@el, "UNITAR"@it, "UNITAR"@ro, "UNITAR"@pt, "UNITAR"@es, "UNITAR"@pl, "Az ENSZ Továbbképző és Kutató Intézete"@hu, "Ústav OSN pre výchovu a výskum"@sk, "Institutul ONU pentru Formare și Cercetare"@ro, "Inštitut ZN za izobraževanje in raziskave"@sl, "ANO Izglītības un zinātniskās pētniecības institūts"@lv, "ЮНИТАР"@bg, "UNITAR"@lt, "UNITAR"@fi, "UNITAR"@el, "UNITAR"@en, "UNITAR"@hr, "UNITAR"@de, "UNITAR"@ga, "Unitar"@sv, "UNITAR"@nl, "UNITAR"@mt, "UNITAR"@cs;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNITAR_1963_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNITAR";
    <http://publications.europa.eu/resource/authority/op-code> "UNITAR";
    <http://publications.europa.eu/ontology/authority/op-code> "UNITAR";
    <http://publications.europa.eu/ontology/authority/start.use> "1963-12-11";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNITAR";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
