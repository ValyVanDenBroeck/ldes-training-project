<../../../index.trig> <https://w3id.org/tree#member> <#1ef23af5f564891bf973df333aa0c3a9>.
<#1ef23af5f564891bf973df333aa0c3a9> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/WEU_1948_0>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:07.634Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1ef23af5f564891bf973df333aa0c3a9> {
<http://publications.europa.eu/resource/authority/corporate-body/WEU_1948_0> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Länsi-Euroopan unioni"@fi, "Западен съюз"@bg, "Western Union"@en, "Unjoni tal-Punent"@mt, "Western Union"@lv, "Vakarų sąjunga"@lt, "Unión Occidental"@es, "Unione occidentale"@it, "Union occidentale"@fr, "União Ocidental"@pt;
    <http://www.w3.org/2004/02/skos/core#definition> "La France, le Royaume-Uni, la Belgique, les Pays-Bas et le Luxembourg signent à Bruxelles le traité instituant l’Union occidentale qui ne se prémunit plus uniquement contre l’Allemagne mais qui vise à prévenir toute agression armée en Europe contre l’un de ses membres. Le pacte de Bruxelles, prévu pour une durée de cinquante ans, prévoit d’organiser la coopération des Cinq dans les domaines militaire, économique, social et culturel. Un haut commandement militaire unifié de l’Union occidentale, sorte d’État-major commun, est créé. Mais le pacte de Bruxelles se trouve rapidement vidé de ses compétences étendues avec la signature successive des traités de l’Organisation européenne de coopération économique (avril 1948), de l’Atlantique Nord (avril 1949), du Conseil de l’Europe (mai 1949) et de la Communauté européenne du charbon et de l’acier (avril 1951)."@fr, "France, the United Kingdom, Belgium, the Netherlands and Luxembourg signed the Brussels Treaty establishing the Western Union, designed to guard against any armed aggression in Europe, no longer just from Germany, against any of its members. The Brussels Treaty, scheduled to remain in force for 50 years, provided for the organisation of cooperation amongst the five signatories in the military, economic, social and cultural spheres. A united Military High Command of Western Union, a kind of joint HQ, was created. However, the Brussels Treaty was soon left devoid of its newly-expanded authority when a succession of treaties was signed which established the Organisation for European Economic Cooperation (April 1948), the North Atlantic Treaty Organisation (April 1949), the Council of Europe (May 1949) and the European Coal and Steel Community (April 1951)."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "WEU"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001281"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UO"@fr, "Brussels Treaty Organisation"@en, "Organisation du traité de Bruxelles"@fr, "WU"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/WEU_1948_0>;
    <http://purl.org/dc/elements/1.1/identifier> "WEU_1948_0";
    <http://publications.europa.eu/resource/authority/op-code> "WEU_1948_0";
    <http://publications.europa.eu/ontology/authority/op-code> "WEU_1948_0";
    <http://publications.europa.eu/ontology/authority/start.use> "1948-03-17";
    <http://publications.europa.eu/ontology/authority/authority-code> "WEU_1948_0";
    <http://publications.europa.eu/ontology/authority/end.use> "1954-10-20"
}
<../../../index.trig> <https://w3id.org/tree#member> <#62ae55e642e1ebd817e5bf41e0de4592>.
<#62ae55e642e1ebd817e5bf41e0de4592> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/COU_ARCTIC>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:07.639Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#62ae55e642e1ebd817e5bf41e0de4592> {
<http://publications.europa.eu/resource/authority/corporate-body/COU_ARCTIC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Arktická rada"@sk, "Arktická rada"@cs, "Északi-sarkvidéki Tanács"@hu, "Arkties taryba"@lt, "Arktika Nõukogu"@et, "Kunsill tal-Artiku"@mt, "Арктически съвет"@bg, "Consiglio dell’Artico"@it, "Arktikas Padome"@lv, "Arctische Raad"@nl, "An Chomhairle Artach"@ga, "Rada Arktyczna"@pl, "Arktični svet"@sl, "Αρκτικό Συμβούλιο"@el, "Conseil de l’Arctique"@fr, "Arktisk Råd"@da, "Arktičko vijeće"@hr, "Arktischer Rat"@de, "Arctic Council"@en, "Arktinen neuvosto"@fi, "Consejo Ártico"@es, "Arktiska rådet"@sv, "Consiliul Arcticii"@ro, "Conselho Ártico"@pt;
    <http://www.w3.org/2004/02/skos/core#definition> "The Arctic Council is a high-level intergovernmental forum that addresses issues faced by the Arctic governments and the indigenous people of the Arctic. It has eight member countries: Canada, Denmark, Finland, Iceland, Norway, Russia, Sweden, and the United States."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COU_ARCTIC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COU_ARCTIC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001076"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/COU_ARCTIC_1996_0>;
