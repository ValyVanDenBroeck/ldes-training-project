    <http://www.w3.org/2004/02/skos/core#altLabel> "Chafea"@sk, "Chafea"@sl, "Chafea"@mt, "Chafea"@nl, "Chafea"@de, "Chafea"@ga, "Chafea"@el, "Chafea"@fr, "Chafea"@en, "Chafea"@it, "Chafea"@sv, "Chafea"@fi, "Chafea"@et, "Chafea"@pt, "Chafea"@hr, "Chafea"@lt, "Chafea"@es, "Chafea"@bg, "Chafea"@ro, "Chafea"@pl, "Chafea"@lv, "CHAFEA"@cs, "CHAFEA"@da, "CHAFEA"@hu;
