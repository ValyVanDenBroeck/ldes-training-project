<#0c7c30680c34918c4072bf72b2e2c0bf> {
<http://publications.europa.eu/resource/authority/corporate-body/CHR> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Cilvēktiesību centrs"@lv, "Centro para os Direitos do Homem"@pt, "Inimõiguste Keskus"@et, "Център за човешките права"@bg, "Centre pour les droits de l’homme"@fr, "Centre for Human Rights"@en, "Ċentru għad-Drittijiet tal-Bniedem"@mt, "Centro de Derechos Humanos"@es, "Ihmisoikeuskeskus"@fi, "Žmogaus teisių centras"@lt;
    <http://www.w3.org/2004/02/skos/core#definition> "Organizationally, it started as a small division at United Nations Headquarters in the 1940s. The division later moved to Geneva and was upgraded to the Centre for Human Rights in the 1980s. At the World Conference on Human Rights in 1993, the international community decided to establish a more robust human rights mandate with stronger institutional support. Accordingly, Member States of the United Nations created OHCHR by a General Assembly Resolution in 1993."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001230"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "CHR"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "CHR"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "HR"@fr, "CDH"@es, "United Nations Centre for Human Rights"@en, "CHR"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/CHR_1980_0>;
    <http://purl.org/dc/elements/1.1/identifier> "CHR";
    <http://publications.europa.eu/resource/authority/op-code> "CHR";
    <http://publications.europa.eu/ontology/authority/op-code> "CHR";
    <http://publications.europa.eu/ontology/authority/start.use> "1980-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "CHR";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1997-09-14"
}
