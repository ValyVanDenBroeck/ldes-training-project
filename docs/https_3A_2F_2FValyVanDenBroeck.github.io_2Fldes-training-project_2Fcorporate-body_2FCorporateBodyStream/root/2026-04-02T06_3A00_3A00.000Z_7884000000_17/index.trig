    <http://www.w3.org/2004/02/skos/core#prefLabel> "Konferencia OSN o životnom prostredí a rozvoji"@sk, "Конференција УН о животној средини и развоју"@sr, "Jungtinių Tautų aplinkos ir plėtros konferencija"@lt, "Conferința Organizației Națiunilor Unite pentru mediu și dezvoltare"@ro, "Конференция на ООН по околна среда и развитие"@bg, "YK:n ympäristö- ja kehityskonferenssi"@fi, "Konferenca Združenih narodov o okolju in razvoju"@sl, "Az Egyesült Nemzetek konferenciája a környezetről és a fejlődésről"@hu, "Διάσκεψη των Ηνωμένων Εθνών για το Περιβάλλον και την Ανάπτυξη"@el, "Conferentie van de Verenigde Naties over milieu en ontwikkeling"@nl, "Conferenza delle Nazioni Unite sull’ambiente e lo sviluppo"@it, "Comhdháil na Náisiún Aontaithe ar Chomhshaol agus Forbairt"@ga, "Konferenza tan-Nazzjonijiet Uniti dwar l-Ambjent u l-Iżvilupp"@mt, "ÜRO keskkonna- ja arengukonverents"@et, "Konferencija Ujedinjenih naroda o okolišu i razvoju"@hr, "Konferenz der Vereinten Nationen über Umwelt und Entwicklung"@de, "Conférence des Nations unies sur l’environnement et le développement"@fr, "Konferencja Narodów Zjednoczonych „Środowisko i Rozwój”"@pl, "Konference OSN o životním prostředí a o rozvoji"@cs, "Conferencia de las Naciones Unidas sobre el Medio Ambiente y el Desarrollo"@es, "De Forenede Nationers konference om miljø og udvikling"@da, "Conferência das Nações Unidas sobre Ambiente e Desenvolvimento"@pt, "United Nations Conference on Environment and Development"@en, "ANO Konference par vidi un attīstību"@lv, "Förenta nationernas konferens om miljö och utveckling"@sv;
    <http://www.w3.org/2004/02/skos/core#definition> "The conference was the culmination of two years of negotiations by the Preparatory Committees (PrepComs). Five major agreements on global environmental issues were signed. Two of these, The Framework Convention on Climate Change and The Convention on Biological Diversity, were formal treaties whose provisions are binding on the parties. Agenda 21 is a wide-ranging assessment of social and economic sectors with goals for improving environmental and developmental impact of each. The Rio Declaration summarizes consensus principles of sustainable development, and the Statement on Forest Principles pledges parties to more sustainable use of forest resources."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001231"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNCED"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "UNCED"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "КОНОСР"@bg, "UNCED"@fi, "UNCED"@lv, "UNCED"@lt, "UNCED"@cs, "UNCED"@nl, "UNCED"@de, "UNCED"@it, "UNCED"@sv, "UNCED"@ro, "UNCED"@pl, "UNCED"@en, "UNCED"@sk, "UNCED"@sl, "UNCED"@mt, "UNCED"@ga, "UNCED"@hr, "UNCED"@hu, "UNCED"@da, "Cumbre para la Tierra"@es, "Cimeira da Terra"@pt, "Szczyt Ziemi"@pl, "Umweltgipfel"@de, "Vertice sulla Terra"@it, "CNUMAD"@es, "Verdensmiljøtopmøde"@da, "Sommet planète Terre"@fr, "ΔΗΕΠΑ"@el, "Earth Summit"@en, "Συνάντηση Κορυφής της Γης"@el, "CNUAD"@pt, "CNUED"@fr, "UNSED"@et;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCED_1992_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCED";
    <http://publications.europa.eu/resource/authority/op-code> "UNCED";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCED";
    <http://publications.europa.eu/ontology/authority/start.use> "1992-06-03";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCED";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1992-06-14"
}
