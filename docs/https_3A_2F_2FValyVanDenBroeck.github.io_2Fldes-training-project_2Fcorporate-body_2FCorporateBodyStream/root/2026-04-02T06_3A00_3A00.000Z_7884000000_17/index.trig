<#77f958c29689701db131b0dcf898930c> {
<http://publications.europa.eu/resource/authority/corporate-body/UNESCWA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Az ENSZ Nyugat-ázsiai Gazdasági és Szociális Bizottsága"@hu, "Икономическа и социална комисия на ООН за Западна Азия"@bg, "Economische en Sociale Commissie van de Verenigde Naties voor West-Azië"@nl, "Apvienoto Nāciju Organizācijas Ekonomikas un sociālo lietu komisija Rietumāzijai"@lv, "FN:s ekonomiska och sociala kommission för Västasien"@sv, "Komisja Gospodarczo-Społeczna ONZ ds. Azji Zachodniej"@pl, "Gospodarska i socijalna komisija Ujedinjenih naroda za zapadnu Aziju"@hr, "Commissione economica e sociale delle Nazioni Unite per l’Asia occidentale"@it, "Ühinenud Rahvaste Organisatsiooni Lääne-Aasia sotsiaal- ja majanduskomisjon"@et, "Ekonomska in socialna komisija Združenih narodov za zahodno Azijo"@sl, "Commission économique et sociale des Nations unies pour l’Asie occidentale"@fr, "Kummissjoni Ekonomika u Soċjali tan-Nazzjonijiet Uniti għall-Ażja tal-Punent"@mt, "Comisión Económica y Social para Asia Occidental de las Naciones Unidas"@es, "Hospodářská a sociální komise OSN pro západní Asii"@cs, "Jungtinių Tautų Vakarų Azijos ekonomikos ir socialinių reikalų komisija"@lt, "Comissão Económica e Social das Nações Unidas para a Ásia Ocidental"@pt, "Coimisiún Eacnamaíoch agus Sóisialta na Náisiún Aontaithe d’Iarthar na hÁise"@ga, "Οικονομική και Κοινωνική Επιτροπή των Ηνωμένων Εθνών για τη Δυτική Ασία"@el, "United Nations Economic and Social Commission for Western Asia"@en, "De Forenede Nationers Økonomiske Kommission for Vestasien"@da, "Comisia Economică și Socială a Națiunilor Unite pentru Asia de Vest"@ro, "Wirtschafts- und Sozialkommission der Vereinten Nationen für Westasien"@de, "Hospodárska a sociálna komisia OSN pre západnú Áziu"@sk, "YK:n Länsi-Aasian talous- ja sosiaalikomissio"@fi;
    <http://www.w3.org/2004/02/skos/core#definition> "Le secrétariat de la Commission économique et sociale pour l’Asie occidentale : Favorise le développement économique et social par la coopération et l’intégration régionales et sous-régionales; Sert, dans le cadre du système des Nations Unies, de principal lieu de discussion sur le développement économique et social dans la région de la CESAO."@fr, "ESCWA provides a framework for the formulation and harmonization of sectoral policies for member countries, a platform for congress and coordination, a home for expertise and knowledge, and an information observatory. ESCWA activities are coordinated with the divisions and main offices of the Headquarters of the United Nations, specialized agencies, and international and regional organizations, including the League of Arab States and its subsidiary bodies, and the Gulf Cooperation Council."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001198"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNESCWA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNESCWA"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Economic and Social Commission for Western Asia"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNESCWA_1985_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNESCWA";
    <http://publications.europa.eu/resource/authority/op-code> "UNESCWA";
    <http://publications.europa.eu/ontology/authority/op-code> "UNESCWA";
    <http://publications.europa.eu/ontology/authority/start.use> "1985-07-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNESCWA";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
