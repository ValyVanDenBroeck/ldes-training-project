<#672496c22b2037b476e277ebf6e1fd18> {
<http://publications.europa.eu/resource/authority/corporate-body/EUROCONTROL> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/906>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Eurocontrol"@ga, "Eurocontrol"@nl, "Eurocontrol"@et, "Eurocontrol"@is, "Eurocontrol"@de, "Eurocontrol"@tr, "Eurocontrol"@en, "Eurocontrol"@pt, "Eurocontrol"@it, "Eurocontrol"@sk, "Eurocontrol"@ro, "Eurocontrol"@da, "Eurocontrol"@es, "Eurocontrol"@lv, "Eurocontrol"@hu, "Eurocontrol"@cs, "Eurocontrol"@hr, "Eurocontrol"@fi, "Eurocontrol"@sl, "Eurocontrol"@mt, "Eurocontrol"@pl, "Eurocontrol"@fr, "Eurocontrol"@el, "Евроконтрол"@bg, "Eurocontrol"@sv, "Eurokontrolė"@lt;
    <http://www.w3.org/2004/02/skos/core#definition> "Eurocontrol is an intergovernmental organisation whose primary objective is the development of a seamless, pan-European air traffic management system that will contribute to making European aviation safer, performance-driven and environmentally sustainable. Eurocontrol supports the European Commission, EASA and National Supervisory Authorities in their regulatory activities. Actively involved in research, development and validation, Eurocontrol makes a substantial contribution to the SESAR Joint Undertaking. It was originally founded as a civil-military organisation to deal with air traffic control for civil and military users in the upper airspace of its six founding European Member States."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EUROCONTROL"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0000372"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EUROCONTROL"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "EUROCONTROL"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Európai Szervezet a Légi Közlekedés Biztonságáért"@hu, "Organizzazione europea per la sicurezza della navigazione aerea"@it, "Ευρωπαϊκός Οργανισμός για την Ασφάλεια της Αεροναυτιλίας"@el, "Europejska Organizacja ds. Bezpieczeństwa Żeglugi Powietrznej"@pl, "Organização Europeia para a Segurança da Navegação Aérea"@pt, "Európska organizácia pre bezpečnosť leteckej prevádzky"@sk, "Европейска организация за безопасност на въздухоплаването"@bg, "Europska organizacija za sigurnost zračne plovidbe"@hr, "Europos saugios oro navigacijos organizacija"@lt, "Europese Organisatie voor de Veiligheid van de Luchtvaart"@nl, "Evropska organizacija za varnost zračne plovbe"@sl, "Euroopa Lennuliikluse Ohutuse Organisatsioon"@et, "Eiropas Aeronavigācijas drošības organizācija"@lv, "An Eagraíocht Eorpach um Shábháilteacht na hAerloingseoireachta"@ga, "Organizzazzjoni Ewropea għas-Sikurezza tan-Navigazzjoni bl-Ajru"@mt, "Evropská organizace pro bezpečnost letového provozu"@cs, "Den Europæiske Organisation for Luftfartens Sikkerhed"@da, "Organisation européenne pour la sécurité de la navigation aérienne"@fr, "Euroopan lennonvarmistusjärjestö"@fi, "Europäische Organisation für Flugsicherung"@de, "Organización Europea para la Seguridad de la Navegación Aérea"@es, "European Organisation for the Safety of Air Navigation"@en, "Europeiska organisationen för säkrare flygtrafiktjänst"@sv, "Organizația Europeană pentru Siguranța Navigației Aeriene"@ro;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EUROCONTROL_1960_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EUROCONTROL";
    <http://publications.europa.eu/resource/authority/op-code> "EUROCONTROL";
    <http://publications.europa.eu/ontology/authority/op-code> "EUROCONTROL";
    <http://publications.europa.eu/ontology/authority/start.use> "1960-12-13";
    <http://publications.europa.eu/ontology/authority/authority-code> "EUROCONTROL";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b23_b22_b21_df_15_2.
_:b23_b22_b21_df_15_2 a <http://publications.europa.eu/ontology/authority/MappedCode>;
