    <http://www.w3.org/2004/02/skos/core#prefLabel> "Ευρωπαϊκή Εθελοντική Υπηρεσία"@el, "Europäischer Freiwilligendienst"@de, "Serviciul European de Voluntariat"@ro, "Den Europæiske Voluntørtjeneste"@da, "Servizio volontario europeo"@it, "Európai önkéntes szolgálat"@hu, "Europska volonterska služba"@hr, "Evrópska sjálfboðaliðaþjónustan"@is, "European Voluntary Service"@en, "Serviço Voluntário Europeu"@pt, "Service volontaire européen"@fr, "Servizz Ewropew tal-Volontarjat"@mt, "Europos savanorių tarnyba"@lt, "Európska dobrovoľnícka služba"@sk, "Servicio Voluntario Europeo"@es, "Avrupa Gönüllü Hizmeti"@tr, "Wolontariat Europejski"@pl, "Evropská dobrovolná služba"@cs, "Europees Vrijwilligerswerk"@nl, "Europeisk volontärtjänst"@sv, "Euroopa vabatahtlik teenistus"@et, "Eiropas Brīvprātīgo dienests"@lv, "An tSeirbhís Shaorálach Eorpach"@ga, "Европейска доброволческа служба"@bg, "Evropska prostovoljska služba"@sl, "Eurooppalainen vapaaehtoispalvelu"@fi;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Voluntary Service (EVS) allows a young person (17–30 years) to become a volunteer in another country for a specified period, normally between 2–12 months. The service activities can be, for example, in the field of environment, arts and culture, activities with children, young people or the elderly, heritage or sports and leisure activities. Each project has three partners, a volunteer, a sending organisation and a host organisation. The project has to take place in a country other than where the volunteers lives, is non-profit-making and unpaid. One of the countries involved in a project must be an EU Member State or an accession country."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EVS"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001548"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EVS"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "SVE"@es, "SVE"@pt, "SVE"@fr, "SVE"@it, "SVE"@mt, "EVS"@fi, "EVS"@lv, "EVS"@sl, "EVS"@nl, "ЕДС"@bg, "EDS"@sk, "EDS"@cs;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EVS_1996_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EVS";
    <http://publications.europa.eu/resource/authority/op-code> "EVS";
    <http://publications.europa.eu/ontology/authority/op-code> "EVS";
