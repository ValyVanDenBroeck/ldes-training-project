<#0d153d9d1bba4cf42f2e66cf966ab735> {
<http://publications.europa.eu/resource/authority/corporate-body/UNCSD> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Комисия на ООН за устойчиво развитие"@bg, "Ühinenud Rahvaste Organisatsiooni säästva arengu komisjon"@et, "Komise OSN pro udržitelný rozvoj"@cs, "Comisia Organizației Națiunilor Unite pentru dezvoltare durabilă"@ro, "Coimisiún na Náisiún Aontaithe um Fhorbairt Inbhuanaithe"@ga, "FN:s kommission för hållbar utveckling"@sv, "Commission des Nations unies du développement durable"@fr, "United Nations Commission on Sustainable Development"@en, "Comisión de las Naciones Unidas sobre el Desarrollo Sostenible"@es, "Jungtinių Tautų Darnaus vystymosi komisija"@lt, "Az ENSZ Fenntartható Fejlődési Bizottsága"@hu, "Apvienoto Nāciju Organizācijas Ilgtspējīgas attīstības komisija"@lv, "Kummissjoni tan-Nazzjonijiet Uniti dwar l-Iżvilupp Sostenibbli"@mt, "Komisia OSN pre trvalo udržateľný rozvoj"@sk, "YK:n kestävän kehityksen toimikunta"@fi, "Komisija Združenih narodov za trajnostni razvoj"@sl;
    <http://www.w3.org/2004/02/skos/core#definition> "The United Nations Commission on Sustainable Development (CSD) was established by the UN General Assembly to ensure effective follow-up of United Nations Conference on Environment and Development. From its inception, the CSD was highly participatory in structure and outlook, by engaging in its formal proceedings a wide range of official stakeholders and partners through innovative formulae. At its eleventh session in 2003, the Commission decided on a multi-year work programme consisting of review and policy years. Since its establishment in 1992, the Commission has greatly advanced the sustainable development agenda within the international community. At the United Nations Conference on Sustainable Development (Rio+20), Member States agreed to establish a high level political forum that will subsequently replace the Commission on Sustainable Development."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001217"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNCSD"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNCSD"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Commission du développement durable"@fr, "Komisia pre trvalo udržateľný rozvoj"@sk, "Säästva arengu komisjon"@et, "Komise pro udržitelný rozvoj"@cs, "Ilgtspējīgas attīstības komisija"@lv, "Commissione per lo sviluppo sostenibile"@it, "CSD"@it, "CSD"@en, "CSD"@es, "Comissão do Desenvolvimento Sustentável"@pt, "Fenntartható Fejlődési Bizottság"@hu, "CSD"@da, "CSD"@sk, "Kestävän kehityksen toimikunta"@fi, "CSD"@sv, "CSD"@cs, "CSD"@de, "CSD"@mt, "CSD"@nl, "Comisión sobre el Desarrollo Sostenible"@es, "Darnaus vystymosi komisija"@lt, "Commission on Sustainable Development"@en, "Kummissjoni dwar l-Iżvilupp Sostenibbli"@mt, "Kommissionen for Bæredygtig Udvikling"@da, "UNCSD"@sl, "UNCSD"@ga, "Komisja ds. Zrównoważonego Rozwoju"@pl, "CDS"@pt, "Commissie Duurzame Ontwikkeling"@nl, "Комисия за устойчиво развитие"@bg, "Comisia ONU pentru Dezvoltare Durabilă"@ro, "CDD"@fr, "CDD"@ro, "Επιτροπή για τη βιώσιμη ανάπτυξη"@el, "Kommission für nachhaltige Entwicklung"@de;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCSD_1992_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCSD";
    <http://publications.europa.eu/resource/authority/op-code> "UNCSD";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCSD";
    <http://publications.europa.eu/ontology/authority/start.use> "1992-12-22";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCSD";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "2013-09-20"
}
<../../../index.trig> <https://w3id.org/tree#member> <#202d9129cbce6e229b6e645efd40e07f>.
<#202d9129cbce6e229b6e645efd40e07f> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/IMCO>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.329Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#202d9129cbce6e229b6e645efd40e07f> {
<http://publications.europa.eu/resource/authority/corporate-body/IMCO> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Междуправителствена морска съвещателна организация"@bg, "Intergouvernementele Maritieme Consultatieve Organisatie"@nl, "Den Mellemstatslige Rådgivende Søfartsorganisation"@da, "Valitsustevaheline merendusalane nõuandeorganisatsioon"@et, "Διακυβερνητικός Ναυτιλιακός Συμβουλευτικός Οργανισμός"@el, "Starpvalstu konsultatīvā jūrniecības organizāciju"@lv, "Organizzazione consultiva intergovernativa della navigazione marittima"@it, "Inter-Governmental Maritime Consultative Organization"@en, "Organizzazzjoni Konsultattiva Marittima Intergovernattiva"@mt, "An Eagraíocht Chomhairleach Mhuirí Idir-rialtasach"@ga, "Kansainvälinen merenkulkualan neuvoa-antava järjestö"@fi, "Zwischenstaatliche Beratende Seeschiffahrtsorganisation"@de, "Organização Marítima Consultiva Intergovernamental"@pt, "Organisation intergouvernementale consultative de la navigation maritime"@fr, "Organización Consultiva Marítima Intergubernamental"@es;
    <http://www.w3.org/2004/02/skos/core#definition> "In 1948 an international conference in Geneva adopted a convention formally establishing IMO (the original name was the Inter-Governmental Maritime Consultative Organization). The purposes of the Organization, as summarized by Article 1(a) of the Convention, was \"to provide machinery for cooperation among Governments in the field of governmental regulation and practices relating to technical matters of all kinds affecting shipping engaged in international trade; to encourage and facilitate the general adoption of the highest practicable standards in matters concerning maritime safety, efficiency of navigation and prevention and control of marine pollution from ships\". IMO’s first task was to adopt a new version of the International Convention for the Safety of Life at Sea (SOLAS), the most important of all treaties dealing with maritime safety."@en, "En 1948, une Conférence internationale convoquée à Genève a adopté une convention portant officiellement création de l’OMI (dont le premier nom était Organisation intergouvernementale consultative de la navigation maritime). Les buts de l’Organisation, tels qu’ils sont énoncés à l’alinéa a) de l’article premier de la Convention sont \"d’instituer un système de collaboration entre les gouvernements dans le domaine de la réglementation et des usages gouvernementaux ayant trait aux questions techniques de toutes sortes qui intéressent la navigation commerciale internationale, d’encourager et de faciliter l’adoption générale de normes aussi élevées que possible en ce qui concerne la sécurité maritime, l’efficacité de la navigation, la prévention de la pollution des mers par les navires et la lutte contre cette pollution\". La première tâche à laquelle s’est attelée l’OMI, lorsqu’elle a commencé ses activités en 1959 après l’entrée en vigueur de la Convention portant création de l’Organisation, a été d’adopter une nouvelle version de la Convention internationale pour la sauvegarde de la vie humaine en mer (Convention SOLAS), le plus important de tous les instruments relatifs à la sécurité maritime."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "IMCO"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "OMCI"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "IMCO"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001256"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "IMCO"@en, "IMCO"@da, "IMCO"@fi, "OCMI"@fr, "ΝΣΟ"@el, "OCMI"@es, "OCIM"@it;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/IMCO_1958_0>;
    <http://purl.org/dc/elements/1.1/identifier> "IMCO";
    <http://publications.europa.eu/resource/authority/op-code> "IMCO";
    <http://publications.europa.eu/ontology/authority/op-code> "IMCO";
    <http://publications.europa.eu/ontology/authority/start.use> "1958-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "IMCO";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b5416_b5415_b5414_df_15_1445;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1981-12-31".
_:b5416_b5415_b5414_df_15_1445 a <http://publications.europa.eu/ontology/authority/MappedCode>;
    <http://purl.org/dc/elements/1.1/source> "EurLex";
    <http://publications.europa.eu/ontology/authority/affected-table> "FD_050";
    <http://publications.europa.eu/ontology/authority/legacy-code> "OMCI"
}
<../../../index.trig> <https://w3id.org/tree#member> <#ad8a8a2270be1d2faf49fd4107dc9271>.
<#ad8a8a2270be1d2faf49fd4107dc9271> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNFF>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.335Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ad8a8a2270be1d2faf49fd4107dc9271> {
<http://publications.europa.eu/resource/authority/corporate-body/UNFF> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Forum Narodów Zjednoczonych ds. Lasów"@pl, "Bossenforum van de Verenigde Naties"@nl, "Yhdistyneiden kansakuntien metsäfoorumi"@fi, "FN:s skogsforum"@sv, "Fórum OSN pro lesy"@cs, "De Forenede Nationers Skovforum"@da, "Fórum OSN o lesoch"@sk, "Φόρουμ των Ηνωμένων Εθνών για τα Δάση"@el, "Fóram na Náisiún Aontaithe maidir le Foraisí"@ga, "Forum tan-Nazzjonijiet Uniti dwar il-Foresti"@mt, "Forum Združenih narodov za gozdove"@sl, "Forumul Organizației Națiunilor Unite pentru păduri"@ro, "Az Egyesült Nemzetek Erdészeti Fóruma"@hu, "Fórum das Nações Unidas sobre as Florestas"@pt, "Forum Ujedinjenih naroda o šumama"@hr, "United Nations Forum on Forests"@en, "Форум на Обединените нации по горите"@bg, "Jungtinių Tautų Miškų forumas"@lt, "Waldforum der Vereinten Nationen"@de, "Foro de las Naciones Unidas sobre los Bosques"@es, "Forum delle Nazioni Unite sulle foreste"@it, "Ühinenud Rahvaste Organisatsiooni metsafoorum"@et, "Forum des Nations unies sur les forêts"@fr, "Apvienoto Nāciju Organizācijas Mežu forums"@lv;
    <http://www.w3.org/2004/02/skos/core#definition> "The Economic and Social Council of the United Nations, in its Resolution 2000/35 established the United Nations Forum on Forests, a subsidiary body with the main objective to promote “… the management, conservation and sustainable development of all types of forests and to strengthen long-term political commitment to this end…” based on the Rio Declaration, the Forest Principles, Chapter 11 of Agenda 21 and the outcome of the IPF/IFF Processes and other key milestones of international forest policy. The Forum has universal membership, and is composed of all Member States of the United Nations and specialized agencies."@en, "Le Forum des Nations Unies sur les forêts a été créé par l’ECOSOC dans sa résolution 2000/35, pour \"renforcer l’engagement politique à l’égard de la gestion, de la conservation et du développement durable de tout type de forêts\". Le Forum se réunit annuellement et rend compte à l’ECOSOC."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001222"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNFF"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "UNFF"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ÜRO metsandusfoorum"@et, "FNUF"@fr, "FNUF"@pt, "UNFF"@nl, "UNFF"@sk, "UNFF"@en, "FNUB"@es, "UNFF"@da, "UNFF"@sv, "UNFF"@mt, "UNFF"@it, "Foro sobre los Bosques"@es, "FN’s Skovforum"@da, "UNFF"@lt, "UNFF"@fi, "Az ENSZ Erdészeti Fóruma"@hu, "UNFF"@lv, "UNFF"@de, "YK:n metsäfoorumi"@fi, "Форум на ООН по горите"@bg, "Miškų forumas"@lt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNFF_2000_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNFF";
    <http://publications.europa.eu/resource/authority/op-code> "UNFF";
    <http://publications.europa.eu/ontology/authority/op-code> "UNFF";
    <http://publications.europa.eu/ontology/authority/start.use> "2000-10-18";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNFF";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
<../../../index.trig> <https://w3id.org/tree#member> <#7e355c8b15fed4e04eaadf1bdbceb016>.
<#7e355c8b15fed4e04eaadf1bdbceb016> a <https://www.w3.org/ns/activitystreams#Create>;
