    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "United Nations Commission on the Status of Women"@en, "Komisja ONZ ds. Statusu Kobiet"@pl, "Kummissjoni tan-Nazzjonijiet Uniti dwar l-Istatus tan-Nisa"@mt, "Apvienoto Nāciju Organizācijas Sieviešu statusa komisija"@lv, "FN’s Kommission for Kvinders Status"@da, "FN:s kvinnokommission"@sv, "Az ENSZ Nők Helyzetével Foglalkozó Bizottsága"@hu, "Kommission der Vereinten Nationen zur Rechtsstellung der Frau"@de, "Комисия на ООН за положението на жените"@bg, "Komisia OSN pre postavenie žien"@sk, "Comisión de la Condición Jurídica y Social de la Mujer de las Naciones Unidas"@es, "Commission des Nations unies de la condition de la femme"@fr, "YK:n naisten asemaa käsittelevä toimikunta"@fi, "Commissie van de Verenigde Naties voor de Status van de Vrouw"@nl, "Coimisiún na Náisiún Aontaithe um Stádas na mBan"@ga, "Επιτροπή των Ηνωμένων Εθνών για τη θέση της γυναίκας"@el, "Komisija Ujedinjenih naroda za status žena"@hr, "Comissão do Estatuto da Mulher das Nações Unidas"@pt, "Komise OSN pro postavení žen"@cs, "Jungtinių Tautų Moterų padėties komisija"@lt, "Commissione delle Nazioni Unite sulla condizione femminile"@it, "Comisia ONU pentru Statutul Femeilor"@ro, "Ühinenud Rahvaste Organisatsiooni naiste olukorra komisjon"@et, "Komisija Združenih narodov za položaj žensk"@sl;
    <http://www.w3.org/2004/02/skos/core#definition> "The Commission on the Status of Women (CSW) is the principal global intergovernmental body exclusively dedicated to the promotion of gender equality and the empowerment of women. A functional commission of the Economic and Social Council, it was established by Council resolution 11(II). The CSW is instrumental in promoting women’s rights, documenting the reality of women’s lives throughout the world, and shaping global standards on gender equality and the empowerment of women."@en, "La Commission de la condition de la femme des Nations Unies (CSW) est le principal organe intergouvernemental mondial dédié exclusivement à la promotion de l’égalité des sexes et de l’autonomisation des femmes. La CSW est une commission fonctionnelle du Conseil économique et social des Nations Unies créée par la résolution 11(II) du Conseil. La Commission de la condition de la femme joue un rôle important dans la promotion des droits des femmes. Elle reflète la réalité vécue par les femmes dans le monde entier et contribue à l’établissement des normes mondiales relatives à l’égalité des sexes et à l’autonomisation des femmes."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "UNCSW"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001221"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNCSW"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Naiste staatuse komisjon"@et, "Commission de la condition de la femme"@fr, "Kvinnokommissionen"@sv, "Comisia pentru statutul femeii"@ro, "Sieviešu statusa komisija"@lv, "Komisja ds. Statusu Kobiet"@pl, "Comisión de la Condición Jurídica y Social de la Mujer"@es, "Komise pro postavení žen"@cs, "FRK"@de, "Comissão da Condição da Mulher"@pt, "Commissie voor de Status van de Vrouw"@nl, "Комисия за положението на жените"@bg, "A Nők Helyzetével Foglalkozó Bizottság"@hu, "CSW"@da, "CSW"@en, "CSW"@fi, "CSW"@nl, "CSW"@mt, "CSW"@sk, "CSW"@it, "Commissione sulla condizione delle donne"@it, "Komisia pre postavenie žien"@sk, "Επιτροπή για τη θέση των γυναικών"@el, "CSW"@lv, "CSW"@sl, "Kummissjoni dwar l-Istatus tan-Nisa"@mt, "An Coimisiún um Stádas na mBan"@ga, "Moterų padėties komisija"@lt, "Kommission für die Rechtsstellung der Frau"@de, "Naisten asema -toimikunta"@fi;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCSW_1946_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCSW";
    <http://publications.europa.eu/resource/authority/op-code> "UNCSW";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCSW";
    <http://publications.europa.eu/ontology/authority/start.use> "1946-06-21";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCSW";
