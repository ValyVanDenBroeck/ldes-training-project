@prefix sds:    <https://w3id.org/sds#> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .
@prefix ldes:   <https://w3id.org/ldes#> .
@prefix tree:   <https://w3id.org/tree#> .
@prefix as:     <https://www.w3.org/ns/activitystreams#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

<https://ValyVanDenBroeck.github.io/ldes-training-project/corporate-body>
    a sds:Stream ;
    sds:carries [
        a sds:Member ;
        sds:shape <https://ValyVanDenBroeck.github.io/ldes-training-project/shape.ttl#ActivityShape> ;
    ] ;
    sds:dataset [
        a dcat:Dataset ;
        dcat:title "EU Corporate Body Vocabulary LDES Feed"@en ;
        ldes:timestampPath as:published ;
        tree:shape <https://ValyVanDenBroeck.github.io/ldes-training-project/shape.ttl#ActivityShape> ;
    ] .
