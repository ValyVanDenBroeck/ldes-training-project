    <http://publications.europa.eu/ontology/authority/op-code> "OHCHR_1993_0";
    <http://publications.europa.eu/ontology/authority/start.use> "1993-12-20";
    <http://publications.europa.eu/ontology/authority/authority-code> "OHCHR_1993_0";
