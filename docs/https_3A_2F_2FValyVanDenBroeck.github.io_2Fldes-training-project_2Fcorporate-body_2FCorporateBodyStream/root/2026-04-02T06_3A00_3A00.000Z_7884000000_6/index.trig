<../../../index.trig> <https://w3id.org/tree#member> <#a6cf602811b323f1692b19f92a75db2f>.
<#a6cf602811b323f1692b19f92a75db2f> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/INEA>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:11.135Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#a6cf602811b323f1692b19f92a75db2f> {
<http://publications.europa.eu/resource/authority/corporate-body/INEA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Exekutivagentur für Innovation und Netze"@de, "Agencja Wykonawcza ds. Innowacyjności i Sieci"@pl, "Forvaltningsorganet for Innovation og Netværk"@da, "Agencia Ejecutiva de Innovación y Redes"@es, "Inovacijų ir tinklų programų vykdomoji įstaiga"@lt, "Genomförandeorganet för innovation och nätverk"@sv, "Innovációs és Hálózati Projektek Végrehajtó Ügynökség"@hu, "Výkonná agentura pro inovace a sítě"@cs, "Изпълнителна агенция за иновации и мрежи"@bg, "Izvajalska agencija za inovacije in omrežja"@sl, "Agence exécutive pour l’innovation et les réseaux"@fr, "Agenția Executivă pentru Inovare și Rețele"@ro, "L-Aġenzija Eżekuttiva għall-Innovazzjoni u n-Networks"@mt, "Uitvoerend Agentschap innovatie en netwerken"@nl, "Izvršna agencija za inovacije i mreže"@hr, "Gníomhaireacht Feidhmiúcháin an Ghréasáin Iompair Thras-Eorpaigh"@ga, "Innovation and Networks Executive Agency"@en, "Agenzia esecutiva per l’innovazione e le reti"@it, "Innovatsiooni ja Võrkude Rakendusamet"@et, "Inovācijas un tīklu izpildaģentūra"@lv, "Innovoinnin ja verkkojen toimeenpanovirasto"@fi, "Εκτελεστικός Οργανισμός Καινοτομίας και Δικτύων"@el, "Výkonná agentúra pre inovácie a siete"@sk, "Agência de Execução para a Inovação e as Redes"@pt;
    <http://www.w3.org/2004/02/skos/core#definition> "1. The Agency is hereby entrusted with the implementation of parts of the following Union programmes: (a) Connecting Europe Facility; (b) Part III Societal Challenges of the Horizon 2020 Specific Programme. This paragraph shall apply subject to and as from the date of the entry into force of each of these programmes. 2. The Agency is hereby entrusted with the implementation of the legacy of the following programmes: (a) trans-European transport network programme; (b) Marco Polo programme. 3. The Agency shall be responsible for the following tasks related to the implementation of the parts of the Union programmes referred to in paragraphs 1 and 2: (a) managing some stages of programme implementation and some phases in the lifetime of specific projects on the basis of the relevant work programmes adopted by the Commission, where the Commission has empowered it to do so in the instrument of delegation; (b) adopting the instruments of budget execution for revenue and expenditure and carrying out all the operations necessary for the management of the programme, where the Commission has empowered it to do so in the instrument of delegation; (c) providing support in programme implementation where the Commission has empowered it to do so in the instrument of delegation."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EF"^^<http://publications.europa.eu/ontology/euvoc#OP_CAT>, "INEA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "INEA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "9208"^^<http://publications.europa.eu/ontology/euvoc#ISBN_RG>, "COB0000753"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "10.2840"^^<http://publications.europa.eu/ontology/euvoc#DOI_P>, "INEA"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "INEA"@hu, "INEA"@es, "INEA"@fi, "INEA"@lt, "INEA"@sl, "INEA"@en, "INEA"@pt, "INEA"@de, "INEA"@ga, "INEA"@cs, "INEA"@bg, "INEA"@da, "INEA"@it, "INEA"@et, "INEA"@sv, "INEA"@hr, "INEA"@nl, "INEA"@lv, "INEA"@pl, "INEA"@fr, "INEA"@mt, "INEA"@el, "INEA"@ro, "INEA"@sk;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/INEA_2014_0>;
    <http://purl.org/dc/elements/1.1/identifier> "INEA";
    <http://publications.europa.eu/resource/authority/op-code> "INEA";
    <http://publications.europa.eu/ontology/authority/op-code> "INEA";
    <http://publications.europa.eu/ontology/authority/start.use> "2014-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "INEA";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b2114_b2113_b2112_df_15_632;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COM>;
    <http://publications.europa.eu/ontology/authority/end.use> "2021-03-31";
    <http://www.w3.org/2004/02/skos/core#historyNote> "According to the Commission Implementing Decision (EU) 2021/173 of 12 February 2021 (http://data.europa.eu/eli/dec_impl/2021/173/oj), the European Climate, Infrastructure and Environment Executive Agency is established from 1 April 2021 until 31 December 2028 and it succeeds and replaces the Innovation and Networks Executive Agency."@en.
_:b2114_b2113_b2112_df_15_632 a <http://publications.europa.eu/ontology/authority/MappedCode>;
    <http://purl.org/dc/elements/1.1/source> "PUB";
    <http://publications.europa.eu/ontology/authority/affected-table> "PUB_CORP";
    <http://publications.europa.eu/ontology/authority/legacy-code> "INEA"
}
