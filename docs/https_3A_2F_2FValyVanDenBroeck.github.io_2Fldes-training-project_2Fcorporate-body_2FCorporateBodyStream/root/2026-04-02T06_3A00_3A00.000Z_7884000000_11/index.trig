<#d6aad8e735b5b5b9b3694cec263666af> {
<http://publications.europa.eu/resource/authority/corporate-body/EUMS_EURO20> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Państwa członkowskie, które przyjęły walutę euro: Belgia, Bułgaria, Niemcy, Estonia, Irlandia, Grecja, Hiszpania, Francja, Włochy, Cypr, Łotwa, Litwa, Luksemburg, Malta, Niderlandy, Austria, Portugalia, Słowenia, Słowacja, Finlandia"@pl, "De medlemsstater, der har indført euroen: Belgien, Bulgarien, Tyskland, Estland, Irland, Grækenland, Spanien, Frankrig, Italien, Cypern, Letland, Litauen, Luxembourg, Malta, Nederlandene, Østrig, Portugal, Slovenien, Slovakiet, Finland"@da, "Členské štáty, ktoré prijali euro: Belgicko, Bulharsko, Nemecko, Estónsko, Írsko, Grécko, Španielsko, Francúzsko, Taliansko, Cyprus, Lotyšsko, Litva, Luxembursko, Malta, Holandsko, Rakúsko, Portugalsko, Slovinsko, Slovensko, Fínsko"@sk, "Valstybės narės, įsivedusios eurą: Belgija, Bulgarija, Vokietija, Estija, Airija, Graikija, Ispanija, Prancūzija, Italija, Kipras, Latvija, Lietuva, Liuksemburgas, Malta, Nyderlandai, Austrija, Portugalija, Slovėnija, Slovakija, Suomija"@lt, "Členské státy, které přijaly euro: Belgie, Bulharsko, Německo, Estonsko, Irsko, Řecko, Španělsko, Francie, Itálie, Kypr, Lotyšsko, Litva, Lucembursko, Malta, Nizozemsko, Rakousko, Portugalsko, Slovinsko, Slovensko, Finsko"@cs, "Gli Stati membri che hanno adottato l’euro: Belgio, Bulgaria, Germania, Estonia, Irlanda, Grecia, Spagna, Francia, Italia, Cipro, Lettonia, Lituania, Lussemburgo, Malta, Paesi Bassi, Austria, Portogallo, Slovenia, Slovacchia, Finlandia"@it, "Die Mitgliedstaaten, die den Euro eingeführt haben: Belgien, Bulgarien, Deutschland, Estland, Irland, Griechenland, Spanien, Frankreich, Italien, Zypern, Lettland, Litauen, Luxemburg, Malta, Niederlande, Österreich, Portugal, Slowenien, Slowakei, Finland"@de, "De lidstaten die de euro hebben aangenomen: België, Bulgarije, Duitsland, Estland, Ierland, Griekenland, Spanje, Frankrijk, Italië, Cyprus, Letland, Litouwen, Luxemburg, Malta, Nederland, Oostenrijk, Portugal, Slovenië, Slowakije, Finland"@nl, "Az eurót bevezető tagállamok: Belgium, Bulgária, Németország, Észtország, Írország, Görögország, Spanyolország, Franciaország, Olaszország, Ciprus, Lettország, Litvánia, Luxemburg, Málta, Hollandia, Ausztria, Portugália, Szlovénia, Szlovákia, Finnország"@hu, "Države članice koje su prihvatile euro: Belgija, Bugarska, Njemačka, Estonija, Irska, Grčka, Španjolska, Francuska, Italija, Cipar, Latvija, Litva, Luksemburg, Malta, Nizozemska, Austrija, Portugal, Slovenija, Slovačka, Finska"@hr, "États membres ayant adopté l’euro: Belgique, Bulgarie, Allemagne, Estonie, Irlande, Grèce, Espagne, France, Italie, Chypre, Lettonie, Lituanie, Luxembourg, Malte, Pays-Bas, Autriche, Portugal, Slovénie, Slovaquie, Finlande"@fr, "Държави членки, които са приели еврото: Белгия, България, Германия, Естония, Ирландия, Гърция, Испания, Франция, Италия, Кипър, Латвия, Литва, Люксембург, Малта, Нидерландия, Австрия, Португалия, Словения, Словакия, Финландия"@bg, "Statele membre care au adoptat euro: Belgia, Bulgaria, Germania, Estonia, Irlanda, Grecia, Spania, Franța, Italia, Cipru, Letonia, Lituania, Luxemburg, Malta, Țările de Jos, Austria, Portugalia, Slovenia, Slovacia, Finlanda"@ro, "Τα κράτη μέλη που υιοθέτησαν το ευρώ: Βέλγιο, Βουλγαρία, Γερμανία, Εσθονία, Ιρλανδία, Ελλάδα, Ισπανία, Γαλλία, Ιταλία, Κύπρος, Λετονία, Λιθουανία, Λουξεμβούργο, Μάλτα, Κάτω Χώρες, Αυστρία, Πορτογαλία, Σλοβενία, Σλοβακία, Φινλανδία"@el, "Euro kasutusele võtnud liikmesriigid: Belgia, Bulgaaria, Saksamaa, Eesti, Iirimaa, Kreeka, Hispaania, Prantsusmaa, Itaalia, Küpros, Läti, Leedu, Luksemburg, Malta, Madalmaad, Austria, Portugal, Sloveenia, Slovakkia, Soome"@et, "Los Estados miembros que han adoptado el euro: Bélgica, Bulgaria, Alemania, Estonia, Irlanda, Grecia, España, Francia, Italia, Chipre, Letonia, Lituania, Luxemburgo, Malta, Países Bajos, Austria, Portugal, Eslovenia, Eslovaquia, Finlandia"@es, "De medlemsstater som har infört euron: Belgien, Bulgarien, Tyskland, Estland, Irland, Grekland, Spanien, Frankrike, Italien, Cypern, Lettland, Litauen, Luxemburg, Malta, Nederländerna, Österrike, Portugal, Slovenien, Slovakien, Finland"@sv, "Jäsenvaltiot, jotka ovat ottaneet käyttöön euron: Belgia, Bulgaria, Saksa, Viro, Irlanti, Kreikka, Espanja, Ranska, Italia, Kypros, Latvia, Liettua, Luxemburg, Malta, Alankomaat, Itävalta, Portugali, Slovenia, Slovakia, Suomi"@fi, "Os Estados-Membros que adotaram o euro: Bélgica, Bulgária, Alemanha, Estónia, Irlanda, Grécia, Espanha, França, Itália, Chipre, Letónia, Lituânia, Luxemburgo, Malta, Países Baixos, Áustria, Portugal, Eslovénia, Eslováquia, Finlândia"@pt, "The Member States having adopted the euro: Belgium, Bulgaria, Germany, Estonia, Ireland, Greece, Spain, France, Italy, Cyprus, Latvia, Lithuania, Luxembourg, Malta, Netherlands, Austria, Portugal, Slovenia, Slovakia, Finland"@en, "Države članice, ki so sprejele euro: Belgija, Bolgarija, Nemčija, Estonija, Irska, Grčija, Španija, Francija, Italija, Ciper, Latvija, Litva, Luksemburg, Malta, Nizozemska, Avstrija, Portugalska, Slovenija, Slovaška, Finska"@sl, "Dalībvalstis, kuras ir ieviesušas euro: Beļģija, Bulgārija, Vācija, Igaunija, Īrija, Grieķija, Spānija, Francija, Itālija, Kipra, Latvija, Lietuva, Luksemburga, Malta, Nīderlande, Austrija, Portugāle, Slovēnija, Slovākija, Somija"@lv, "L-Istati Membri wara li adottaw l-euro: il-Belġju, il-Bulgarija, il-Ġermanja, l-Estonja, l-Irlanda, il-Greċja, Spanja, Franza, l-Italja, Ċipru, il-Latvja, il-Litwanja, il-Lussemburgu, Malta, il-Pajjiżi l-Baxxi, l-Awstrija, il-Portugall, is-Slovenja, is-Slovakkja, il-Finlandja"@mt, "Na Ballstáit a ghlac leis an euro: an Bheilg, an Bhulgáir, an Ghearmáin, an Eastóin, Éire, an Ghréig, an Spáinn, an Fhrainc, an Iodáil, an Chipir, an Laitvia, an Liotuáin, Lucsamburg, Málta, an Ísiltír, an Ostair, an Phortaingéil, an tSlóivéin, an tSlóvaic, an Fhionlainn"@ga;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001954"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EUMS_EURO20"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "EUMS_EURO20"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EUMS_EURO20_2026_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EUMS_EURO20";
    <http://publications.europa.eu/resource/authority/op-code> "EUMS_EURO20";
