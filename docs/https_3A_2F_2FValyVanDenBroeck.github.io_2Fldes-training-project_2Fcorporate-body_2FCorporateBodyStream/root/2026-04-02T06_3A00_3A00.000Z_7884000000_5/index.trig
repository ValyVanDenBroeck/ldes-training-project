<#b1a6b60c1f574bc682334a95b3a870dd> {
<http://publications.europa.eu/resource/authority/corporate-body/EISMEA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Agenzia esecutiva del Consiglio europeo per l’innovazione e delle PMI"@it, "Izvršna agencija za Europsko vijeće za inovacije i MSP-ove"@hr, "Izvajalska agencija Evropskega sveta za inovacije ter za mala in srednja podjetja"@sl, "Genomförandeorganet för Europeiska innovationsrådet samt för små och medelstora företag"@sv, "Europees Uitvoerend Agentschap Innovatieraad en het mkb"@nl, "Eiropas Inovācijas padomes un MVU izpildaģentūra"@lv, "Európai Innovációs Tanács és Kkv-ügyi Végrehajtó Ügynökség"@hu, "Europos inovacijų tarybos ir MVĮ reikalų vykdomoji įstaiga"@lt, "Forvaltningsorganet for Det Europæiske Innovationsråd og SMV’er"@da, "Agence exécutive pour le Conseil européen de l’innovation et les PME"@fr, "Výkonná agentura Evropské rady pro inovace a pro malé a střední podniky"@cs, "Εκτελεστικός Οργανισμός για το Ευρωπαϊκό Συμβούλιο Καινοτομίας και τις ΜΜΕ"@el, "Euroopa Innovatsiooninõukogu ja VKEde Rakendusamet"@et, "Výkonná agentúra pre Európsku radu pre inováciu a MSP"@sk, "Euroopan innovaationeuvoston ja pk-yritysasioiden toimeenpanovirasto"@fi, "Europäische Exekutivagentur für den Innovationsrat und für KMU"@de, "Agência de Execução do Conselho Europeu de Inovação e das PME"@pt, "Agencia Ejecutiva para el Consejo Europeo de Innovación y las Pymes"@es, "Agencja Wykonawcza Europejskiej Rady ds. Innowacji i ds. MŚP"@pl, "Изпълнителна агенция за Европейския съвет по иновациите и за МСП"@bg, "Gníomhaireacht Feidhmiúcháin na Comhairle Nuálaíochta Eorpaí agus na bhFiontar Beag agus Meánmhéide"@ga, "European Innovation Council and SMEs Executive Agency"@en, "Agenția Executivă pentru Consiliul European pentru Inovare și IMM-uri"@ro, "L-Aġenzija Eżekuttiva Ewropea għall-Kunsill Ewropew tal-Innovazzjoni u għall-SMEs"@mt;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Innovation Council and SMEs Executive Agency is entrusted with the implementation of the following (parts of) Union programmes: Horizon Europe, pillar III: the European Innovation Council (EIC) and European Innovation Ecosystems; Interregional Innovation Investments; Single Market Programme: COSME; Internal market; support to standardisation; and Consumers, as well as with the implementation of the legacy of the following (parts of) Union programmes: Horizon 2020: Part I: Future and emerging technologies FET-Open and FET-Pro-Active; Horizon 2020: Part II: Access to Risk Finance (including EIC inducement Prizes) and Innovation in SMEs; Horizon 2020: Part II and III: Fast Track to Innovation (FTI); Horizon 2020: Part II and III: SME instrument; other EIC related prizes, such as iCapital (H2020 SC 6 WP) and Women Innovators’ Prize (H2020 SWAFs WP); any other activities covered since 2018 under the EIC pilot part of Horizon 2020 WP on Innovative SMEs; COSME and the Competitiveness and Innovation Framework Programme (CIP); Internal Market and support to Standardisation activities; Consumer Programme."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "10.2826"^^<http://publications.europa.eu/ontology/euvoc#DOI_P>, "EA"^^<http://publications.europa.eu/ontology/euvoc#OP_CAT>, "EACI"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>, "EISMEA"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>, "9412"^^<http://publications.europa.eu/ontology/euvoc#ISBN_RG>, "EISMEA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "EISMEA"^^<http://publications.europa.eu/ontology/euvoc#FD_110>, "EISMEA"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001634"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EACI_CRF_232594"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "EISMEA"@fi, "EISMEA"@et, "EISMEA"@el, "EISMEA"@pt, "EISMEA"@hr, "EISMEA"@sk, "EISMEA"@de, "EISMEA"@pl, "EISMEA"@lv, "EISMEA"@sv, "EISMEA"@lt, "EISMEA"@bg, "EISMEA"@sl, "EISMEA"@mt, "EISMEA"@en, "EISMEA"@fr, "EISMEA"@cs, "EISMEA"@ro, "EISMEA"@ga, "EISMEA"@es, "EISMEA"@da, "EISMEA"@it, "EISMEA"@hu, "Eismea"@nl;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EISMEA_2021_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EISMEA";
