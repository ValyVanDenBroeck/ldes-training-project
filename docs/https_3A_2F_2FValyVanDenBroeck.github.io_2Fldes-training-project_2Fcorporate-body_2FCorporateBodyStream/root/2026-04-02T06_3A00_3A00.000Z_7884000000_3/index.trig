<#310b4d7c693cb618e7b013aee77f66f3> {
<http://publications.europa.eu/resource/authority/corporate-body/FRONTEX> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/8439>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Frontex"@cs, "Frontex"@sk, "Frontex"@nl, "Frontex"@lv, "Frontex"@ro, "Frontex"@fi, "Frontex"@hr, "Frontex"@sl, "Frontex"@el, "Frontex"@mt, "Frontex"@it, "Frontex"@pl, "Frontex"@fr, "Frontex"@de, "Frontex"@ga, "Frontex"@sv, "Frontex"@en, "Frontex"@et, "Frontex"@da, "Frontex"@hu, "Frontex"@es, "Frontex"@lt, "Frontex"@bg, "Frontex"@pt;
    <http://www.w3.org/2004/02/skos/core#definition> "Frontex, the European Border and Coast Guard Agency, supports EU and Schengen countries in the management of the EU’s external borders and the fight against cross-border crime. Frontex is a centre of excellence for border control activities at the EU’s external borders, sharing intelligence and expertise with all EU countries, as well as the neighbouring non-EU countries affected by migratory trends and cross-border crime. Frontex supports EU and Schengen countries in all aspects related to border management, from support on the ground and fighting cross-border crime, aerial surveillance and collecting information, to help with return procedures, identifying new technologies and many others. With the standing corps, the European Union’s first uniformed law enforcement service, Frontex has transformed into an operational arm of the EU. Hundreds of officers are taking part in operations at the external borders of the European Union and beyond. Today, Frontex provides security and ensures safe and well-functioning external borders. It is the biggest and fastest growing EU agency."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "TT"^^<http://publications.europa.eu/ontology/euvoc#OP_CAT>, "FRONTEX"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "9411"^^<http://publications.europa.eu/ontology/euvoc#ISBN_RG>, "COB0001355"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "AMOC_1"^^<http://publications.europa.eu/ontology/euvoc#PUB_CORP>, "Frontex"^^<http://publications.europa.eu/ontology/euvoc#WHOISWHO>, "FRONTEX"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Európai Határ- és Partvédelmi Ügynökség"@hu, "Agência Europeia da Guarda de Fronteiras e Costeira"@pt, "L-Aġenzija Ewropea għall-Gwardja tal-Fruntiera u tal-Kosta"@mt, "Europees Grens- en kustwachtagentschap"@nl, "Agencija za europsku graničnu i obalnu stražu"@hr, "Ευρωπαϊκός Οργανισμός Συνοριοφυλακής και Ακτοφυλακής"@el, "Европейска агенция за гранична и брегова охрана"@bg, "Europejska Agencja Straży Granicznej i Przybrzeżnej"@pl, "Evropska agencija za mejno in obalno stražo"@sl, "Europos sienų ir pakrančių apsaugos agentūra"@lt, "Euroopan raja- ja merivartiovirasto"@fi, "Agenzia europea della guardia di frontiera e costiera"@it, "Europeiska gräns- och kustbevakningsbyrån"@sv, "European Border and Coast Guard Agency"@en, "An Ghníomhaireacht Eorpach um an nGarda Teorann agus Cósta"@ga, "Agenția Europeană pentru Poliția de Frontieră și Garda de Coastă"@ro, "Agence européenne de garde-frontières et de garde-côtes"@fr, "Evropská agentura pro pohraniční a pobřežní stráž"@cs, "Eiropas Robežu un krasta apsardzes aģentūra"@lv, "Euroopa Piiri- ja Rannikuvalve Amet"@et, "Agencia Europea de la Guardia de Fronteras y Costas"@es, "Det Europæiske Agentur for Grænse- og Kystbevogtning"@da, "Europäische Agentur für die Grenz- und Küstenwache"@de, "Európska agentúra pre pohraničnú a pobrežnú stráž"@sk;
