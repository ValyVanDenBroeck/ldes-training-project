    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/NEA_1972_0>;
    <http://purl.org/dc/elements/1.1/identifier> "NEA";
    <http://publications.europa.eu/resource/authority/op-code> "NEA";
    <http://publications.europa.eu/ontology/authority/op-code> "NEA";
