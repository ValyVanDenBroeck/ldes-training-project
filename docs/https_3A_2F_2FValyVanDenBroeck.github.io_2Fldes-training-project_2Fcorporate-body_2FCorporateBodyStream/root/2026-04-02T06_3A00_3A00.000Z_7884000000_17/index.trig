}
<../../../index.trig> <https://w3id.org/tree#member> <#805141d31bb5590681be5a761d1506e5>.
<#805141d31bb5590681be5a761d1506e5> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNCSOCD>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.119Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#805141d31bb5590681be5a761d1506e5> {
<http://publications.europa.eu/resource/authority/corporate-body/UNCSOCD> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Coimisiún na Náisiún Aontaithe um Fhorbairt Shóisialta"@ga, "Ühinenud Rahvaste Organisatsiooni sotsiaalarengu komisjon"@et, "Jungtinių Tautų Socialinio vystymosi komisija"@lt, "Commission des Nations unies du développement social"@fr, "Commissione delle Nazioni Unite per lo sviluppo sociale"@it, "Komise OSN pro sociální rozvoj"@cs, "Az ENSZ Szociális Fejlesztési Bizottsága"@hu, "Comisión de Desarrollo Social de las Naciones Unidas"@es, "Commissie Sociale Ontwikkeling van de Verenigde Naties"@nl, "Kommission der Vereinten Nationen für soziale Entwicklung"@de, "De Forenede Nationers Kommission for Social Udvikling"@da, "Komisia OSN pre sociálny rozvoj"@sk, "Επιτροπή των Ηνωμένων Εθνών για την Κοινωνική Ανάπτυξη"@el, "Apvienoto Nāciju Organizācijas Sociālās attīstības komisija"@lv, "Komisija Združenih narodov za socialni razvoj"@sl, "United Nations Commission for Social Development"@en, "Komisija Ujedinjenih naroda za socijalni razvoj"@hr, "YK:n sosiaalisen kehityksen toimikunta"@fi, "Комисия на ООН за социално развитие"@bg, "Comissão das Nações Unidas para o Desenvolvimento Social"@pt, "Kummissjoni tan-Nazzjonijiet Uniti għall-Iżvilupp Soċjali"@mt, "Comisia Națiunilor Unite pentru dezvoltare socială"@ro, "Komisja Rozwoju Społecznego ONZ"@pl, "FN:s kommission för social utveckling"@sv;
    <http://www.w3.org/2004/02/skos/core#definition> "The Commission for Social Development has been in existence from the very inception of the United Nations, advising the Economic and Social Council and Governments on a wide range of social policy issues and on the social perspective of development. It is a functional commission of the Economic and Social Council of the United Nations. Since the convening of the World Summit for Social Development in Copenhagen in 1995, the Commission has been the key UN body in charge of the follow-up and implementation of the Copenhagen Declaration and Programme of Action."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001201"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNCSOCD"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNCSOCD"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Komisia pre sociálny rozvoj"@sk, "Comisión de Desarrollo Social"@es, "Commission for Social Development"@en, "Sociālās attīstības komisija"@lv, "Kummissjoni għall-Iżvilupp Soċjali"@mt, "Komise pro sociální rozvoj"@cs, "Comisia pentru dezvoltare socială"@ro, "Επιτροπή κοινωνικής ανάπτυξης"@el, "Комисия за социално развитие"@bg, "Szociális Fejlesztési Bizottság"@hu, "Commission du développement social"@fr, "Komisja Rozwoju Społecznego"@pl, "Kommissionen for Social Udvikling"@da, "Socialinio vystymosi komisija"@lt, "Commissie Sociale Ontwikkeling"@nl, "Comissão para o Desenvolvimento Social"@pt, "Commissione per lo sviluppo sociale"@it, "CSocD"@nl, "CSocD"@de, "An Coimisiún um Fhorbairt Shóisialta"@ga, "CSocD"@it, "CSocD"@mt, "Kommissionen för social utveckling"@sv, "CSocD"@en, "Kommission für soziale Entwicklung"@de, "Sosiaalisen kehityksen toimikunta"@fi;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCSOCD_1966_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCSOCD";
    <http://publications.europa.eu/resource/authority/op-code> "UNCSOCD";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCSOCD";
    <http://publications.europa.eu/ontology/authority/start.use> "1966-07-29";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCSOCD";
