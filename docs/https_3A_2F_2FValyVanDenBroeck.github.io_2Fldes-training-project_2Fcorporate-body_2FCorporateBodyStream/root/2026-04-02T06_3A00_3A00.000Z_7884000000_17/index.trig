<http://publications.europa.eu/resource/authority/corporate-body/UNREGICOM> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/8386>;
