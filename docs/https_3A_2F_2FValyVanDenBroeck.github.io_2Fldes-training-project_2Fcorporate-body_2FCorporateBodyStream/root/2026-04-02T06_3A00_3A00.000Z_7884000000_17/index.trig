<#d0b3adc3d98af0976b22dc00511efbdc> {
<http://publications.europa.eu/resource/authority/corporate-body/UNCTAD> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
