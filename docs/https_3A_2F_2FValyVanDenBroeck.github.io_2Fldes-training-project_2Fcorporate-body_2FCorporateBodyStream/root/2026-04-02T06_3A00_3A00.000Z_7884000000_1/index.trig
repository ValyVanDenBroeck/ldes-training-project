    <http://www.w3.org/2004/02/skos/core#definition> "The Southern African Customs Union (SACU) is a customs union among five countries of Southern Africa: Botswana, Lesotho, Namibia, South Africa and Swaziland. It is the oldest existing customs union in the world."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001037"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "SACU"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "SACU"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UAAA"@pt, "UAAM"@es, "UDAA"@it, "UDAA"@fr, "SACU"@cs, "SACU"@en, "SACU"@sl, "SACU"@lv, "SACU"@fi, "SACU"@ga, "SACU"@mt, "SACU"@nl, "SACU"@de, "SACU"@pl, "SACU"@sk, "SACU"@da, "SACU"@sv, "SACU"@ro;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/SACU_1910_0>;
