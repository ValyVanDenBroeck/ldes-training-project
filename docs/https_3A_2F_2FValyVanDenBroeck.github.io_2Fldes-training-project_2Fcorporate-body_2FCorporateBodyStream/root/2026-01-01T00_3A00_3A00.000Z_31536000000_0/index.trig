    <http://www.w3.org/2004/02/skos/core#prefLabel> "Централноевропейско споразумение за свободна търговия"@bg, "Centraleuropeiska frihandelsavtalet"@sv, "Srednjeevropski sporazum o prosti trgovini"@sl, "Centrāleiropas Brīvās tirdzniecības nolīgums"@lv, "Comhaontú Saorthrádála Lár na hEorpa"@ga, "Acordo de comércio livre da Europa Central"@pt, "Midden-Europese Vrijhandelsovereenkomst"@nl, "Acordul central european de comerț liber"@ro, "Středoevropská dohoda o volném obchodu"@cs, "Acuerdo Centroeuropeo de Libre Comercio"@es, "Vidurio Europos laisvosios prekybos susitarimas"@lt, "Stredoeurópska dohoda o voľnom obchode"@sk, "Accordo centroeuropeo di libero scambio"@it, "Orta Avrupa Serbest Ticaret Anlaşması"@tr, "Mitteleuropäisches Freihandelsabkommen"@de, "Keski-Euroopan vapaakauppasopimus"@fi, "Ftehim dwar il-Kummerċ Ħieles tal-Ewropa Ċentrali"@mt, "Kesk-Euroopa vabakaubandusleping"@et, "Централноевропски уговор о слободној трговини"@sr, "Central European Free Trade Agreement"@en, "Środkowoeuropejska umowa o wolnym handlu"@pl, "Συμφωνία Ελεύθερων Συναλλαγών της Κεντρικής Ευρώπης"@el, "Közép-európai Szabadkereskedelmi Megállapodás"@hu, "Accord de libre-échange centre-européen"@fr, "Den centraleuropæiske frihandelsaftale"@da, "Srednjoeuropski ugovor o slobodnoj trgovini"@hr;
    <http://www.w3.org/2004/02/skos/core#definition> "Agreement whose main objectives are, inter alia, to expand trade in goods and services and foster investment by means of fair, stable and predictable rules, eliminate barriers to trade between the Parties, provide appropriate protection of intellectual property rights in accordance with international standards and harmonize provisions on modern trade policy issues such as competition rules and state aid."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "CEFTA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001285"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "CEFTA"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Cefta"@nl, "Cefta"@sv, "Cefta"@fi, "ЦЕФТА"@bg, "ACELC"@es, "CEFTA"@et, "VELPS"@lt, "CEFTA"@pl, "CEFTA"@de, "CEFTA"@ga, "CEFTA"@sl, "CEFTA"@hr, "CEFTA"@da, "CEFTA"@mt, "CEFTA"@hu, "CEFTA"@it, "CEFTA"@cs, "CEFTA"@ro, "CEFTA"@en, "CBTN"@lv, "CEFTA"@sk, "ALECE"@fr, "ACLEC"@pt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/CEFTA_1992_0>;
    <http://purl.org/dc/elements/1.1/identifier> "CEFTA";
