# ═══════════════════════════════════════════════════════════
# STEP 12: Consume the LDES
# ═══════════════════════════════════════════════════════════

class LDESConsumer:
    """Simple LDES consumer that processes events."""
    
    def __init__(self, state_file="consumer_state.json"):
        self.state_file = state_file
        self.processed_events = self._load_state()
    
    def _load_state(self):
        if os.path.exists(self.state_file):
            with open(self.state_file, 'r') as f:
                return set(json.load(f).get("processed_events", []))
        return set()
    
    def _save_state(self):
        with open(self.state_file, 'w') as f:
            json.dump({"processed_events": list(self.processed_events)}, f)
    
    def consume_from_file(self, filepath):
        """Consume LDES from a local file."""
        print(f"📥 Reading LDES from: {filepath}")
        
        graph = Graph()
        graph.parse(filepath, format="json-ld")
        
        return self._process_graph(graph)
    
    def consume_from_url(self, url):
        """Consume LDES from a URL."""
        print(f"📥 Fetching LDES from: {url}")
        
        response = requests.get(url, headers={"Accept": "application/ld+json"})
        
        graph = Graph()
        graph.parse(data=response.text, format="json-ld")
        
        return self._process_graph(graph)
    
    def _process_graph(self, graph):
        """Process events from an LDES graph."""
        
        # Find all events (members of the stream)
        events = list(graph.objects(predicate=TREE.member))
        print(f"   Found {len(events)} events")
        
        new_events = 0
        creates = updates = deletes = 0
        
        for event_uri in events:
            event_id = str(event_uri)
            
            # Skip already processed events
            if event_id in self.processed_events:
                continue
            
            new_events += 1
            
            # Get event type
            event_type = graph.value(event_uri, RDF.type)
            
            if event_type == AS.Create:
                creates += 1
                self._handle_create(graph, event_uri)
            elif event_type == AS.Update:
                updates += 1
                self._handle_update(graph, event_uri)
            elif event_type == AS.Delete:
                deletes += 1
                self._handle_delete(graph, event_uri)
            
            # Mark as processed
            self.processed_events.add(event_id)
        
        self._save_state()
        
        print(f"\n📊 Processing complete:")
        print(f"   New events: {new_events}")
        print(f"   ➕ Creates: {creates}")
        print(f"   📝 Updates: {updates}")
        print(f"   🗑️  Deletes: {deletes}")
        
        return {"new": new_events, "creates": creates, "updates": updates, "deletes": deletes}
    
    def _handle_create(self, graph, event_uri):
        """Handle a Create event."""
        subject = graph.value(event_uri, AS.object)
        # In a real consumer, you would add this to your database
        # print(f"   CREATE: {subject}")
    
    def _handle_update(self, graph, event_uri):
        """Handle an Update event."""
        subject = graph.value(event_uri, AS.object)
        # In a real consumer, you would update your database
        # print(f"   UPDATE: {subject}")
    
    def _handle_delete(self, graph, event_uri):
        """Handle a Delete event."""
        subject = graph.value(event_uri, AS.object)
        # In a real consumer, you would remove this from your database
        # print(f"   DELETE: {subject}")

print("✅ LDES Consumer ready!")

