    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/ASPAC>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:06.914Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#3f87ef3abb3e50b39a5402e2810970ba> {
<http://publications.europa.eu/resource/authority/corporate-body/ASPAC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
