    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.157Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1c03799aa0da28976429b2f48899f736> {
<http://publications.europa.eu/resource/authority/corporate-body/UFC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Egység a konszenzusért"@hu, "Uniting for Consensus -ryhmä"@fi, "Zjednoczenie dla konsensusu"@pl, "Kustība Uniting for Consensus"@lv, "Sjednocení pro konsensus"@cs, "Unidos por el Consenso"@es, "Uniting for Consensus"@el, "Uniting for Consensus"@mt, "Ühinemine konsensuse saavutamiseks"@et, "Uniting for Consensus"@de, "Uniting for Consensus"@it, "Uniting for Consensus"@nl, "Uniting for Consensus"@sv, "Uniting for Consensus"@en, "Uniting for Consensus"@ga, "Uniting for Consensus"@da, "Unis pour le consensus"@fr, "„Vieningai už konsensusą“"@lt, "Обединение за консенсус"@bg, "União pelo Consenso"@pt, "Skupina Uniting for Consensus"@hr, "Skupina Uniting for Consensus"@sl, "Skupina Uniting for Consensus"@sk, "Unire pentru consens"@ro;
    <http://www.w3.org/2004/02/skos/core#definition> "Uniting for Consensus (UfC) is a movement, nicknamed the Coffee Club, that developed in opposition to the possible expansion of permanent seats in the United Nations Security Council. Under the leadership of Italy, it aims to counter the bids for permanent seats proposed by G4 nations (Brazil, Germany, India, and Japan) and is calling for a consensus before any decision is reached on the form and size of the Security Council."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UFC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UFC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001082"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UFC"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UFC_2005_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UFC";
    <http://publications.europa.eu/resource/authority/op-code> "UFC";
    <http://publications.europa.eu/ontology/authority/op-code> "UFC";
    <http://publications.europa.eu/ontology/authority/start.use> "2005-07-26";
    <http://publications.europa.eu/ontology/authority/authority-code> "UFC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
