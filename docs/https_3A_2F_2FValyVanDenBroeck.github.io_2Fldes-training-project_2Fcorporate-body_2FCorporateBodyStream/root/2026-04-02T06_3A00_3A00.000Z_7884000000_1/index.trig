    <http://www.w3.org/2004/02/skos/core#altLabel> "IFLA"@en, "IFLA"@fr, "IFLA"@sv, "IFLA"@hu, "IFLA"@sk, "IFLA"@hr, "IFLA"@it, "IFLA"@lt, "IFLA"@fi, "IFLA"@ro, "IFLA"@de, "IFLA"@el, "IFLA"@lv, "IFLA"@sl, "IFLA"@pt, "IFLA"@pl, "IFLA"@mt, "IFLA"@es, "IFLA"@et, "IFLA"@cs, "IFLA"@ga, "IFLA"@nl, "ИФЛА"@bg, "IFLA"@da;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/IFLA_1976_0>;
