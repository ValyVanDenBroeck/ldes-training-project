    <http://www.w3.org/2004/02/skos/core#prefLabel> "CENEL"@fi, "CENEL"@bg, "CENEL"@sv, "CENEL"@es, "CENEL"@ga, "CENEL"@lv, "CENEL"@de, "CENEL"@sl, "CENEL"@ro, "CENEL"@hr, "CENEL"@en, "CENEL"@nl, "CENEL"@da, "CENEL"@cs, "CENEL"@lt, "CENEL"@fr, "CENEL"@et, "CENEL"@hu, "CENEL"@el, "CENEL"@mt, "CENEL"@sk, "CENEL"@it, "CENEL"@pt, "CENEL"@pl;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Committee for the Coordination of Electrotechnical Standards (CENEL) aimed at analysis of IEC electrotechnical standards to determine to what extent they were suitable for implementation in the EEC and EFTA states. Its members were the EEC countries and on behalf of EFTA Austria, Denmark, Norway, Portugal, Sweden, Switzerland and Great Britain. In 1973 CENEL and CENELCOM joined up to form the European Committee for Electrotechnical Standardisation (CENELEC), which counted Austria among its members."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "CENEL"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001295"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "CENEL"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "European Committee for the Coordination of Electrotechnical Standards"@en, "Comité européen de coordination des normes électriques"@fr, "Comité Europeu de Coordenação das Normas Elétricas"@pt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/CENEL_1960_0>;
    <http://purl.org/dc/elements/1.1/identifier> "CENEL";
    <http://publications.europa.eu/resource/authority/op-code> "CENEL";
    <http://publications.europa.eu/ontology/authority/op-code> "CENEL";
