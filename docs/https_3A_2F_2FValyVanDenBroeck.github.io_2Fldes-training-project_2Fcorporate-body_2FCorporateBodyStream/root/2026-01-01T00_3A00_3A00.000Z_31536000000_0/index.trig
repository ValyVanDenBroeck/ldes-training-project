<#feabcf2d74b19104774932ed96b28394> {
<http://publications.europa.eu/resource/authority/corporate-body/CENELEC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/6094>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Европски одбор за електротехничку стандардизацију"@sr, "Euroopan sähkötekniikan standardointikomitea"@fi, "Eiropas Elektrotehnikas standartizācijas komiteja"@lv, "Europos elektrotechnikos standartizacijos komitetas"@lt, "Coiste Eorpach na gCaighdeán Leictriteicniúil"@ga, "Comité Europeu de Normalização Eletrotécnica"@pt, "Europejski Komitet Normalizacyjny Elektrotechniki"@pl, "European Committee for Electrotechnical Standardisation"@en, "Den Europæiske Komité for Elektronisk Standardisering"@da, "Europäisches Komitee für Elektrotechnische Normung"@de, "Ευρωπαϊκή Επιτροπή Ηλεκτροτεχνικής Τυποποίησης"@el, "Comitetul European de Standardizare în Electrotehnică"@ro, "Evropský výbor pro normalizaci v elektrotechnice"@cs, "Európai Elektrotechnikai Szabványügyi Bizottság"@hu, "Comité européen de normalisation électrotechnique"@fr, "Európska Komisia pre elektrotechnickú normalizáciu"@sk, "Euroopa Elektrotehnika Standardikomitee"@et, "Comitato europeo di normalizzazione elettrotecnica"@it, "Europees Comité voor Elektrotechnische Normalisatie"@nl, "Comité Europeo de Normalización Electrotécnica"@es, "Kumitat Ewropew għall-Istandardizzazzjoni tal-Elettroteknika"@mt, "Evropski odbor za standardizacijo v elektrotehniki"@sl, "Europski odbor za elektrotehničku normizaciju"@hr, "Europeiska standardiseringsorganisationen inom elområdet"@sv, "Европейски комитет по стандартизация в електротехниката"@bg;
    <http://www.w3.org/2004/02/skos/core#definition> "The European Committee for Electrotechnical Standardization is responsible for standardization in the electrotechnical engineering field. CENELEC prepares voluntary standards, which help facilitate trade between countries, create new markets, cut compliance costs and support the development of a Single European Market. CENELEC creates market access at European level but also at international level, adopting international standards wherever possible, through its close collaboration with the International Electrotechnical Commission (IEC), under the Dresden Agreement. Designated as a European Standards Organization by the European Commission, CENELEC is a non-profit technical organization set up under Belgian law. It was created as a result of the merger of two previous European organizations: CENELCOM and CENEL."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001293"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "CENELEC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "CENELEC"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "CENELEC"@ro, "CENELEC"@de, "CENELEC"@et, "CENELEC"@cs, "CENELEC"@hr, "CENELEC"@ga, "CENELEC"@pl, "CENELEC"@en, "CENELEC"@lt, "CENELEC"@mt, "CENELEC"@bg, "CENELEC"@fr, "CENELEC"@nl, "Cenelec"@sl, "Cenelec"@es, "Cenelec"@fi, "CENELEC"@sk, "CENELEC"@el, "CENELEC"@it, "CENELEC"@hu, "CENELEC"@lv, "Cenelec"@sv, "CENELEC"@da, "CENELEC"@pt;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/CENELEC_1973_0>;
    <http://purl.org/dc/elements/1.1/identifier> "CENELEC";
    <http://publications.europa.eu/resource/authority/op-code> "CENELEC";
    <http://publications.europa.eu/ontology/authority/op-code> "CENELEC";
    <http://publications.europa.eu/ontology/authority/start.use> "1973-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "CENELEC"
}
