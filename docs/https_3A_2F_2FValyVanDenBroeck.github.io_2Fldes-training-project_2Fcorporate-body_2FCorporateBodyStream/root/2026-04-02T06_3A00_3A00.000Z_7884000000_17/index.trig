<#ed09416bf0d00e9b8e8f91ac27537377> {
<http://publications.europa.eu/resource/authority/corporate-body/IMF> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/1043>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Fond Monetarju Internazzjonali"@mt, "Fondo monetario internazionale"@it, "Nemzetközi Valutaalap"@hu, "Международен валутен фонд"@bg, "Mezinárodní měnový fond"@cs, "An Ciste Airgeadaíochta Idirnáisiúnta"@ga, "Mednarodni denarni sklad"@sl, "Den Internationale Valutafond"@da, "Fondul Monetar Internațional"@ro, "Rahvusvaheline Valuutafond"@et, "Internationaal Muntfonds"@nl, "Fonds monétaire international"@fr, "Fondo Monetario Internacional"@es, "Medzinárodný menový fond"@sk, "Tarptautinis pinigų fondas"@lt, "Διεθνές Νομισματικό Ταμείο"@el, "Międzynarodowy Fundusz Walutowy"@pl, "Kansainvälinen valuuttarahasto"@fi, "Međunarodni monetarni fond"@hr, "Међународни монтарни фонд"@sr, "Starptautiskais Valūtas fonds"@lv, "Internationella valutafonden"@sv, "Internationaler Währungsfonds"@de, "Fundo Monetário Internacional"@pt, "International Monetary Fund"@en;
    <http://www.w3.org/2004/02/skos/core#definition> "Le FMI a été créé lors d’une conférence des Nations Unies à Bretton Woods dans le New Hampshire (États-Unis). Les quarante-quatre pays représentés à la conférence voulaient établir un cadre de coopération économique pour éviter que ne se reproduisent les dévaluations compétitives qui avaient contribué à la grande crise des années 30. Le FMI encourage la stabilité financière et la coopération monétaire internationale, et s’efforce aussi de faciliter le commerce international, d’œuvrer en faveur d’un emploi élevé et d’une croissance économique durable, et de faire reculer la pauvreté dans le monde. Le FMI est gouverné par ses 188 États membres, auxquels il rend compte de son action."@fr, "The IMF, also known as the Fund, was conceived at a UN conference in Bretton Woods, New Hampshire, United States, in July 1944. The 44 countries at that conference sought to build a framework for economic cooperation to avoid a repetition of the competitive devaluations that had contributed to the Great Depression of the 1930s. The IMF’s primary purpose is to ensure the stability of the international monetary system – the system of exchange rates and international payments that enables countries (and their citizens) to transact with each other. The Fund’s mandate was updated in 2012 to include all macroeconomic and financial sector issues that bear on global stability."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "IMF"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "IMF"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001257"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "CAI"@ga, "MFI"@es, "MDS"@sl, "ΔΝΤ"@el, "TVF"@lt, "IMF"@nl, "IMF"@en, "IMF"@da, "IMF"@et, "MFW"@pl, "IWF"@de, "IMF"@hu, "IMF"@fi, "IMF"@sv, "SVF"@lv, "FMI"@it, "FMI"@ro, "МВФ"@bg, "FMI"@mt, "FMI"@pt, "FMI"@fr, "MMF"@cs, "MMF"@sk, "MMF"@hr;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/IMF_1951_0>;
    <http://purl.org/dc/elements/1.1/identifier> "IMF";
    <http://publications.europa.eu/resource/authority/op-code> "IMF";
    <http://publications.europa.eu/ontology/authority/op-code> "IMF";
    <http://publications.europa.eu/ontology/authority/start.use> "1951-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "IMF";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
