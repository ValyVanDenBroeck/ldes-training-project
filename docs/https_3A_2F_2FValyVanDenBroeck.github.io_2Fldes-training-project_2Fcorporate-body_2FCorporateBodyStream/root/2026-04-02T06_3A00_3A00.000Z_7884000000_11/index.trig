    <http://publications.europa.eu/ontology/authority/op-code> "EUROSYSTEM";
    <http://publications.europa.eu/ontology/authority/start.use> "1999-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "EUROSYSTEM";
