    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/EAPC>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:07.074Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#bef49ae6ccee9f3004b35d8d3dc3cd2d> {
<http://publications.europa.eu/resource/authority/corporate-body/EAPC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/5478>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Euro-Atlantische Partnerschapsraad"@nl, "Eiroatlantiskās partnerības padome"@lv, "Euro-atlanttinen kumppanuusneuvosto"@fi, "Συμβούλιο Ευρωατλαντικής Εταιρικής Σχέσης"@el, "Euroatlanti Partnerségi Tanács"@hu, "Euroatlantická partnerská rada"@sk, "Conselho de Parceria Euro-Atlântico"@pt, "Consiglio di partenariato euro-atlantico"@it, "Conseil de partenariat euro-atlantique"@fr, "Euro-Atlantic Partnership Council"@en, "Consejo de Asociación Euroatlántico"@es, "Evroatlantski partnerski svet"@sl, "Euroatlantsko partnersko vijeće"@hr, "Euro-Atlantischer Partnerschaftsrat"@de, "Consiliul Parteneriatului Euro-Atlantic"@ro, "Съвет за евроатлантическо партньорство"@bg, "Kunsill tas-Sħubija Ewro-Atlantika"@mt, "Euroatlantická rada partnerství"@cs, "Euroatlantinės partnerystės Taryba"@lt, "Euroatlantiska partnerskapsrådet"@sv, "Det Euro-Atlantiske Partnerskabsråd"@da, "Comhairle Comhpháirtíochta Eora-Atlantach"@ga, "Rada Partnerstwa Euroatlantyckiego"@pl, "Avrupa-Atlantik Ortaklık Konseyi"@tr, "Euro-Atlandi Partnerlusnõukogu"@et;
    <http://www.w3.org/2004/02/skos/core#definition> "The Euro-Atlantic Partnership Council (EAPC), a post-Cold War NATO institution, is a multilateral forum created to improve relations between NATO and non-NATO countries in Europe and those parts of Asia on the European periphery. States meet to cooperate and go to the range of political and security issues."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EAPC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001001"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EAPC"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "EAPC"@ga, "EAPC"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EAPC_1997_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EAPC";
    <http://publications.europa.eu/resource/authority/op-code> "EAPC";
    <http://publications.europa.eu/ontology/authority/op-code> "EAPC";
    <http://publications.europa.eu/ontology/authority/start.use> "1997-05-29";
    <http://publications.europa.eu/ontology/authority/authority-code> "EAPC"
}
<../../../index.trig> <https://w3id.org/tree#member> <#44780f6d7d0828245190430ec3e77b62>.
<#44780f6d7d0828245190430ec3e77b62> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/PACIFIC_AL>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:07.079Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#44780f6d7d0828245190430ec3e77b62> {
<http://publications.europa.eu/resource/authority/corporate-body/PACIFIC_AL> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/c_5bad9438>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Alleanza tal-Paċifiku"@mt, "Stillahavsalliansen"@sv, "Csendes-óceáni Szövetség"@hu, "Alianța Pacificului"@ro, "Pacific Alliance"@en, "Ramiojo vandenyno aljansas"@lt, "Tyynenmeren allianssi"@fi, "Тихоокеански алианс"@bg, "Tichomořská aliance"@cs, "Stillehavsalliancen"@da, "Pacifiška zveza"@sl, "Pasifik İttifakı"@tr, "Alianza del Pacífico"@es, "Vaikse ookeani liit"@et, "Pacifički savez"@hr, "Tichomorská aliancia"@sk, "Pacifische Alliantie"@nl, "Sojusz Pacyfiku"@pl, "Pazifische Allianz"@de, "Alleanza del Pacifico"@it, "Alliance du Pacifique"@fr, "Συμμαχία του Ειρηνικού"@el, "Klusā okeāna valstu alianse"@lv, "Comhghuaillíocht an Aigéin Chiúin"@ga, "Aliança do Pacífico"@pt;
    <http://www.w3.org/2004/02/skos/core#definition> "The Pacific Alliance is a regional integration organisation comprised by Chile, Colombia, Mexico and Peru. Its objectives are: build in a participatory and consensual way an area of deep integration to move progressively towards the free movement of goods, services, resources and people; drive further growth, development and competitiveness of the economies of its members, focused on achieving greater well-being, overcoming socioeconomic inequality and promote the social inclusion of its inhabitants; become a platform of political articulation, economic and commercial integration and projection to the world, with emphasis on the Asia-Pacific region."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "PACIFIC_AL"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "PACIFIC_AL"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001549"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/PACIFIC_AL_2011_0>;
    <http://purl.org/dc/elements/1.1/identifier> "PACIFIC_AL";
    <http://publications.europa.eu/resource/authority/op-code> "PACIFIC_AL";
    <http://publications.europa.eu/ontology/authority/op-code> "PACIFIC_AL";
    <http://publications.europa.eu/ontology/authority/start.use> "2011-04-28";
    <http://publications.europa.eu/ontology/authority/authority-code> "PACIFIC_AL"
}
<../../../index.trig> <https://w3id.org/tree#member> <#37f6f639398cdd8dabcc3b01ca54ffda>.
<#37f6f639398cdd8dabcc3b01ca54ffda> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/ANZUS>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:07.085Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#37f6f639398cdd8dabcc3b01ca54ffda> {
<http://publications.europa.eu/resource/authority/corporate-body/ANZUS> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/2070>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "ANZUS-Abkommen"@de, "Pakt Bezpieczeństwa Pacyfiku"@pl, "ANZUS sutartis"@lt, "Pacte de l’ANZUS"@fr, "ANZUS-verdrag"@nl, "Trattato ANZUS"@it, "ANZUS-paktum"@hu, "Tratatul ANZUS"@ro, "Pakt ANZUS"@cs, "Sporazum ANZUS"@hr, "Sporazum ANZUS"@sl, "ANZUS Treaty"@en, "Договор ANZUS"@bg, "Stillehavspagten"@da, "Tratado ANZUS"@es, "Tratado ANZUS"@pt, "ANZUS Rahvusvaheline Leping"@et, "It-Trattat ta’ ANZUS"@mt, "Σύμφωνο ANZUS"@el, "ANZUS Paktı"@tr, "ANZUS līgums"@lv, "Stillahavspakten"@sv, "Tichomorský bezpečnostný pakt"@sk, "Conradh ANZUS"@ga, "ANZUS-sopimus"@fi;
    <http://www.w3.org/2004/02/skos/core#definition> "The ANZUS Treaty is the 1951 Collective security agreement which binds Australia and New Zealand and, separately, Australia and the United States, to co-operate on military matters in the Pacific Ocean region, although today the treaty is taken to relate to conflicts worldwide."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0000993"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ANZUS"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "ANZUS"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ANZUS"@de, "ANZUS"@el, "ANZUS"@es, "ANZUS"@lt, "ANZUS"@et, "ANZUS"@da, "ANZUS"@en, "ANZUS"@lv, "ANZUS"@sl, "ANZUS"@fr, "ANZUS"@sv, "ANZUS"@pl, "ANZUS"@fi, "ANZUS"@hu, "ANZUS"@ga, "ANZUS"@nl, "ANZUS"@pt, "ANZUS"@cs, "ANZUS"@it, "Anzus"@hr, "Anzus"@sk, "Anzus"@ro, "Australia, New Zealand, United States Security Treaty"@en, "Anzus"@mt, "АНЗЮС"@bg;
