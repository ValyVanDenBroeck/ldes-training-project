    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Mercosur"@lv, "Mercosur"@it, "Mercosur"@sk, "Mercosur"@de, "Mercosur"@cs, "Mercosur"@sv, "Mercosur"@da, "Mercosur"@ga, "Mercosur"@ro, "Mercosur"@en, "Mercosur"@et, "Mercosur"@fr, "Mercosur"@es, "Mercosur"@el, "Mercosur"@fi, "Mercosur"@hr, "Mercosur"@pl, "Mercosur"@nl, "Mercosur"@hu, "Mercosur"@mt, "Mercosur"@lt, "Mercosur"@pt, "Mercosur"@sl, "Меркосур"@bg;
    <http://www.w3.org/2004/02/skos/core#definition> "Mercosur or Mercosul is an economic and political agreement among Argentina, Brazil, Paraguay, Uruguay and Venezuela with Bolivia becoming an acceding member on 7 December 2012 to be ratified by member states legislatures."@en, "Le Marché commun du Sud, Mercosur ou Mercosul est une communauté économique qui est composé de l’Argentine, du Brésil, du Paraguay actuellement suspendu, de l’Uruguay, du Venezuela. La Bolivie a signé son adhésion le 7 décembre 2012 mais il manque les ratifications des pays membres."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0000758"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "MERCOSUR"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "MERCOSUR"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "MERCOSUR"^^<http://publications.europa.eu/ontology/euvoc#FD_050>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/MERCOSUR_1991_0>;
    <http://purl.org/dc/elements/1.1/identifier> "MERCOSUR";
    <http://publications.europa.eu/resource/authority/op-code> "MERCOSUR";
    <http://publications.europa.eu/ontology/authority/op-code> "MERCOSUR";
    <http://publications.europa.eu/ontology/authority/start.use> "1991-03-26";
    <http://publications.europa.eu/ontology/authority/authority-code> "MERCOSUR";
