    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:18.374Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9e683d29e23c8b729c9589611a9b9f5f> {
<http://publications.europa.eu/resource/authority/corporate-body/ICSID> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/8378>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Międzynarodowe Centrum Rozwiązywania Sporów Inwestycyjnych"@pl, "International Centre for Settlement of Investment Disputes"@en, "Det Internationale Center til Bilæggelse af Investeringstvister"@da, "Centro Internacional para a Resolução de Diferendos relativos a Investimentos"@pt, "Centro Internacional de Arreglo de Diferencias relativas a Inversiones"@es, "Mezinárodní středisko pro řešení investičních sporů"@cs, "Centre international pour le règlement des différends relatifs aux investissements"@fr, "Starptautiskais Investīciju strīdu izšķiršanas centrs"@lv, "Internationales Zentrum zur Beilegung von Investitionsstreitigkeiten"@de, "An Lárionad Idirnáisiúnta chun Díospóidí Infheistíochtaí a Shocrú"@ga, "Međunarodni centar za rješavanje ulagačkih sporova"@hr, "Befektetési Viták Rendezésének Nemzetközi Központja"@hu, "Centrul Internațional pentru Reglementarea Diferendelor privind Investițiile"@ro, "Medzinárodné centrum pre riešenie investičných sporov"@sk, "Centro internazionale per la risoluzione delle controversie relative agli investimenti"@it, "Међународни центар за решавање инвестиционих спорова"@sr, "Tarptautinis investicinių ginčų sprendimo centras"@lt, "Rahvusvaheline Investeeringuvaidluste Lahendamise Keskus"@et, "Ċentru Internazzjonali għas-Soluzzjoni ta’ Tilwim dwar Investiment"@mt, "Internationaal Centrum voor beslechting van investeringsgeschillen"@nl, "Mednarodni center za reševanje sporov glede naložb"@sl, "Διεθνές Κέντρο για το Διακανονισμό των Διαφορών εξ Επενδύσεων"@el, "Международен център за регулиране на инвестиционите спорове"@bg, "Sijoituksia koskevien riitaisuuksien kansainvälinen ratkaisukeskus"@fi, "Internationella centret för lösning av investeringstvister"@sv;
    <http://www.w3.org/2004/02/skos/core#definition> "ICSID is the world’s leading institution devoted to international investment dispute settlement. ICSID was established in 1966 by the Convention on the Settlement of Investment Disputes between States and Nationals of Other States (the ICSID Convention). The ICSID Convention is a multilateral treaty formulated by the Executive Directors of the World Bank to further the Bank’s objective of promoting international investment. ICSID is an independent, depoliticized and effective dispute-settlement institution. Its availability to investors and States helps to promote international investment by providing confidence in the dispute resolution process."@en, "Le Centre international pour le règlement des différends relatifs aux investissements offre des mécanismes internationaux de conciliation et d’arbitrage des différends liés aux investissements."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "ICSID"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "ICSID"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001266"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ICSID"@ro, "ICSID"@ga, "ICSID"@mt, "ICSID"@fi, "ICSID"@lt, "ICSID"@lv, "ICSID"@it, "CIRDI"@fr, "ICSID"@sk, "ICSID"@hu, "CIRDI"@pt, "ICSID"@et, "ICSID"@sl, "ICSID"@pl, "ICSID"@sv, "ICSID"@hr, "ICSID"@el, "ICSID"@de, "ICSID"@cs, "ICSID"@en, "ICSID"@da, "CIADI"@es, "Icsid"@nl;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ICSID_1966_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ICSID";
    <http://publications.europa.eu/resource/authority/op-code> "ICSID";
    <http://publications.europa.eu/ontology/authority/op-code> "ICSID";
    <http://publications.europa.eu/ontology/authority/start.use> "1966-09-14";
    <http://publications.europa.eu/ontology/authority/authority-code> "ICSID";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/WB>
}
<../../../index.trig> <https://w3id.org/tree#member> <#e6abfeb93267ff2fcc5fe63300065ffb>.
<#e6abfeb93267ff2fcc5fe63300065ffb> a <https://www.w3.org/ns/activitystreams#Create>;
