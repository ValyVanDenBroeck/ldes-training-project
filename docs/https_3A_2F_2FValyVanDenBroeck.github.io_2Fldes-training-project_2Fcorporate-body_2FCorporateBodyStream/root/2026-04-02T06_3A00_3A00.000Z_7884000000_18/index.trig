    <http://publications.europa.eu/ontology/authority/op-code> "IILAC";
    <http://publications.europa.eu/ontology/authority/start.use> "1997-04-24";
    <http://publications.europa.eu/ontology/authority/authority-code> "IILAC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/IDB>
}
