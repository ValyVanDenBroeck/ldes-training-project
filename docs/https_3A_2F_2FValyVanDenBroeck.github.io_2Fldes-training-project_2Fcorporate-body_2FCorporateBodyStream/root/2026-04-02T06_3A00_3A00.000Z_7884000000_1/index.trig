<#2ef66750a98cc3fdb4a05cb91c7f4a7b> {
<http://publications.europa.eu/resource/authority/corporate-body/CEN> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/6093>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#topConceptOf> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Euroopa Standardikomitee"@et, "Comitato europeo di normalizzazione"@it, "Европейски комитет по стандартизация"@bg, "Den Europæiske Standardiseringsorganisation"@da, "Európsky výbor pre normalizáciu"@sk, "Evropský výbor pro normalizaci"@cs, "Comité européen de normalisation"@fr, "European Committee for Standardization"@en, "Europejski Komitet Normalizacyjny"@pl, "Europäisches Komitee für Normung"@de, "Európai Szabványügyi Bizottság"@hu, "Europski odbor za normizaciju"@hr, "Comité Europeo de Normalización"@es, "Comitetul European de Standardizare"@ro, "Eiropas Standartizācijas komiteja"@lv, "Euroopan standardointikomitea"@fi, "Comité Europeu de Normalização"@pt, "Europeiska standardiseringsorganisationen"@sv, "Kumitat Ewropew għall-istandardizzazzjoni"@mt, "Europees Comité voor Normalisatie"@nl, "Европски одбор за стандардизацију"@sr, "Europos standartizacijos komitetas"@lt, "An Coiste Eorpach um Chaighdeánú"@ga, "Ευρωπαϊκή Επιτροπή Τυποποίησης"@el, "Evropski odbor za standardizacijo"@sl;
    <http://www.w3.org/2004/02/skos/core#definition> "CEN is an association that brings together the National Standardization Bodies of 33 European countries. CEN is one of three European Standardization Organizations (together with CENELEC and ETSI) that have been officially recognized by the European Union and by the European Free Trade Association as being responsible for developing and defining voluntary standards at European level. CEN provides a platform for the development of European Standards and other technical documents in relation to various kinds of products, materials, services and processes. CEN supports standardization activities in relation to a wide range of fields and sectors."@en, "Organisme créé par les instituts de normalisation des États membres de la CEE et de l’AELE, afin d’harmoniser les normes européennes. Domaines principaux d’activité: les normes techniques, le libre commerce, la sécurité des travailleurs et des consommateurs, l’interopérabilité des réseaux, la protection de l’environnement. Il est complété dans son action par le Comité européen de normalisation électrotechnique (CENELEC). Tous ses membres sont également membres de l’Organisation internationale de normalisation (ISO)."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "CEN"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001292"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "CEN"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "CEN"@sk, "CEN"@el, "CEN"@de, "CEN"@da, "CEN"@pl, "CEN"@es, "CEN"@pt, "CEN"@lt, "CEN"@et, "CEN"@fr, "CEN"@hu, "CEN"@en, "CEN"@it, "CEN"@sl, "CEN"@sv, "CEN"@cs, "CEN"@ga, "CEN"@bg, "CEN"@mt, "CEN"@lv, "CEN"@nl, "CEN"@hr, "CEN"@fi, "CEN"@ro;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/CEN_1961_0>;
    <http://purl.org/dc/elements/1.1/identifier> "CEN";
    <http://publications.europa.eu/resource/authority/op-code> "CEN";
    <http://publications.europa.eu/ontology/authority/op-code> "CEN";
    <http://publications.europa.eu/ontology/authority/start.use> "1961-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "CEN"
}
