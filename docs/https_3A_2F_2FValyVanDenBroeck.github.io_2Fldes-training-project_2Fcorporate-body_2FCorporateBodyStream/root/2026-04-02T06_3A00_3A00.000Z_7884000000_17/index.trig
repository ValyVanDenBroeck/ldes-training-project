<#42900ebd5cd68de0976532fbc4a4efb4> {
<http://publications.europa.eu/resource/authority/corporate-body/UNAIDS> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/8393>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "UNAIDS"@sl, "UNAIDS"@en, "UNAIDS"@hr, "UNAIDS"@mt, "UNAIDS"@lv, "UNAIDS"@lt, "UNAIDS"@ga, "UNAIDS"@da, "UNAIDS"@nl, "UNAIDS"@cs, "UNAIDS"@fi, "UNAIDS"@sk, "UNAIDS"@hu, "UNAIDS"@ro, "UNAIDS"@pl, "UNAIDS"@el, "Unaids"@sv, "Unaids"@it, "УНСИДА"@sr, "UNAids"@de, "ЮНЕЙДС"@bg, "ÜRO HIV- ja AIDSi-vastane ühisprogramm"@et, "Onusida"@fr, "Onusida"@es, "ONUSIDA"@pt;
    <http://www.w3.org/2004/02/skos/core#definition> "Originally drew together six organizations: UNICEF, the United Nations Development Programme, the United Nations Population Fund, UNESCO, the World Health Organization, and the World Bank. The original six organizations were joined in April 1999 by the United Nations International Drug Control Programme. In May 2010 there were 10 organizations involved: the previous seven plus the ILO, UNHCR and WFP. UN-Women has become the 11th co-sponsor of UNAIDS, as per UN-Women strategic plan for 2014-2017. The goal of UNAIDS is to catalyse, strengthen and orchestrate the unique expertise, resources, and networks of influence that each of these organizations offers."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNAIDS"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "ONUSIDA"^^<http://publications.europa.eu/ontology/euvoc#FD_050>, "UNAIDS"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001250"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Programul Comun al Națiunilor Unite pentru HIV/SIDA"@ro, "Apvienoto Nāciju Organizācijas Kopējā HIV/AIDS apkarošanas programma"@lv, "Обща програма на ООН срещу ХИВ/СПИН"@bg, "Programme commun des Nations Unies sur le VIH/sida"@fr, "Programa das Nações Unidas para a sida"@pt, "Zajednički program Ujedinjenih naroda za HIV/AIDS"@hr, "Programa Conjunto de las Naciones Unidas sobre el VIH/SIDA"@es, "Společný program OSN pro HIV/AIDS"@cs, "Joint United Nations Programme on HIV/AIDS"@en, "Programul Națiunilor Unite pentru HIV/SIDA"@ro, "FN’s fælles program for bekæmpelse af hiv/aids"@da, "Sojusz Agend Narodów Zjednoczonych ds. HIV/AIDS"@pl, "Gemeinsames Programm der Vereinten Nationen für HIV/Aids"@de, "Programa conjunto das Nações Unidas sobre VIH/SIDA"@pt, "Jungtinių Tautų bendra kovos su ŽIV/AIDS programa"@lt, "Programm tan-NU dwar l-HIV/AIDS"@mt, "Gemeinsames UN-Programm zu HlV/Aids"@de, "Programma congiunto delle Nazioni Unite sull’HIV/AIDS"@it, "Spoločný program OSN pre HIV/AIDS"@sk, "Az Egyesült Nemzetek HIV/AIDS-programja"@hu, "Yhdistyneiden Kansakuntien yhteinen HIV:n ja aidsin vastainen ohjelma"@fi, "Programme commun ONUSIDA"@fr, "Programm Konġunt tan-Nazzjonijiet Uniti dwar l-HIV/AIDS"@mt, "Skupni program Združenih narodov za boj proti aidsu"@sl, "Κοινό πρόγραμμα των Ηνωμένων ΕΘνών για τον ιό HIV και το AIDS"@el, "United Nations Programme on HIV/AIDS"@en, "Clár Comhpháirteach na Náisiún Aontaithe maidir le VEID/SEIF"@ga, "VN-aids-programma"@nl, "Gezamenlijk Programma van de Verenigde Naties inzake hiv/aids"@nl;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNAIDS_1996_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNAIDS";
    <http://publications.europa.eu/resource/authority/op-code> "UNAIDS";
    <http://publications.europa.eu/ontology/authority/op-code> "UNAIDS";
    <http://publications.europa.eu/ontology/authority/start.use> "1996-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNAIDS";
    <http://publications.europa.eu/ontology/authority/op-mapped-code> _:b5143_b5142_b5141_df_15_1430;
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>.
_:b5143_b5142_b5141_df_15_1430 a <http://publications.europa.eu/ontology/authority/MappedCode>;
    <http://purl.org/dc/elements/1.1/source> "EurLex";
    <http://publications.europa.eu/ontology/authority/affected-table> "FD_050";
    <http://publications.europa.eu/ontology/authority/legacy-code> "ONUSIDA"
}
<../../../index.trig> <https://w3id.org/tree#member> <#e678999d78567847d6d2a7b68f2ce336>.
<#e678999d78567847d6d2a7b68f2ce336> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/ITU>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.805Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#e678999d78567847d6d2a7b68f2ce336> {
<http://publications.europa.eu/resource/authority/corporate-body/ITU> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/4591>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Union internationale des télécommunications"@fr, "Unione internazionale per le telecomunicazioni"@it, "Unjoni Internazzjonali tat-Telekomunikazzjoni"@mt, "Medzinárodná telekomunikačná únia"@sk, "Unión Internacional de Telecomunicaciones"@es, "Mezinárodní telekomunikační unie"@cs, "Rahvusvaheline Telekommunikatsiooni Liit"@et, "Međunarodna telekomunikacijska unija"@hr, "Mednarodna zveza za telekomunikacije"@sl, "Internationale Telecommunicatie-unie"@nl, "Internationella teleunionen"@sv, "União Internacional de Telecomunicações"@pt, "Tarptautinė telekomunikacijų sąjunga"@lt, "Nemzetközi Távközlési Egyesület"@hu, "International Telecommunication Union"@en, "Den Internationale Telekommunikationsunion"@da, "Διεθνής Ένωση Τηλεπικοινωνιών"@el, "Uniunea Internațională a Telecomunicațiilor"@ro, "Starptautiskā Telekomunikāciju savienība"@lv, "Internationale Fernmelde-Union"@de, "Kansainvälinen televiestintäliitto"@fi, "Международно обединение за телекомуникации"@bg, "An tAοntas Teileachumarsáide Idirnáisiúnta"@ga, "Међународна унија за телекомуникације"@sr, "Międzynarodowy Związek Telekomunikacyjny"@pl;
    <http://www.w3.org/2004/02/skos/core#definition> "L’UIT est l’institution spécialisée des Nations Unies pour les technologies de l’information et de la communication (TIC). L’UIT a été fondée à Paris en 1865 sous le nom d’Union télégraphique internationale. Elle porte son nom actuel depuis 1934. En 1947, elle est devenue l’une des institutions spécialisées des Nations Unies. L’UIT attribue dans le monde entier des fréquences radioélectriques et des orbites de satellite, élabore les normes techniques qui assurent l’interconnexion harmonieuse des réseaux et des technologies et s’efforce d’améliorer l’accès aux TIC pour les communautés mal desservies."@fr, "Founded in Paris, France, in 1865 as the International Telegraph Union, the ITU took its present name in 1934 and became a specialized agency of the United Nations in 1947. It was one of the first international organizations established to cooperate on a specific matter. It is an international organization within which Governments and the private sector coordinate global telecom networks and services."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ITU"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001259"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ITU"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "ITU"@pl, "ITU"@fi, "ITU"@hr, "ITU"@lv, "ITU"@cs, "UIT"@it, "UIT"@fr, "UIT"@mt, "UIT"@pt, "UIT"@ro, "МСД"@bg, "ΔΕΤ"@el, "UIT"@es, "ITU"@da, "ITU"@hu, "ITU"@en, "ITU"@nl, "ITU"@lt, "ITU"@de, "ITU"@sv, "ITU"@sk, "ITU"@sl;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ITU_1951_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ITU";
    <http://publications.europa.eu/resource/authority/op-code> "ITU";
    <http://publications.europa.eu/ontology/authority/op-code> "ITU";
    <http://publications.europa.eu/ontology/authority/start.use> "1951-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "ITU";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
<../../../index.trig> <https://w3id.org/tree#member> <#c51271ee3ac2159144e3d1cb3d91e31a>.
<#c51271ee3ac2159144e3d1cb3d91e31a> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/UNIDO>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.811Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c51271ee3ac2159144e3d1cb3d91e31a> {
<http://publications.europa.eu/resource/authority/corporate-body/UNIDO> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/2145>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Apvienoto Nāciju Organizācijas Industriālās attīstības organizācija"@lv, "Organizacija Združenih narodov za industrijski razvoj"@sl, "Organizacija UN-a za industrijski razvoj"@hr, "Organización de las Naciones Unidas para el Desarrollo Industrial"@es, "FN:s organisation för industriell utveckling"@sv, "Yhdistyneiden kansakuntien teollisen kehityksen järjestö"@fi, "Organizației Națiunilor Unite pentru Dezvoltare Industrială"@ro, "ÜRO Tööstusarengu Organisatsioon"@et, "Organizace OSN pro průmyslový rozvoj"@cs, "Organizzazione delle Nazioni Unite per lo sviluppo industriale"@it, "Organizácia OSN pre priemyselný rozvoj"@sk, "Organizacja Narodów Zjednoczonych ds. Rozwoju Przemysłowego"@pl, "Eagraíocht Forbartha Tionscail na Náisiún Aontaithe"@ga, "Organisation des Nations unies pour le développement industriel"@fr, "Organisatie van de Verenigde Naties voor industriële ontwikkeling"@nl, "Az ENSZ Iparfejlesztési Szervezete"@hu, "United Nations Industrial Development Organization"@en, "Οργανισμός Βιομηχανικής Ανάπτυξης των Ηνωμένων Εθνών"@el, "Organização das Nações Unidas para o Desenvolvimento Industrial"@pt, "Organizzazzjoni Industrijali tan-Nazzjonijiet Uniti"@mt, "Организација Уједињених нација за индустријски развој"@sr, "Jungtinių Tautų pramonės plėtros organizacija"@lt, "De Forenede Nationers Organisation for Industriel Udvikling"@da, "Организация на ООН за промишлено развитие"@bg, "Organisation der Vereinten Nationen für industrielle Entwicklung"@de;
    <http://www.w3.org/2004/02/skos/core#definition> "United Nations Industrial Development Organization (UNIDO) is the specialized agency of the United Nations that promotes industrial development for poverty reduction, inclusive globalization and environmental sustainability. Its mandate, as described in the Lima Declaration adopted at the fifteenth session of the UNIDO General Conference in 2013, is to promote and accelerate inclusive and sustainable industrial development (ISID) in developing countries and economies in transition. Accordingly, the Organization’s programmatic focus is structured in three thematic priorities, each of which represents different aspects of ISID: Creating shared prosperity; Advancing economic competitiveness; Safeguarding the environment."@en, "L’ONUDI est l’institution spécialisée des Nations Unies chargée de promouvoir le développement industriel pour la réduction de la pauvreté, la mondialisation inclusive et la sauvegarde d’un environnement durable. Le mandat de l’ONUDI est de promouvoir et d’accélérer le développement industriel durable des pays en voie de développement et des économies en transition. L’Organisation a centré ses activités autour de trois domaines thématiques: Réduction de la pauvreté grâce à des activités productives ; Renforcement des capacités commerciales ; Environnement et énergie."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001263"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNIDO"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNIDO"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "UNIDO"@et, "UNIDO"@pl, "UNIDO"@hu, "UNIDO"@bg, "UNIDO"@da, "UNIDO"@lv, "UNIDO"@it, "UNIDO"@pt, "UNIDO"@fi, "UNIDO"@de, "UNIDO"@sl, "UNIDO"@ga, "UNIDO"@hr, "UNIDO"@nl, "UNIDO"@en, "UNIDO"@sv, "UNIDO"@sk, "UNIDO"@el, "UNIDO"@lt, "UNIDO"@fr, "UNIDO"@ro, "UNIDO"@es, "UNIDO"@mt, "UNIDO"@cs;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNIDO_1966_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNIDO";
    <http://publications.europa.eu/resource/authority/op-code> "UNIDO";
    <http://publications.europa.eu/ontology/authority/op-code> "UNIDO";
    <http://publications.europa.eu/ontology/authority/start.use> "1966-11-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNIDO";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
<../../../index.trig> <https://w3id.org/tree#member> <#963d825c15246277c20870c87dcaa78e>.
<#963d825c15246277c20870c87dcaa78e> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://publications.europa.eu/resource/authority/corporate-body/ILOFF>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.817Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#963d825c15246277c20870c87dcaa78e> {
<http://publications.europa.eu/resource/authority/corporate-body/ILOFF> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://eurovoc.europa.eu/3708>;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Ufficio internazionale del lavoro"@it, "Διεθνές Γραφείο Εργασίας"@el, "Internationaal Arbeidsbureau"@nl, "Międzynarodowe Biuro Pracy"@pl, "Internationales Arbeitsamt"@de, "Medzinárodný úrad práce"@sk, "Международно бюро на труда"@bg, "Međunarodni ured rada"@hr, "International Labour Office"@en, "Међународни биро рада"@sr, "Rahvusvaheline Tööbüroo"@et, "Mednarodni urad dela"@sl, "An Oifig Idirnáisiúnta Saothair"@ga, "Repartição Internacional do Trabalho"@pt, "Mezinárodní úřad práce"@cs, "Oficina Internacional del Trabajo"@es, "Internationella arbetsbyrån"@sv, "Uffiċċju Internazzjonali tax-Xogħol"@mt, "Kansainvälinen työtoimisto"@fi, "Nemzetközi Munkaügyi Hivatal"@hu, "Bureau international du travail"@fr, "Det Internationale Arbejdsbureau"@da, "Tarptautinis darbo biuras"@lt, "Biroul Internațional al Muncii"@ro, "Starptautiskais Darba birojs"@lv;
    <http://www.w3.org/2004/02/skos/core#definition> "En 1919, l’Organisation internationale du Travail est fondée dans le cadre du Traité de Versailles qui met fin à la Première Guerre mondiale pour incarner l’idée qu’il ne saurait y avoir de paix universelle et durable sans justice sociale. L’OIT est l’agence des Nations Unies pour le monde du travail. Elle établit les normes internationales du travail, promeut les droits au travail et favorise la création d’emplois décents, l’amélioration de la protection sociale et le renforcement du dialogue sur les questions liées au travail. L’OIT est dotée d’une structure unique qui rassemble des représentants des gouvernements, des employeurs et des travailleurs."@fr, "In 1919, the International Labour Organization is founded as part of the Treaty of Versailles that ended World War I, to reflect the belief that universal and lasting peace cannot be achieved without social justice. The International Labour Organization is the United Nations agency for the world of work. It sets international labour standards, promotes rights at work, and encourages decent employment opportunities, the enhancement of social protection and the strengthening of dialogue on work-related issues. The ILO has a unique structure, bringing together governments, employers’ and workers’ representatives."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ILOFF"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001254"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "ILOFF"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "IAB"@nl, "BIT"@fr, "OIT"@es, "ΔΓΕ"@el, "MÚP"@cs, "ILO"@lt, "ILO"@et, "ILO"@da, "ILO"@sv, "ILO"@it, "IAA"@de, "ILO"@mt, "ILO"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ILOFF_1951_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ILOFF";
    <http://publications.europa.eu/resource/authority/op-code> "ILOFF";
    <http://publications.europa.eu/ontology/authority/op-code> "ILOFF";
    <http://publications.europa.eu/ontology/authority/start.use> "1951-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "ILOFF";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
