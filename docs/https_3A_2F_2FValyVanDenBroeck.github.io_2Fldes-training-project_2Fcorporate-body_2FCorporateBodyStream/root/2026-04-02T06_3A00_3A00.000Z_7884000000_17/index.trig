<http://publications.europa.eu/resource/authority/corporate-body/UNECWA> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Apvienoto Nāciju Organizācijas Ekonomikas komisija Rietumāzijai"@lv, "Kummissjoni Ekonomika tan-Nazzjonijiet Uniti għall-Ażja tal-Punent"@mt, "Ühinenud Rahvaste Organisatsiooni Lääne-Aasia majanduskomisjon"@et, "United Nations Economic Commission for Western Asia"@en, "Commission économique des Nations unies pour l’Asie occidentale"@fr, "Comisión Económica para Asia Occidental de las Naciones Unidas"@es, "Икономическа комисия на ООН за Западна Азия"@bg, "Comissão Económica das Nações Unidas para a Ásia Ocidental"@pt, "YK:n Länsi-Aasian talouskomissio"@fi;
    <http://www.w3.org/2004/02/skos/core#definition> "The Economic Commission for Western Asia (ECWA) was established pursuant to the Economic and Social Council’s resolution 1818 (LV). The purpose of setting up the Commission was to raise the level of economic activity in member countries and strengthen cooperation among them. It was also intended to meet the need of the countries in Western Asia for the services of a regional economic commission to promote the development efforts in the region. In recognition of the social component of its work, the Commission was entrusted with new responsibilities in the social field by virtue of Economic and Social Council resolution 69/1985 of July 1985. Its name therefore became the Economic and Social Commission for Western Asia."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COB0001199"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNECWA"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "UNECWA"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Economic Commission for Western Asia"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNECWA_1973_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNECWA";
    <http://publications.europa.eu/resource/authority/op-code> "UNECWA";
    <http://publications.europa.eu/ontology/authority/op-code> "UNECWA";
    <http://publications.europa.eu/ontology/authority/start.use> "1973-08-09";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNECWA";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1985-06-30"
}
