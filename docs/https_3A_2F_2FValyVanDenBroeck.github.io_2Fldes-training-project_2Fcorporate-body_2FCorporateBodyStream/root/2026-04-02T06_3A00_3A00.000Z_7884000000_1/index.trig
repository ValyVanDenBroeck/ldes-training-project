    <http://www.w3.org/2004/02/skos/core#prefLabel> "Comhshocraíocht Wassenaar"@ga, "Wassenaarské usporiadanie"@sk, "Intesa di Wassenaar"@it, "Wassenaar-Abkommen"@de, "Acuerdo de Wassenaar"@es, "Arrangement de Wassenaar"@fr, "Wassenaarski aranžman"@hr, "L-Arranġament ta’ Wassenaar"@mt, "Wassenaarski sporazum"@sl, "Διακανονισμός του Wassenaar"@el, "Aranjamentul de la Wassenaar"@ro, "Wassenaarské ujednání"@cs, "Wassenaararrangementet"@da, "Wassenaarin järjestely"@fi, "Wassenaar susitarimas"@lt, "Wassenaar Arrangement"@nl, "Wassenaar Arrangement"@en, "Acordo de Wassenaar"@pt, "Porozumienie z Wassenaar"@pl, "Wassenaar-arrangemanget"@sv, "Vasenāras vienošanās"@lv, "Wassenaari Megállapodás"@hu, "Споразумение от Васенаар"@bg, "Wassenaari kokkulepe"@et;
    <http://www.w3.org/2004/02/skos/core#definition> "The Wassenaar Arrangement is a multilateral export control regime. It been established in order to contribute to regional and international security and stability, by promoting transparency and greater responsibility in transfers of conventional arms and dual-use goods and technologies."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "ARRANG_WSS"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "ARRANG_WSS"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001012"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "The Wassenaar Arrangement on Export Controls for Conventional Arms and Dual-Use Goods and Technologies"@en;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/ARRANG_WSS_1996_0>;
    <http://purl.org/dc/elements/1.1/identifier> "ARRANG_WSS";
    <http://publications.europa.eu/resource/authority/op-code> "ARRANG_WSS";
    <http://publications.europa.eu/ontology/authority/op-code> "ARRANG_WSS";
    <http://publications.europa.eu/ontology/authority/start.use> "1996-07-12";
    <http://publications.europa.eu/ontology/authority/authority-code> "ARRANG_WSS"
}
