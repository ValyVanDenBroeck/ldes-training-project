    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "United Nations Committee on Crime Prevention and Control"@en, "Комитет на ООН за криминална превенция и контрол"@bg, "Comité des Nations unies pour la prévention du crime et la lutte contre la délinquance"@fr, "Ühinenud Rahvaste Organisatsiooni kuriteoennetuse ja kontrolli komisjon"@et, "Apvienoto Nāciju Organizācijas Noziedzības novēršanas un kontroles komiteja"@lv, "YK:n rikosten torjuntaa ja valvontaa käsittelevä toimikunta"@fi, "Kumitat tan-Nazzjonijiet Uniti għall-Prevenzjoni tal-Kriminalità u l-Kontroll"@mt, "Comité das Nações Unidas para a Prevenção e o Controlo do Crime"@pt, "Comisión de las Naciones Unidas sobre Prevención y Control"@es;
    <http://www.w3.org/2004/02/skos/core#definition> "The political agreement to establish the Commission derived from a ministerial meeting held in Versailles in 1991. It was preceded by a more technically focussed Committee on Crime Prevention and Control, formed in 1971 to replace an earlier expert advisory committee and tackle a broadened scope of UN interest in criminal justice policy."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "UNCCPC"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001204"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNCCPC"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Auschuss für Verbrechensverhütung und -bekämpfung"@de, "Committee on Crime Prevention and Control"@en, "Comitato per la prevenzione del crimine e della lotte alle delinquenza"@it, "Komitéen for Forebyggelse af Kriminalitet"@da, "Comité pour la prévention du crime et la lutte contre la délinquance"@fr, "Comité de Prevención del Delito y Lucha contra la Delincuencia"@es;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNCCPC_1971_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNCCPC";
    <http://publications.europa.eu/resource/authority/op-code> "UNCCPC";
    <http://publications.europa.eu/ontology/authority/op-code> "UNCCPC";
    <http://publications.europa.eu/ontology/authority/start.use> "1971-06-20";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNCCPC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>;
    <http://publications.europa.eu/ontology/authority/end.use> "1992-02-05"
}
<../../../index.trig> <https://w3id.org/tree#member> <#49a78f0e1ccce724a21126b42b7fb109>.
