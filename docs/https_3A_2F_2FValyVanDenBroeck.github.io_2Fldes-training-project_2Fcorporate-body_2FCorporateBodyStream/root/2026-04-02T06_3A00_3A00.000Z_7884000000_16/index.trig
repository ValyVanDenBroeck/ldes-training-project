    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T17:12:17.623Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#3e0045d1b369aa02cfb45b1c8c3015ab> {
<http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_CDPPE> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "true";
    <http://www.w3.org/2002/07/owl#deprecated> true;
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Comitato direttivo per le politiche e le pratiche in materia di istruzione"@it, "Comité Diretor de Políticas e Práticas Educativas"@pt, "Διευθύνουσα επιτροπή για την εκπαιδευτική πολιτική και πρακτική"@el, "Oktatáspolitikáért és Oktatási Gyakorlatért Felelős Irányítóbizottság"@hu, "Styrkommittén för utbildningsfrågor"@sv, "Řídící výbor pro politiku a praxi v oblasti vzdělávání"@cs, "Lenkungsausschuss für Bildungspolitik und -praxis"@de, "Usmerjevalni odbor za izobraževalne politike in prakse"@sl, "Hariduspoliitika ja -praktika juhtkomitee"@et, "Управителен комитет за образователна политика и практика"@bg, "Comitetul director pentru politica și practica în domeniul educației"@ro, "Comité directeur pour les politiques et pratiques éducatives"@fr, "Koulutuksen ja tutkimuksen johtokomitea"@fi, "Comité Director de Políticas y Prácticas Educativas"@es, "Komitet Sterujący ds. Polityki i Praktyki Edukacyjnej"@pl, "Steering Committee for Education Policy and Practice"@en, "Upravljački odbor za obrazovnu politiku i praksu"@hr, "Stuurgroep Onderwijsbeleid en -praktijk"@nl, "Styringsgruppen for uddannelsespolitik og -praksis"@da, "An Coiste Stiúrtha um Beartas agus Cleachtas Oideachais"@ga, "Kumitat tat-Tmexxija għall-Politika tal-Edukazzjoni u l-Prattika"@mt, "Riadiaci výbor pre politiku a prax v oblasti vzdelávania"@sk, "Izglītības politikas un prakses koordinācijas komiteja"@lv, "Švietimo politikos ir praktikos iniciatyvinis komitetas"@lt;
    <http://www.w3.org/2004/02/skos/core#definition> "Sous l’autorité du Comité des Ministres, et dans le cadre de la Convention culturelle européenne, le CDPPE supervisera les programmes du Conseil de l’Europe dans le domaine de l’éducation et conseillera le Comité des Ministres sur toutes les questions relevant de son domaine de compétence."@fr, "Under the authority of the Committee of Ministers and in the framework of the European Cultural Convention, the CDPPE will oversee the Council of Europe’s programmes in the field of education and advise the Committee of Ministers on all questions within its area of competence."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "COU_EUR_CDPPE"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COU_EUR_CDPPE"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001316"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "CDPPE"@en, "CDPPE"@fr;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR_CDPPE_2012_0>;
    <http://purl.org/dc/elements/1.1/identifier> "COU_EUR_CDPPE";
    <http://publications.europa.eu/resource/authority/op-code> "COU_EUR_CDPPE";
    <http://publications.europa.eu/ontology/authority/op-code> "COU_EUR_CDPPE";
    <http://publications.europa.eu/ontology/authority/start.use> "2012-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "COU_EUR_CDPPE";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/COU_EUR>;
    <http://publications.europa.eu/ontology/authority/end.use> "2021-12-31"
}
