<#7e355c8b15fed4e04eaadf1bdbceb016> {
<http://publications.europa.eu/resource/authority/corporate-body/UNODC> a <http://www.w3.org/2004/02/skos/core#Concept>;
    <http://publications.europa.eu/ontology/authority/deprecated> "false";
    <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/corporate-body>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Büro der Vereinten Nationen für Drogen- und Verbrechensbekämpfung"@de, "Biroul Organizației Națiunilor Unite pentru Droguri și Criminalitate"@ro, "Uffiċċju tan-Nazzjonijiet Uniti kontra d-Droga u l-Kriminalità"@mt, "Γραφείο των Ηνωμένων Εθνών για τον ’Ελεγχο των Ναρκωτικών και την Πρόληψη του Εγκλήματος"@el, "Jungtinių Tautų Narkotikų kontrolės ir nusikalstamumo prevencijos biuras"@lt, "Az ENSZ Kábítószer- és Bűnügyi Hivatala"@hu, "Ured Ujedinjenih naroda za borbu protiv droge i kriminala"@hr, "Úřad OSN pro drogy a kriminalitu"@cs, "ÜRO uimastite ja kuritegevuse vastu võitlemise büroo"@et, "Ufficio delle Nazioni Unite contro la droga e il crimine"@it, "Apvienoto Nāciju Organizācijas Narkotiku un noziedzības novēršanas birojs"@lv, "Oficina de las Naciones Unidas contra la Droga y el Delito"@es, "FN:s drog- och brottsbekämpningsbyrå"@sv, "Bureau van de Verenigde Naties voor drugs- en misdaadbestrijding"@nl, "Office des Nations unies contre la drogue et le crime"@fr, "Oifig na Náisiún Aontaithe i leith Drugaí agus Coireachta"@ga, "Gabinete para a Droga e a Criminalidade"@pt, "YK:n huumeiden ja rikollisuuden torjunnasta vastaava toimisto"@fi, "United Nations Office on Drugs and Crime"@en, "Úrad Organizácie Spojených národov pre drogy a kriminalitu"@sk, "Служба на ООН по наркотиците и престъпността"@bg, "Urad Združenih narodov za droge in kriminal"@sl, "Biuro Narodów Zjednoczonych ds. Narkotyków i Przestępczości"@pl, "FN’s Kontor for Narkotikakontrol og Kriminalitetsbekæmpelse"@da;
    <http://www.w3.org/2004/02/skos/core#definition> "United Nations Office on Drugs and Crime is a global leader in the fight against illicit drugs and international crime. Established through a merger between the United Nations Drug Control Programme and the Centre for International Crime Prevention, UNODC relies on voluntary contributions, mainly from Governments, for 90 per cent of its budget. UNODC is mandated to assist Member States in their struggle against illicit drugs, crime and terrorism. In the Millennium Declaration, Member States also resolved to intensify efforts to fight transnational crime in all its dimensions, to redouble the efforts to implement the commitment to counter the world drug problem and to take concerted action against international terrorism."@en, "L’ONUDC travaille directement avec les gouvernements, les organisations internationales, les autres organes des Nations Unies et la société civile pour développer et mettre en œuvre des programmes répondant aux besoins des pays et des régions. La stratégie de l’ONUDC pour le lutte contre la criminalité, la drogue et le terrorisme intègre une approche thématique et une approche régionale pour assurer des initiatives proactives, centrées et efficaces."@fr;
    <http://www.w3.org/2004/02/skos/core#notation> "UNODC"^^<http://publications.europa.eu/ontology/euvoc#LAC>, "COB0001236"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "UNODC"^^<http://publications.europa.eu/ontology/euvoc#NAC>;
    <http://www.w3.org/2004/02/skos/core#altLabel> "Oficina contra la Droga y el Delito"@es, "СНПООН"@bg, "ONUDC"@fr, "YK:n huume- ja rikosjärjestö"@fi, "Úřad pro drogy a kriminalitu"@cs, "Office contre la drogue et le crime"@fr, "ANO Narkotiku kontroles programma"@lv, "UNODC"@ro, "UNODC"@hr, "UNODC"@lt, "UNODC"@pl, "UNODC"@mt, "UNODC"@lv, "UNODC"@et, "UNODC"@en, "UNODC"@sl, "UNODC"@pt, "UNODC"@da, "UNODC"@es, "UNODC"@nl, "UNODC"@ga, "UNODC"@cs, "UNODC"@hu, "UNODC"@el, "UNODC"@it, "UNODC"@de, "UNODC"@fi, "UNODC"@sk, "UNODC"@sv;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/UNODC_1997_0>;
    <http://purl.org/dc/elements/1.1/identifier> "UNODC";
    <http://publications.europa.eu/resource/authority/op-code> "UNODC";
    <http://publications.europa.eu/ontology/authority/op-code> "UNODC";
    <http://publications.europa.eu/ontology/authority/start.use> "1997-11-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "UNODC";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/UNO>
}
