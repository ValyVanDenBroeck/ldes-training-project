    <http://www.w3.org/2004/02/skos/core#prefLabel> "Statistički ured EFTA-e"@hr, "Статистическата служба на ЕАСТ"@bg, "Statistický úřad ESVO"@cs, "Oifig Staidrimh CSTE"@ga, "EFTA Statistical Office"@en, "Serviço de Estatística da EFTA"@pt, "Bureau voor de statistiek van de EVA"@nl, "EFTA’s Statistiske Kontor"@da, "Ufficio statistico dell’EFTA"@it, "Στατιστική Υπηρεσία της ΕΖΕΣ"@el, "EFTAn tilastolaitos"@fi, "Urząd Statystyczny EFTA"@pl, "Oficina Estadística de la AELC"@es, "Biroul de statistică al AELS"@ro, "EFTA statistikaamet"@et, "Eftas statistikkontor"@sv, "Statistische EFTA-Amt"@de, "Štatistický úrad EZVO"@sk, "EFTA Statisztikai Hivatal"@hu, "Statistični urad Efte"@sl, "Uffiċju tal-Istatistika tal-EFTA"@mt, "ELPA statistikos biuras"@lt, "EBTA Statistikas birojs"@lv, "Office statistique de l’AELE"@fr;
    <http://www.w3.org/2004/02/skos/core#definition> "The EFTA Statistical Office (ESO) was established as a liaison office between the EFTA National Statistical Institutes and Eurostat. Although ESO’s tasks have expanded and today include activities in the field of statistical cooperation with partners beyond the EU and EFTA (\"statistical capacity building\"), its main objective was and still is to promote the full inclusion of the EFTA States in the continuously evolving European Statistical System."@en;
    <http://www.w3.org/2004/02/skos/core#notation> "EFTA_STAT"^^<http://publications.europa.eu/ontology/euvoc#NAC>, "COB0001584"^^<http://publications.europa.eu/ontology/euvoc#XML_RECORD>, "EFTA_STAT"^^<http://publications.europa.eu/ontology/euvoc#LAC>;
    <http://www.w3.org/2002/07/owl#sameAs> <http://publications.europa.eu/resource/authority/corporate-body/EFTA_STAT_1991_0>;
    <http://purl.org/dc/elements/1.1/identifier> "EFTA_STAT";
    <http://publications.europa.eu/resource/authority/op-code> "EFTA_STAT";
    <http://publications.europa.eu/ontology/authority/op-code> "EFTA_STAT";
    <http://publications.europa.eu/ontology/authority/start.use> "1991-01-01";
    <http://publications.europa.eu/ontology/authority/authority-code> "EFTA_STAT";
    <http://www.w3.org/2004/02/skos/core#broader> <http://publications.europa.eu/resource/authority/corporate-body/EFTA>
}
